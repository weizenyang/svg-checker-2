				justify-content: center;
				width: 18px;
				height: 22px;
				color: rgb(163 163 163);
				cursor: grab;
				border-radius: 4px;
				opacity: 0.45;
				transition: opacity 100ms ease, color 100ms ease, background-color 100ms ease;
				z-index: 2;
				background: transparent;
