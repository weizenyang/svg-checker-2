			function escapeHtml(s) {
				const div = document.createElement('div');
				div.textContent = s;
				return div.innerHTML;
			}

			function addRow(cells: string[] = ['', '', ''], options?: { silent?: boolean }) {
				const silent = options?.silent === true;
				const tr = document.createElement('tr');
				tr.className = 'border-t border-neutral-200';
				tr.innerHTML = `
					<td class="p-1"><input type="text" class="cell-input w-full p-1.5 border border-neutral-200 rounded text-sm" data-col="0" value="${escapeHtml(cells[0] ?? '')}" spellcheck="false" autocomplete="off" autocapitalize="off" autocorrect="off" /></td>
					<td class="p-1"><input type="text" class="cell-input w-full p-1.5 border border-neutral-200 rounded text-sm" data-col="1" value="${escapeHtml(cells[1] ?? '')}" spellcheck="false" autocomplete="off" autocapitalize="off" autocorrect="off" /></td>
					<td class="p-1"><input type="text" class="cell-input w-full p-1.5 border border-neutral-200 rounded text-sm" data-col="2" value="${escapeHtml(cells[2] ?? '')}" spellcheck="false" autocomplete="off" autocapitalize="off" autocorrect="off" /></td>
					<td class="p-1"><button type="button" class="delete-row px-2 py-1 text-xs rounded bg-red-100 text-red-800 hover:bg-red-200">Del</button></td>
				`;
				tr.querySelector('.delete-row')!.addEventListener('click', () => {
					tr.remove();
					renderPreview();
				});
				tbody.appendChild(tr);
				tr.querySelectorAll('.cell-input').forEach((el) => {
					el.addEventListener('input', () => {
						renderPreview();
					});
				});
				if (!silent) renderPreview();
			}

			const sheetTabsEl = document.getElementById('sheet-tabs');
			const addSheetBtn = document.getElementById('add-sheet-btn');

			function commitActiveSheet() {
				if (!sheets[activeIndex]) return;
				sheets[activeIndex].rows = getTableData();
			}

			function replaceEditorRows(rows) {
				const capped = normalizeSheetRows(rows).slice(0, MAX_IMPORT_ROWS);
				tbody.innerHTML = '';
				for (let i = 0; i < capped.length; i++) {
					addRow(capped[i], { silent: i < capped.length - 1 });
				}
			}

			function scrollActiveTabIntoView() {
				const el = sheetTabsEl?.querySelector(`[data-sheet-tab="${activeIndex}"]`);
				if (el && 'scrollIntoView' in el) {
					el.scrollIntoView({ block: 'nearest', inline: 'nearest', behavior: 'smooth' });
				}
			}

			function renderTabBar() {
				if (!sheetTabsEl) return;
				sheetTabsEl.innerHTML = '';
				sheets.forEach((sheet, i) => {
					const wrap = document.createElement('div');
					wrap.className = 'inline-flex items-stretch shrink-0 rounded-md border border-neutral-200 overflow-hidden';
					const tabMain = document.createElement('div');
					tabMain.setAttribute('role', 'tab');
					tabMain.tabIndex = 0;
					tabMain.setAttribute('aria-selected', i === activeIndex ? 'true' : 'false');
					tabMain.dataset.sheetTab = String(i);
					tabMain.className =
						i === activeIndex
							? 'px-2.5 py-1.5 max-w-[220px] min-w-[3rem] flex items-center text-sm font-medium bg-neutral-800 text-white cursor-default select-none'
							: 'px-2.5 py-1.5 max-w-[220px] min-w-[3rem] flex items-center text-sm font-medium bg-neutral-100 text-neutral-800 hover:bg-neutral-200 cursor-pointer select-none';
					const labelSpan = document.createElement('span');
					labelSpan.className = 'truncate';
					labelSpan.textContent = sheet.label;
					labelSpan.title = 'Double-click to rename (used for export filename)';
					tabMain.appendChild(labelSpan);
					tabMain.addEventListener('click', () => setActiveSheet(i));
					tabMain.addEventListener('keydown', (e) => {
						if (e.key === 'Enter' || e.key === ' ') {
							e.preventDefault();
							setActiveSheet(i);
						}
					});
					labelSpan.addEventListener('dblclick', (e) => {
						e.stopPropagation();
						e.preventDefault();
						commitActiveSheet();
						const inp = document.createElement('input');
						inp.type = 'text';
						inp.value = sheet.label;
						inp.className =
							'w-full min-w-[10rem] max-w-[200px] px-1 py-0.5 text-sm rounded border border-violet-500 bg-white text-neutral-900 shadow-sm';
						let cancelled = false;
						inp.addEventListener('keydown', (ev) => {
							if (ev.key === 'Escape') {
								ev.preventDefault();
								cancelled = true;
								renderTabBar();
								scrollActiveTabIntoView();
							}
						});
						inp.addEventListener('blur', () => {
							if (cancelled) return;
							const v = inp.value.trim().slice(0, 120) || sheet.label;
							sheets[i].label = v;
							persistState();
							renderTabBar();
							scrollActiveTabIntoView();
						});
						labelSpan.replaceWith(inp);
						inp.focus();
						inp.select();
					});

					const close = document.createElement('button');
					close.type = 'button';
					close.setAttribute('aria-label', `Close ${sheet.label}`);
					close.className =
						'px-1.5 text-sm leading-none border-l border-neutral-200 bg-neutral-50 text-neutral-600 hover:bg-red-50 hover:text-red-700 disabled:opacity-40 disabled:hover:bg-neutral-50 disabled:hover:text-neutral-600';
					close.textContent = '×';
					close.title = sheets.length <= 1 ? 'Close sheet (resets to a new empty sheet)' : 'Close sheet';
					close.addEventListener('click', (ev) => {
						ev.stopPropagation();
						removeSheet(i);
					});

					wrap.appendChild(tabMain);
					wrap.appendChild(close);
					sheetTabsEl.appendChild(wrap);
				});
				updateBatchExportVisibility();
			}

			function updateBatchExportVisibility() {
				const multi = sheets.length > 1;
				const count = multi ? `${sheets.length}` : '';
				if (batchExportPngBtn) {
					batchExportPngBtn.disabled = !multi;
					batchExportPngBtn.title = multi ? '' : 'Add another sheet to export all.';
				}
				if (batchExportCsvBtn) {
					batchExportCsvBtn.disabled = !multi;
					batchExportCsvBtn.title = multi ? '' : 'Add another sheet to export all.';
				}
				if (batchExportPngCount) batchExportPngCount.textContent = count;
				if (batchExportCsvCount) batchExportCsvCount.textContent = count;
			}

			function setActiveSheet(i) {
				if (i === activeIndex) return;
				commitActiveSheet();
				activeIndex = Math.max(0, Math.min(i, sheets.length - 1));
				replaceEditorRows(sheets[activeIndex].rows);
				renderTabBar();
				renderPreview();
				scrollActiveTabIntoView();
			}

			function removeSheet(index) {
				commitActiveSheet();
				sheets.splice(index, 1);
				if (sheets.length === 0) {
					sheets.push({ id: uid(), label: 'Sheet 1', rows: [['', '', '']] });
					activeIndex = 0;
				} else {
					if (activeIndex >= sheets.length) activeIndex = sheets.length - 1;
					else if (index < activeIndex) activeIndex--;
				}
				replaceEditorRows(sheets[activeIndex].rows);
				renderTabBar();
				renderPreview();
				scrollActiveTabIntoView();
				persistState();
			}

			function addEmptySheet() {
				commitActiveSheet();
				if (sheets.length >= MAX_SHEETS) return;
				const n = sheets.length + 1;
				sheets.push({ id: uid(), label: `Sheet ${n}`, rows: [['', '', '']] });
				activeIndex = sheets.length - 1;
				replaceEditorRows(sheets[activeIndex].rows);
				renderTabBar();
				renderPreview();
				scrollActiveTabIntoView();
			}

			async function importCsvFiles(fileList) {
				const files = Array.from(fileList ?? []).filter((f): f is File => f instanceof File && (f.name.toLowerCase().endsWith('.csv') || f.type === 'text/csv'));
				if (!files.length) return;
				commitActiveSheet();
				let added = 0;
				let firstNewIndex = -1;
				for (const file of files) {
					if (sheets.length >= MAX_SHEETS) break;
					const text = await readFileAsText(file);
					const rows = parseCSV(text);
					const body = rows.length > 0 ? rows.slice(0, MAX_IMPORT_ROWS) : [['', '', '']];
					const label = file.name.replace(/\.csv$/i, '') || 'Imported';
					sheets.push({ id: uid(), label, rows: body });
					if (firstNewIndex < 0) firstNewIndex = sheets.length - 1;
					added++;
				}
				if (added > 0 && firstNewIndex >= 0) {
					activeIndex = firstNewIndex;
					replaceEditorRows(sheets[activeIndex].rows);
					renderTabBar();
					renderPreview();
					scrollActiveTabIntoView();
				}
			}

			function importPastedCsv(text) {
				const rows = parseCSV(text);
				if (!rows.length) return;
				commitActiveSheet();
				if (sheets.length >= MAX_SHEETS) return;
				const body = rows.slice(0, MAX_IMPORT_ROWS);
				let label = 'Pasted';
				let n = 2;
				while (sheets.some((s) => s.label === label)) {
					label = `Pasted (${n})`;
					n++;
				}
				sheets.push({ id: uid(), label, rows: body });
				activeIndex = sheets.length - 1;
				replaceEditorRows(sheets[activeIndex].rows);
				renderTabBar();
				renderPreview();
				scrollActiveTabIntoView();
			}

			function importMatrixAsNewSheet(matrix: string[][], baseLabel = 'AI parsed') {
				const body = (Array.isArray(matrix) ? matrix : [])
					.map((r) => [String(r[0] ?? ''), String(r[1] ?? ''), String(r[2] ?? '')])
					.filter((r) => r.some((c) => c.length))
					.slice(0, MAX_IMPORT_ROWS);
				if (!body.length) return false;
				commitActiveSheet();
				if (sheets.length >= MAX_SHEETS) return false;
				let label = baseLabel;
				let n = 2;
				while (sheets.some((s) => s.label === label)) {
					label = `${baseLabel} (${n})`;
					n++;
				}
				sheets.push({ id: uid(), label, rows: body.length ? body : [['', '', '']] });
				activeIndex = sheets.length - 1;
				replaceEditorRows(sheets[activeIndex].rows);
				renderTabBar();
				renderPreview();
				scrollActiveTabIntoView();
				return true;
			}

			function labelForAiAttachment(index: number, total: number, attachmentName?: string) {
				if (total <= 1) return 'AI parsed';
				const raw = (attachmentName ?? '').replace(/\.[^.]+$/i, '').trim();
				if (raw) return raw.length > 48 ? raw.slice(0, 45) + '…' : raw;
				return `AI ${index + 1}`;
			}

			function dedupeSheetLabel(baseLabel: string) {
				let label = baseLabel;
				let n = 2;
				while (sheets.some((s) => s.label === label)) {
					label = `${baseLabel} (${n})`;
					n++;
				}
				return label;
			}

			function rowsFromAiPart(part: { rows: { a?: string; b?: string; c?: string }[] }) {
				const matrix = part.rows.map((row) => [
					String(row.a ?? ''),
					normalizeMetricTypography(String(row.b ?? '')),
					normalizeImperialTypography(String(row.c ?? ''))
				]);
				const body = matrix
					.map((r) => [String(r[0] ?? ''), String(r[1] ?? ''), String(r[2] ?? '')])
					.filter((r) => r.some((c) => c.length))
					.slice(0, MAX_IMPORT_ROWS);
				return body.length ? body : [['', '', '']];
			}

			function extractJsonRowsFromAssistantText(raw: string): { rows: { a?: string; b?: string; c?: string }[] } {
				let t = String(raw ?? '').trim();
				const fence = /```(?:json)?\s*([\s\S]*?)```/;
				const fm = t.match(fence);
				if (fm) t = fm[1].trim();

				function tryParse(s: string): unknown {
					return JSON.parse(s);
				}

				let parsed: unknown;
				try {
					parsed = tryParse(t);
				} catch {
					const start = t.indexOf('{');
					const end = t.lastIndexOf('}');
					if (start < 0 || end <= start) {
						throw new Error('Model did not return JSON with a "rows" array. Try again or pick a stronger model.');
					}
					parsed = tryParse(t.slice(start, end + 1));
				}
				if (!parsed || typeof parsed !== 'object' || !Array.isArray((parsed as { rows?: unknown }).rows)) {
					throw new Error('JSON must be an object with a "rows" array.');
				}
				return parsed as { rows: { a?: string; b?: string; c?: string }[] };
			}

			async function parseOpenRouterResponse(res: Response): Promise<unknown> {
				const text = await res.text();
				if (!text) return {};
				try {
					return JSON.parse(text) as unknown;
				} catch {
					return { _raw: text };
				}
			}

			/** 429 = rate limit; free models hit this often. One retry after Retry-After or short backoff. */
			async function parseDimensionsWithOpenRouter(options: {
				apiKey: string;
				model: string;
				pastedText: string;
				imageDataUrls: string[];
				reportStatus?: (msg: string) => void;
				onImagePart?: (detail: {
					index: number;
					total: number;
					part: ReturnType<typeof extractJsonRowsFromAssistantText>;
				}) => void;
			}) {
				let DIMENSION_PARSE_SYSTEM_PROMPT: string;
				let OPENROUTER_CHAT_URL: string;
				try {
					const mod = await import('../lib/dimension-ai-prompt.ts');
					DIMENSION_PARSE_SYSTEM_PROMPT = mod.DIMENSION_PARSE_SYSTEM_PROMPT;
					OPENROUTER_CHAT_URL = mod.OPENROUTER_CHAT_URL;
				} catch {
					throw new Error('AI prompt module failed to load.');
				}

				const { apiKey, model, pastedText, imageDataUrls, reportStatus, onImagePart } = options;
				const trimmed = pastedText?.trim() ?? '';
				const imgs = Array.isArray(imageDataUrls) ? imageDataUrls.filter(Boolean) : [];
				if (!trimmed && imgs.length === 0) {
					throw new Error('Add pasted text and/or an image.');
				}

				type UserPart = { type: string; text?: string; image_url?: { url: string } };

				function userPartsForSingleImage(imageUrl: string): UserPart[] {
					const userParts: UserPart[] = [];
					if (trimmed) {
						userParts.push({
							type: 'text',
							text: `Convert the following into JSON as specified in the system message. Also use the attached image for any dimensions or labels not fully captured in the text.\n\n${trimmed}`
						});
					} else {
						userParts.push({
							type: 'text',
							text: 'Read all room or area labels and metric/imperial dimensions from the attached image. Output JSON as specified in the system message.'
						});
					}
					userParts.push({ type: 'image_url', image_url: { url: imageUrl } });
					return userParts;
				}

				const headers = {
					Authorization: `Bearer ${apiKey}`,
					'Content-Type': 'application/json',
					'HTTP-Referer': typeof window !== 'undefined' ? window.location.origin : '',
					'X-Title': '3-Column Dimension Parser'
				};

				async function completeOneRequest(
					userContent: string | UserPart[]
				): Promise<ReturnType<typeof extractJsonRowsFromAssistantText>> {
					const body = JSON.stringify({
						model,
						temperature: 0.15,
						messages: [
							{ role: 'system', content: DIMENSION_PARSE_SYSTEM_PROMPT },
							{ role: 'user', content: userContent }
						]
					});

					let res = await fetch(OPENROUTER_CHAT_URL, { method: 'POST', headers, body });
					let data = (await parseOpenRouterResponse(res)) as {
						error?: { message?: string };
						choices?: { message?: { content?: string } }[];
					};

					if (res.status === 429) {
						const ra = res.headers.get('Retry-After');
						const sec = Math.min(90, Math.max(4, parseInt(ra || '10', 10) || 10));
						reportStatus?.(`Rate limited (429). Retrying in ${sec}s…`);
						await new Promise((r) => setTimeout(r, sec * 1000));
						res = await fetch(OPENROUTER_CHAT_URL, { method: 'POST', headers, body });
						data = (await parseOpenRouterResponse(res)) as typeof data;
					}

					if (!res.ok) {
						const apiMsg =
							typeof data?.error?.message === 'string'
								? data.error.message
								: typeof (data as { error?: string })?.error === 'string'
									? (data as { error: string }).error
									: '';
						if (res.status === 429) {
							throw new Error(
								`Rate limited (429). Free models have tight quotas on OpenRouter. Wait a few minutes, try again, add credits, or pick a non-free model. ${apiMsg || ''}`.trim()
							);
						}
						throw new Error(apiMsg || `OpenRouter HTTP ${res.status}`);
					}
					const content = data?.choices?.[0]?.message?.content;
					if (!content || typeof content !== 'string') {
						throw new Error('Empty response from model.');
					}
					return extractJsonRowsFromAssistantText(content);
				}

				// Text-only: single request.
				if (imgs.length === 0) {
					const single = await completeOneRequest(
						`Convert the following into JSON as specified in the system message.\n\n${trimmed}`
					);
					return { parts: [single] };
				}

				// One image: single request (caller imports one sheet).
				if (imgs.length === 1) {
					reportStatus?.('Parsing image…');
					const single = await completeOneRequest(userPartsForSingleImage(imgs[0]));
					return { parts: [single] };
				}

				// Multiple images: parallel requests; onImagePart runs as each completes (for progressive tab fill).
				reportStatus?.(`Parsing ${imgs.length} images in parallel…`);
				const parts = await Promise.all(
					imgs.map((url, i) =>
						completeOneRequest(userPartsForSingleImage(url)).then((part) => {
							onImagePart?.({ index: i, total: imgs.length, part });
							return part;
						})
					)
				);
				return { parts };
			}

			tbody.innerHTML = '';
			const loaded = loadState();
			sheets = loaded.sheets;
			activeIndex = loaded.activeIndex;
			replaceEditorRows(sheets[activeIndex].rows);
			renderTabBar();
			isHydrating = false;
			renderPreview();
			scrollActiveTabIntoView();

			document.addEventListener('dragover', (e) => {
				e.preventDefault();
			});
			document.addEventListener('drop', (e) => {
				e.preventDefault();
				const dt = e.dataTransfer?.files;
				if (dt?.length) void importCsvFiles(dt);
			});

			fileInput.addEventListener('change', () => {
				const files = fileInput.files;
				if (!files?.length) return;
				void importCsvFiles(files).finally(() => {
					fileInput.value = '';
				});
			});

			addRowBtn.addEventListener('click', () => addRow());

			tbody.addEventListener('focusout', (e) => {
				const t = e.target;
				if (!(t instanceof HTMLInputElement) || !t.classList.contains('cell-input')) return;
				const col = t.dataset.col;
				const n =
					col === '1'
						? normalizeMetricTypography(t.value)
						: col === '2'
							? normalizeImperialTypography(t.value)
							: null;
				if (n !== null && n !== t.value) {
					t.value = n;
					t.dispatchEvent(new Event('input', { bubbles: true }));
				}
			});

			importPasteBtn.addEventListener('click', () => {
				const text = (csvPaste.value ?? '').trim();
				if (!text) return;
				importPastedCsv(text);
				csvPaste.value = '';
			});

			const OPENROUTER_KEY_FROM_ENV =
				typeof import.meta.env.PUBLIC_OPENROUTER_API_KEY === 'string'
					? import.meta.env.PUBLIC_OPENROUTER_API_KEY.trim()
					: '';

			const aiApiKey = document.getElementById('ai-api-key') as HTMLInputElement | null;
			const aiRememberKey = document.getElementById('ai-remember-key') as HTMLInputElement | null;
			const aiModelSelect = document.getElementById('ai-model-select') as HTMLSelectElement | null;
			const aiModelCustomWrap = document.getElementById('ai-model-custom-wrap') as HTMLDivElement | null;
			const aiModelCustom = document.getElementById('ai-model-custom') as HTMLInputElement | null;
			const aiImageInput = document.getElementById('ai-image-input') as HTMLInputElement | null;
			const aiAttachBtn = document.getElementById('ai-attach-btn') as HTMLButtonElement | null;
			const aiAttachmentChips = document.getElementById('ai-attachment-chips') as HTMLDivElement | null;
			const pasteComposer = document.getElementById('paste-composer') as HTMLDivElement | null;
			const csvParseAiBtn = document.getElementById('csv-parse-ai-btn') as HTMLButtonElement | null;
			const aiStatus = document.getElementById('ai-status') as HTMLSpanElement | null;
			const aiCopyPrompt = document.getElementById('ai-copy-prompt') as HTMLButtonElement | null;
			const aiOptionsTrigger = document.getElementById('ai-options-trigger') as HTMLButtonElement | null;
			const aiOptionsPanel = document.getElementById('ai-options-panel') as HTMLDivElement | null;
			const manualKeyRow = document.getElementById('ai-manual-key-row') as HTMLDivElement | null;

			function getEffectiveApiKey(): string {
				if (OPENROUTER_KEY_FROM_ENV) return OPENROUTER_KEY_FROM_ENV;
				return (aiApiKey?.value ?? '').trim();
			}

			if (OPENROUTER_KEY_FROM_ENV) manualKeyRow?.classList.add('hidden');
			else manualKeyRow?.classList.remove('hidden');

			function positionAiOptionsPanel() {
				const trigger = aiOptionsTrigger;
				const panel = aiOptionsPanel;
				if (!trigger || !panel || panel.classList.contains('hidden')) return;
				const r = trigger.getBoundingClientRect();
				const maxW = Math.min(352, window.innerWidth - 16);
				const left = Math.max(8, Math.min(r.right - maxW, window.innerWidth - maxW - 8));
				panel.style.setProperty('left', `${left}px`);
				panel.style.setProperty('width', `${maxW}px`);
				panel.style.setProperty('top', `${r.bottom + 6}px`);
				requestAnimationFrame(() => {
					const ph = panel.getBoundingClientRect().height;
					let top = r.bottom + 6;
					if (top + ph > window.innerHeight - 8) {
						top = Math.max(8, r.top - ph - 6);
					}
					panel.style.setProperty('top', `${top}px`);
				});
			}

			function setAiOptionsOpen(open: boolean) {
				if (!aiOptionsPanel || !aiOptionsTrigger) return;
				aiOptionsPanel.classList.toggle('hidden', !open);
				aiOptionsTrigger.setAttribute('aria-expanded', open ? 'true' : 'false');
				if (open) {
					requestAnimationFrame(() => {
						positionAiOptionsPanel();
					});
				}
			}

			aiOptionsTrigger?.addEventListener('click', (e) => {
				e.stopPropagation();
				const panelClosed = aiOptionsPanel?.classList.contains('hidden') ?? true;
				setAiOptionsOpen(panelClosed);
			});

			window.addEventListener('resize', () => {
				if (aiOptionsPanel && !aiOptionsPanel.classList.contains('hidden')) positionAiOptionsPanel();
			});
			window.addEventListener(
				'scroll',
				() => {
					if (aiOptionsPanel && !aiOptionsPanel.classList.contains('hidden')) positionAiOptionsPanel();
				},
				true
			);

			document.addEventListener('mousedown', (e) => {
				const t = e.target as Node;
				if (aiOptionsPanel?.classList.contains('hidden')) return;
				if (aiOptionsTrigger?.contains(t) || aiOptionsPanel?.contains(t)) return;
				setAiOptionsOpen(false);
			});

			try {
				const savedKey = localStorage.getItem(STORAGE_OPENROUTER_KEY);
				if (savedKey && aiApiKey && !OPENROUTER_KEY_FROM_ENV) aiApiKey.value = savedKey;
				const savedModel = localStorage.getItem(STORAGE_OPENROUTER_MODEL);
				if (savedModel && aiModelSelect) {
					const opt = Array.from(aiModelSelect.options).find((o) => o.value === savedModel);
					if (opt) aiModelSelect.value = savedModel;
					else if (aiModelCustom && aiModelCustomWrap) {
						aiModelSelect.value = '__custom';
						aiModelCustom.value = savedModel;
						aiModelCustomWrap.classList.remove('hidden');
					}
				}
			} catch {
				// ignore
			}

			aiModelSelect?.addEventListener('change', () => {
				const v = aiModelSelect?.value;
				if (v === '__custom') aiModelCustomWrap?.classList.remove('hidden');
				else aiModelCustomWrap?.classList.add('hidden');
			});

			aiCopyPrompt?.addEventListener('click', async () => {
				try {
					const { DIMENSION_PARSE_SYSTEM_PROMPT } = await import('../lib/dimension-ai-prompt.ts');
					await navigator.clipboard.writeText(DIMENSION_PARSE_SYSTEM_PROMPT);
					aiCopyPrompt.textContent = 'Copied';
					setTimeout(() => {
						aiCopyPrompt.textContent = 'Copy prompt';
					}, 1500);
				} catch {
					aiCopyPrompt.textContent = 'Copy failed';
				}
			});

			function readFileAsDataUrl(file: File): Promise<string> {
				return new Promise((resolve, reject) => {
					const r = new FileReader();
					r.onload = () => resolve(String(r.result));
					r.onerror = () => reject(r.error ?? new Error('read failed'));
					r.readAsDataURL(file);
				});
			}

			/** @type {{ id: string; name: string; dataUrl: string }[]} */
			let aiAttachments = [];

			function renderAiAttachmentChips() {
				const wrap = aiAttachmentChips;
				if (!wrap) return;
				wrap.innerHTML = '';
				if (aiAttachments.length === 0) {
					wrap.classList.add('hidden');
					return;
				}
				wrap.classList.remove('hidden');
				for (const att of aiAttachments) {
					const chip = document.createElement('div');
					chip.className =
						'inline-flex items-center gap-2 pl-1.5 pr-1 py-1 rounded-full bg-violet-100 border border-violet-200/90 text-xs text-violet-950 shadow-sm max-w-full';
					chip.dataset.attachmentId = att.id;
					const thumb = document.createElement('img');
					thumb.src = att.dataUrl;
					thumb.alt = '';
					thumb.className = 'w-8 h-8 rounded-md object-cover shrink-0 border border-white shadow-sm';
					const nameEl = document.createElement('span');
					nameEl.className = 'truncate max-w-[min(100%,200px)] font-medium';
					nameEl.textContent = att.name;
					const rm = document.createElement('button');
					rm.type = 'button';
					rm.className =
						'shrink-0 flex h-6 w-6 items-center justify-center rounded-full text-violet-700 hover:bg-violet-200/90 text-base leading-none';
					rm.setAttribute('aria-label', `Remove ${att.name}`);
					rm.textContent = '×';
					rm.addEventListener('click', () => {
						aiAttachments = aiAttachments.filter((x) => x.id !== att.id);
						renderAiAttachmentChips();
					});
					chip.appendChild(thumb);
					chip.appendChild(nameEl);
					chip.appendChild(rm);
					wrap.appendChild(chip);
				}
			}

			// OpenRouter vision models reliably accept these; HEIC/AVIF/BMP/TIFF/SVG are frequently rejected.
			const ACCEPTED_IMAGE_MIME_TYPES = new Set([
				'image/png',
				'image/jpeg',
				'image/jpg',
				'image/webp',
				'image/gif'
			]);
			const ACCEPTED_IMAGE_EXTENSIONS = ['png', 'jpg', 'jpeg', 'webp', 'gif'];

			function describeFileFormat(f: File): string {
				const ext = (f.name.split('.').pop() ?? '').toLowerCase();
				if (f.type) return f.type + (ext ? ` (.${ext})` : '');
				return ext ? `.${ext}` : 'unknown';
			}

			function isAcceptedImage(f: File): boolean {
				const mime = (f.type || '').toLowerCase();
				if (ACCEPTED_IMAGE_MIME_TYPES.has(mime)) return true;
				if (!mime && f.name) {
					const ext = (f.name.split('.').pop() ?? '').toLowerCase();
					return ACCEPTED_IMAGE_EXTENSIONS.includes(ext);
				}
				return false;
			}

			function reportImageFormatIssue(rejected: File[], nonImages: File[]) {
				if (!aiStatus) return;
				if (!rejected.length && !nonImages.length) return;
				const parts: string[] = [];
				if (rejected.length) {
					const list = rejected.map((f) => `${f.name} [${describeFileFormat(f)}]`).join(', ');
					parts.push(
						`Unsupported image format — vision models here accept PNG, JPEG, WebP, GIF. Rejected: ${list}`
					);
				}
				if (nonImages.length) {
					const list = nonImages.map((f) => `${f.name} [${describeFileFormat(f)}]`).join(', ');
					parts.push(`Not an image file: ${list}`);
				}
				const msg = parts.join(' · ');
				aiStatus.textContent = msg;
				// Dev: full details (raw MIME/extension) for debugging which formats slipped through.
				console.warn('[three-column] Image format check failed', {
					rejected: rejected.map((f) => ({ name: f.name, type: f.type, size: f.size })),
					nonImages: nonImages.map((f) => ({ name: f.name, type: f.type, size: f.size }))
				});
			}

			async function addAiImagesFromFileList(files: FileList | File[] | null | undefined) {
				if (!files?.length) return;
				const all = Array.from(files);
				const nonImages = all.filter((f) => !f.type.startsWith('image/') && !isAcceptedImage(f));
				const imageLike = all.filter((f) => f.type.startsWith('image/') || isAcceptedImage(f));
				const accepted = imageLike.filter(isAcceptedImage);
				const rejected = imageLike.filter((f) => !isAcceptedImage(f));

				for (const f of accepted) {
					try {
						aiAttachments.push({
							id: uid(),
							name: f.name,
							dataUrl: await readFileAsDataUrl(f)
						});
					} catch (e) {
						if (aiStatus) {
							aiStatus.textContent = `Could not read ${f.name}. See console for details.`;
						}
						console.error('[three-column] Failed to read image', f.name, e);
					}
				}
				renderAiAttachmentChips();
				if (rejected.length || nonImages.length) reportImageFormatIssue(rejected, nonImages);
			}

			aiAttachBtn?.addEventListener('click', () => aiImageInput?.click());

			aiImageInput?.addEventListener('change', async () => {
				await addAiImagesFromFileList(aiImageInput.files);
				aiImageInput.value = '';
			});

			function wireImageDropZone(el: HTMLElement | null) {
				if (!el) return;
				el.addEventListener('dragover', (e) => {
					if ([...(e.dataTransfer?.types ?? [])].includes('Files')) {
						e.preventDefault();
						e.dataTransfer!.dropEffect = 'copy';
					}
				});
				el.addEventListener('drop', (e) => {
					const fl = e.dataTransfer?.files;
					if (!fl?.length) return;
					const all = Array.from(fl);
					const hasCsv = all.some((f) => f.name.toLowerCase().endsWith('.csv') || f.type === 'text/csv');
					if (hasCsv) return; // let CSV drop handler take this
					e.preventDefault();
					e.stopPropagation();
					void addAiImagesFromFileList(all);
				});
			}

			function clipboardImageFilesFromPaste(e: ClipboardEvent): File[] {
				const cd = e.clipboardData;
				if (!cd) return [];
				const out: File[] = [];
				const items = cd.items;
				if (items) {
					for (let i = 0; i < items.length; i++) {
						const it = items[i];
						if (it.kind === 'file' && it.type.startsWith('image/')) {
							const f = it.getAsFile();
							if (f) out.push(f);
						}
					}
				}
				if (out.length === 0 && cd.files?.length) {
					for (const f of Array.from(cd.files)) {
						if (f.type.startsWith('image/')) out.push(f);
					}
				}
				return out;
			}

			csvPaste?.addEventListener('paste', (e) => {
				const imgs = clipboardImageFilesFromPaste(e);
				if (!imgs.length) return;
				e.preventDefault();
				const text = e.clipboardData?.getData('text/plain') ?? '';
				if (text && csvPaste) {
					const start = csvPaste.selectionStart ?? 0;
					const end = csvPaste.selectionEnd ?? 0;
					const v = csvPaste.value;
					csvPaste.value = v.slice(0, start) + text + v.slice(end);
					const pos = start + text.length;
					csvPaste.setSelectionRange(pos, pos);
				}
				void addAiImagesFromFileList(imgs);
			});

			wireImageDropZone(pasteComposer);
			wireImageDropZone(csvPaste);

			csvParseAiBtn?.addEventListener('click', async () => {
				const key = getEffectiveApiKey();
				if (!key) {
					if (aiStatus) {
						aiStatus.textContent = 'Set your API key in .env (build) or in the field above.';
					}
					return;
				}
				let modelId = aiModelSelect?.value ?? '';
				if (modelId === '__custom') {
					modelId = (aiModelCustom?.value ?? '').trim();
					if (!modelId) {
						if (aiStatus) aiStatus.textContent = 'Enter a custom model id.';
						return;
					}
				}
				const pasted = csvPaste?.value ?? '';
				const imageDataUrls = aiAttachments.map((a) => a.dataUrl);
				if (!pasted.trim() && imageDataUrls.length === 0) {
					if (aiStatus) aiStatus.textContent = 'Paste text and/or attach one or more images.';
					return;
				}
				setAiOptionsOpen(false);
				if (aiRememberKey?.checked) {
					try {
						if (!OPENROUTER_KEY_FROM_ENV) localStorage.setItem(STORAGE_OPENROUTER_KEY, key);
						localStorage.setItem(STORAGE_OPENROUTER_MODEL, modelId);
					} catch {
						// ignore
					}
				}
				csvParseAiBtn.disabled = true;
				if (aiStatus) aiStatus.textContent = 'Calling OpenRouter…';
				try {
					const imgUrls = imageDataUrls.filter(Boolean);
					const multiImage = imgUrls.length > 1;

					if (multiImage) {
						commitActiveSheet();
						if (sheets.length + imgUrls.length > MAX_SHEETS) {
							if (aiStatus) {
								aiStatus.textContent = `Sheet limit (${MAX_SHEETS}). Close or remove sheets, then try again.`;
							}
							return;
						}
						const batchSheetIds: string[] = [];
						for (let i = 0; i < imgUrls.length; i++) {
							const base = labelForAiAttachment(i, imgUrls.length, aiAttachments[i]?.name);
							const label = dedupeSheetLabel(base);
							const sid = uid();
							batchSheetIds.push(sid);
							sheets.push({ id: sid, label, rows: [['', '', '']] });
						}
						const insertAt = sheets.length - imgUrls.length;
						activeIndex = insertAt;
						replaceEditorRows(sheets[activeIndex].rows);
						renderTabBar();
						renderPreview();
						scrollActiveTabIntoView();
						persistState();

						const { parts } = await parseDimensionsWithOpenRouter({
							apiKey: key,
							model: modelId,
							pastedText: pasted,
							imageDataUrls: imgUrls,
							reportStatus: (msg) => {
								if (aiStatus) aiStatus.textContent = msg;
							},
							onImagePart: ({ index, total, part }) => {
								const body = rowsFromAiPart(part);
								const ii = Number(index);
								const id = batchSheetIds[ii];
								const sheet = id ? sheets.find((s) => s.id === id) : undefined;
								if (!sheet) {
									if (aiStatus) {
										aiStatus.textContent = `Image ${ii + 1}/${total}: tab missing (sheet may have been removed).`;
									}
									return;
								}
								sheet.rows = body;
								const sheetIndex = sheets.indexOf(sheet);
								if (sheetIndex >= 0 && activeIndex === sheetIndex) {
									replaceEditorRows(sheets[activeIndex].rows);
									renderPreview();
								} else {
									persistState();
								}
								if (aiStatus) {
									aiStatus.textContent = `Updated ${sheet.label} (image ${ii + 1}/${total})`;
								}
							}
						});

						const totalRows = parts.reduce((acc, p) => {
							const b = rowsFromAiPart(p);
							return acc + b.filter((r) => r.some((c) => c.length)).length;
						}, 0);
						const withData = parts.filter((p) => {
							const b = rowsFromAiPart(p);
							return b.some((r) => r.some((c) => c.length));
						}).length;

						if (withData === 0) {
							if (aiStatus) aiStatus.textContent = 'No rows parsed (try another model or clearer images).';
						} else if (aiStatus) {
							aiStatus.textContent = `Done: ${parts.length} sheet(s), ${totalRows} row(s) total.`;
						}
					} else {
						const { parts } = await parseDimensionsWithOpenRouter({
							apiKey: key,
							model: modelId,
							pastedText: pasted,
							imageDataUrls,
							reportStatus: (msg) => {
								if (aiStatus) aiStatus.textContent = msg;
							}
						});
						const first = parts[0];
						if (!first?.rows) {
							throw new Error('Empty response from model.');
						}
						const matrix = first.rows.map((row) => [
							String(row.a ?? ''),
							normalizeMetricTypography(String(row.b ?? '')),
							normalizeImperialTypography(String(row.c ?? ''))
						]);
						const ok = importMatrixAsNewSheet(matrix, 'AI parsed');
						const totalRows = matrix.filter((r) => r.some((c) => c.length)).length;
						if (!ok) {
							if (aiStatus) aiStatus.textContent = 'No rows or sheet limit reached.';
						} else if (aiStatus) {
							aiStatus.textContent = `Imported ${totalRows} row(s).`;
						}
					}
				} catch (e) {
					const raw = e instanceof Error ? e.message : String(e);
					const lower = raw.toLowerCase();
					const looksImageFormat =
						/invalid image|unsupported image|image (format|type|mime|media)|could not (read|fetch|decode) image|failed to (fetch|decode|load) image|image.*not supported|image.*corrupt|unable to process image|image must be|you must provide a valid image/.test(
							lower
						);
					let friendly: string;
					if (looksImageFormat && imageDataUrls.length > 0) {
						friendly =
							`The model couldn't read one of the images (likely an unsupported format). ` +
							`Vision models here accept PNG, JPEG, WebP, and GIF. ` +
							`Convert HEIC/AVIF/BMP/TIFF/SVG first, or try a smaller image. — ${raw}`;
					} else {
						friendly = raw;
					}
					if (aiStatus) {
						aiStatus.textContent =
							friendly.length > 240 ? friendly.slice(0, 240) + '…' : friendly;
					}
					// Dev: always log the raw error for debugging.
					console.error('[three-column] Parse with AI failed', e);
				} finally {
					csvParseAiBtn.disabled = false;
				}
			});

			importCsvBtn?.addEventListener('click', () => {
				fileInput?.click();
			});

			addSheetBtn?.addEventListener('click', () => addEmptySheet());

			function escapeCsvCell(s: string) {
				const str = String(s ?? '');
				if (str.includes(',') || str.includes('"') || str.includes('\n')) {
					return '"' + str.replace(/"/g, '""') + '"';
				}
				return str;
			}

			function sheetRowsToCsv(rows: string[][]) {
				return rows
					.map((cells) =>
						cells
							.map((cell, i) =>
								escapeCsvCell(
									i === 1
										? normalizeMetricTypography(String(cell ?? ''))
										: i === 2
											? normalizeImperialTypography(String(cell ?? ''))
											: String(cell ?? '')
								)
							)
							.join(',')
					)
					.join('\n');
			}

			function delayMs(ms: number) {
				return new Promise((r) => setTimeout(r, ms));
			}

			exportCsvBtn?.addEventListener('click', () => {
				commitActiveSheet();
				const csv = sheetRowsToCsv(getTableData());
				const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
				const url = URL.createObjectURL(blob);
				const a = document.createElement('a');
				a.href = url;
				const base = sanitizeFilenameBase(sheets[activeIndex]?.label ?? 'three-column');
				a.download = `${base}.csv`;
				a.click();
				URL.revokeObjectURL(url);
			});

			function exportPreviewToPng4096(filenameLabel?: string): Promise<void> {
				return new Promise((resolve) => {
				const CANVAS_SIZE = 4096;
				const LINE_WIDTH = 654;
				const COL1_X = 17;
				const COL2_X = 337;
				const COL3_RIGHT_PAD = 21;

				const previewWrap = document.getElementById('preview-table-wrap');
				const previewTable = document.getElementById('preview-table');
				const previewLines = previewWrap
					? (Array.from(previewWrap.querySelectorAll('div.h-\\[2px\\]')) as HTMLDivElement[])
					: [];
				if (!previewWrap || !previewTable || previewLines.length === 0) {
					resolve();
					return;
				}

				const wrapRect = previewWrap.getBoundingClientRect();
				const tableRect = previewTable.getBoundingClientRect();

				// Center the entire preview group (table + line) inside 4096x4096
				const groupW = Math.max(LINE_WIDTH, wrapRect.width);
				// Include the full preview wrap height (spacers are part of the look now).
				const groupH = Math.max(1, wrapRect.bottom - tableRect.top);
				const offsetX = Math.round((CANVAS_SIZE - groupW) / 2);
				const offsetY = Math.round((CANVAS_SIZE - groupH) / 2);

				const canvas = document.createElement('canvas');
				canvas.width = CANVAS_SIZE;
				canvas.height = CANVAS_SIZE;
				const ctx = canvas.getContext('2d');
				if (!ctx) {
					resolve();
					return;
				}

				ctx.clearRect(0, 0, CANVAS_SIZE, CANVAS_SIZE); // transparent
				ctx.textBaseline = 'alphabetic';

				// Draw every 2px divider line under each preview row
				ctx.strokeStyle = '#000000';
				ctx.lineWidth = 2;
				for (const lineDiv of previewLines) {
					const r = lineDiv.getBoundingClientRect();
					const y = offsetY + (r.top - tableRect.top) + r.height / 2;
					ctx.beginPath();
					ctx.moveTo(offsetX, y);
					ctx.lineTo(offsetX + LINE_WIDTH, y);
					ctx.stroke();
				}

				// Draw all preview <p> text at their exact DOM positions (including letter-spacing),
				// so the PNG export matches the on-screen preview.
				ctx.fillStyle = '#111111';
				const textEls = Array.from(previewTable.querySelectorAll('tbody tr td p')) as HTMLElement[];
				ctx.textAlign = 'left';
				ctx.textBaseline = 'alphabetic';

				for (const el of textEls) {
					const r = el.getBoundingClientRect();
					const s = getComputedStyle(el);

					const fontWeight = s.fontWeight;
					const fontSize = s.fontSize || '14.4px';
					const fontFamily = s.fontFamily;
					const fontLineHeight = parseFloat(s.lineHeight || s.fontSize || '14.4') || parseFloat(fontSize);
					const letterSpacingStr = s.letterSpacing || '0px';
					const letterSpacing = letterSpacingStr === 'normal' ? 0 : Number.parseFloat(letterSpacingStr);

					// Baseline within the line box: tuned for the preview's lineHeight == fontSize.
					const baselineY = offsetY + (r.top - tableRect.top) + fontLineHeight * 0.8;

					ctx.font = `${fontWeight} ${fontSize} ${fontFamily}`;

					const text = (el.textContent ?? '');
					if (!text) continue;

					// Determine alignment from CSS textAlign.
					const cssAlign = (s.textAlign ?? '').toLowerCase();
					const mode = cssAlign.includes('right') || cssAlign === 'end' ? 'right' : cssAlign.includes('center') || cssAlign.includes('middle') ? 'center' : 'left';

					// Compute total width including letter-spacing.
					let totalWidth = 0;
					const chars = Array.from(text);
					for (let i = 0; i < chars.length; i++) {
						const w = ctx.measureText(chars[i]).width;
						totalWidth += w;
						if (i < chars.length - 1) totalWidth += letterSpacing;
					}

					const leftX = offsetX + (r.left - tableRect.left);
					const rightX = offsetX + (r.right - tableRect.left);
					const centerX = leftX + r.width / 2;

					let x = leftX;
					if (mode === 'center') x = centerX - totalWidth / 2;
					if (mode === 'right') x = rightX - totalWidth;

					let advance = 0;
					for (let i = 0; i < chars.length; i++) {
						const ch = chars[i];
						ctx.fillText(ch, x + advance, baselineY);
						const w = ctx.measureText(ch).width;
						advance += w + (i < chars.length - 1 ? letterSpacing : 0);
					}
				}

				const base = sanitizeFilenameBase(filenameLabel ?? sheets[activeIndex]?.label ?? 'table');
				canvas.toBlob((blob) => {
					if (!blob) {
						resolve();
						return;
					}
					const url = URL.createObjectURL(blob);
					const a = document.createElement('a');
					a.href = url;
					a.download = `${base}-4096.png`;
					a.click();
					URL.revokeObjectURL(url);
					resolve();
				}, 'image/png');
				});
			}

			exportPngBtn?.addEventListener('click', () => {
				void exportPreviewToPng4096();
			});

			batchExportCsvBtn?.addEventListener('click', async () => {
				if (sheets.length < 2) return;
				commitActiveSheet();
				for (let i = 0; i < sheets.length; i++) {
					const sheet = sheets[i];
					const csv = sheetRowsToCsv(sheet.rows);
					const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
					const url = URL.createObjectURL(blob);
					const a = document.createElement('a');
					a.href = url;
					a.download = `${sanitizeFilenameBase(sheet.label)}.csv`;
					a.click();
					URL.revokeObjectURL(url);
					await delayMs(220);
				}
			});

			batchExportPngBtn?.addEventListener('click', async () => {
				if (sheets.length < 2) return;
				commitActiveSheet();
				const saved = activeIndex;
				for (let i = 0; i < sheets.length; i++) {
					setActiveSheet(i);
					await new Promise<void>((r) => requestAnimationFrame(() => requestAnimationFrame(() => r())));
					await exportPreviewToPng4096(sheets[i].label);
					await delayMs(180);
				}
				setActiveSheet(saved);
			});

			[...trackingInputs, ...weightSelects].forEach((el) => {
				el?.addEventListener('input', () => renderPreview());
				el?.addEventListener('change', () => renderPreview());
			});

			// Token palette: click token to insert into focused A/B/C cell
			const tokenPalette = document.getElementById('token-palette');
			const tokenBtns = tokenPalette ? Array.from(tokenPalette.querySelectorAll('.token-btn')) as HTMLButtonElement[] : [];

			let activeCellInput: HTMLInputElement | null = null;

			function hideTokenPalette() {
				if (tokenPalette) tokenPalette.style.display = 'none';
			}

			function showTokenPaletteBelowInput(input: HTMLInputElement) {
				if (!tokenPalette) return;
				activeCellInput = input;

				// Show first so we can measure width.
				tokenPalette.style.display = 'block';

				const rect = input.getBoundingClientRect();

				// Exact dropdown-like alignment: directly above the input.
				// (We must measure after display:block, so offsetHeight is available.)
				const desiredTop = rect.top - tokenPalette.offsetHeight - 12;
				tokenPalette.style.left = `${rect.left}px`;
				tokenPalette.style.top = `${Math.max(8, desiredTop)}px`;

				// Match dropdown width to the input (at least a minimum for usability).
				const desiredMinWidth = Math.round(rect.width);
				tokenPalette.style.minWidth = `${Math.max(120, desiredMinWidth)}px`;

				// Prevent going off-screen to the right.
				const maxLeft = window.innerWidth - tokenPalette.offsetWidth - 8;
				const clampedLeft = Math.max(8, Math.min(rect.left, maxLeft));
				tokenPalette.style.left = `${clampedLeft}px`;
			}

			function insertTokenIntoActiveCell(token: string) {
				if (!activeCellInput) return;
				if (!token) return;

				const currentTrimmed = (activeCellInput.value ?? '').trim();
				const tokenIsSlash = token === '/';
				const tokenIsApostrophe = token === '’' || token === "'";
				const tokenIsSymbol = tokenIsSlash || tokenIsApostrophe;
				const prevEndsWithSlash = currentTrimmed.endsWith('/');

				const sep = currentTrimmed.length === 0
					? ''
					: prevEndsWithSlash || tokenIsSymbol
						? ''
						: ' / ';

				const next = currentTrimmed.length === 0 ? token : `${currentTrimmed}${sep}${token}`;
				activeCellInput.value = next;
				activeCellInput.dispatchEvent(new Event('input', { bubbles: true }));
			}

			document.addEventListener('focusin', (e) => {
				const t = e.target as HTMLElement | null;
				if (t?.classList?.contains('cell-input')) {
					showTokenPaletteBelowInput(t as HTMLInputElement);
				}
			});

			document.addEventListener('mousedown', (e) => {
				const target = e.target as HTMLElement | null;
				if (!tokenPalette || tokenPalette.style.display === 'none') return;
				if (!target) return;
				if (tokenPalette.contains(target)) return;
				if (target.classList?.contains('cell-input')) return;
				hideTokenPalette();
			});

			tokenBtns.forEach((btn) => {
				btn.addEventListener('click', () => {
					const token = btn.getAttribute('data-token') ?? '';
					insertTokenIntoActiveCell(token);
				});
			});

			renderPreview();
		</script>
	</body>
</html>
