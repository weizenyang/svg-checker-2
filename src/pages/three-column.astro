---
import "../styles.css";
import { DIMENSION_PARSE_SYSTEM_PROMPT, DEFAULT_OPENROUTER_MODELS } from "../lib/dimension-ai-prompt";
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>3-Column CSV Input</title>
	</head>
	<body class="bg-neutral-100 min-h-screen flex flex-col">
		<!-- Hidden: full-page CSV drop + file input (no visible drop zone) -->
		<input type="file" id="file-input" accept=".csv,text/csv" multiple class="sr-only" tabindex="-1" aria-hidden="true" />

		<main class="flex-1 flex flex-col gap-4 p-4 md:p-6 max-w-7xl w-full mx-auto">
			<!-- 1. Top band: title + tab bar + add -->
			<header class="flex flex-col gap-2">
				<div class="flex items-baseline justify-between gap-3 flex-wrap">
					<h1 class="text-xl font-semibold tracking-tight">Table Dimensions</h1>
					<span class="text-[11px] uppercase tracking-wider text-neutral-400 hidden sm:inline">3-column · metric + imperial · PNG 4096</span>
				</div>
				<div class="flex items-stretch gap-2 min-w-0">
					<div
						id="sheet-tabs-scroll"
						class="sheet-tabs-scroll flex-1 min-w-0 overflow-x-auto overflow-y-hidden rounded-xl border border-neutral-200 bg-white px-1 py-1"
						role="tablist"
						aria-label="Imported CSV sheets"
					>
						<div id="sheet-tabs" class="flex flex-nowrap gap-1 w-max min-h-[2.25rem] items-center"></div>
					</div>
					<button
						type="button"
						id="add-sheet-btn"
						class="shrink-0 px-3 py-1.5 rounded-xl border border-neutral-200 bg-white hover:bg-neutral-50 text-sm font-medium"
						title="New empty sheet"
					>
						+
					</button>
				</div>
			</header>

			<!-- 2. Preview card: preview table + docked typography controls + export actions -->
			<section class="flex-1 min-h-0 rounded-xl border border-neutral-200 bg-white overflow-hidden flex flex-col">
				<div class="px-4 py-3 flex flex-wrap items-center justify-between gap-3 border-b border-neutral-100">
					<div class="flex items-center gap-2 min-w-0">
						<span class="text-[11px] font-semibold uppercase tracking-wider text-neutral-500">Preview</span>
						<span class="text-neutral-300">·</span>
						<span class="text-xs text-neutral-600 truncate" id="preview-subtitle">Exports current view at 4096×4096</span>
					</div>
					<div class="flex flex-wrap gap-2 items-center">
						<div class="inline-flex items-stretch rounded-lg shadow-sm">
							<button
								type="button"
								id="export-png"
								class="px-3 py-1.5 rounded-l-lg bg-neutral-900 text-white hover:bg-neutral-800 text-sm font-medium border-r border-neutral-700/60"
								title="Export current sheet as 4096×4096 PNG"
							>
								Export PNG (4096)
							</button>
							<button
								type="button"
								id="batch-export-png"
								class="px-2.5 py-1.5 rounded-r-lg bg-neutral-900 text-white hover:bg-neutral-800 text-sm inline-flex items-center gap-1 border-l border-neutral-700/40 disabled:opacity-40 disabled:cursor-not-allowed"
								title="Export all sheets as PNG (4096)"
							>
								<span>All</span>
								<span id="batch-export-png-count" class="text-[11px] text-white"></span>
							</button>
						</div>
						<div class="inline-flex items-stretch rounded-lg shadow-sm">
							<button
								type="button"
								id="export-csv"
								class="px-3 py-1.5 rounded-l-lg bg-neutral-200 text-neutral-900 hover:bg-neutral-300 text-sm font-medium border-r border-neutral-300"
								title="Export current sheet as CSV"
							>
								Export CSV
							</button>
							<button
								type="button"
								id="batch-export-csv"
								class="px-2.5 py-1.5 rounded-r-lg bg-neutral-200 text-neutral-900 hover:bg-neutral-300 text-sm inline-flex items-center gap-1 border-l border-neutral-300 disabled:opacity-40 disabled:cursor-not-allowed"
								title="Export all sheets as CSV"
							>
								<span>All</span>
								<span id="batch-export-csv-count" class="text-[11px] text-neutral-900"></span>
							</button>
						</div>
					</div>
				</div>
				<div class="flex-1 min-h-[280px] p-4 overflow-auto flex justify-center">
					<div id="preview-table-wrap" class="preview-table-wrap">
						<table id="preview-table" class="preview-table w-[654px] text-left">
							<tbody id="preview-tbody">
								<tr><td colspan="3" class="text-neutral-400 text-center py-10">No data yet — drop a CSV, use the Input panel below, or add rows.</td></tr>
							</tbody>
						</table>
					</div>
				</div>
				<!-- Typography controls strip (docked to preview since they change the preview) -->
				<div class="px-4 py-2.5 border-t border-neutral-100 bg-neutral-50/70">
					<div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-neutral-600">
						<span class="text-[10px] font-semibold uppercase tracking-wider text-neutral-500">Typography</span>
						<label class="flex items-center gap-1.5">
							<span class="font-medium text-neutral-700 w-4">A</span>
							<select id="weight-col-0" class="border border-neutral-200 rounded-md px-1.5 py-0.5 bg-white">
								<option value="regular">Regular</option>
								<option value="bold" selected>Bold</option>
							</select>
							<span class="text-neutral-400">track</span>
							<input id="tracking-col-0" type="number" step="0.1" value="-0.6" class="w-14 border border-neutral-200 rounded-md px-1.5 py-0.5 bg-white" />
						</label>
						<label class="flex items-center gap-1.5">
							<span class="font-medium text-neutral-700 w-4">B</span>
							<select id="weight-col-1" class="border border-neutral-200 rounded-md px-1.5 py-0.5 bg-white">
								<option value="regular" selected>Regular</option>
								<option value="bold">Bold</option>
							</select>
							<span class="text-neutral-400">track</span>
							<input id="tracking-col-1" type="number" step="0.1" value="-0.6" class="w-14 border border-neutral-200 rounded-md px-1.5 py-0.5 bg-white" />
						</label>
						<label class="flex items-center gap-1.5">
							<span class="font-medium text-neutral-700 w-4">C</span>
							<select id="weight-col-2" class="border border-neutral-200 rounded-md px-1.5 py-0.5 bg-white">
								<option value="regular" selected>Regular</option>
								<option value="bold">Bold</option>
							</select>
							<span class="text-neutral-400">track</span>
							<input id="tracking-col-2" type="number" step="0.1" value="-2" class="w-14 border border-neutral-200 rounded-md px-1.5 py-0.5 bg-white" />
						</label>
					</div>
				</div>
			</section>

			<!-- 3. Input card: paste / attach / AI parse -->
			<section
				id="paste-composer"
				class="rounded-xl border border-neutral-200 bg-white overflow-visible"
			>
				<div class="px-4 py-3 flex flex-wrap items-center justify-between gap-3 border-b border-neutral-100">
					<div class="flex items-center gap-2 min-w-0">
						<span class="text-[11px] font-semibold uppercase tracking-wider text-neutral-500">Input</span>
						<span class="text-neutral-300">·</span>
						<span class="text-xs text-neutral-600">CSV, messy notes, or image for AI</span>
					</div>
					<p
						id="ai-status"
						class="flex-1 min-w-0 text-xs sm:text-sm text-neutral-600 min-h-[1.25rem] text-right break-words"
						aria-live="polite"
					></p>
				</div>

				<div id="ai-manual-key-row" class="mx-4 mt-3 flex flex-wrap gap-3 items-end">
					<label class="flex flex-col gap-1 text-xs font-medium text-neutral-600 min-w-[180px] flex-1">
						<span>OpenRouter API key</span>
						<input
							type="password"
							id="ai-api-key"
							autocomplete="off"
							placeholder="sk-or-…"
							class="w-full px-2.5 py-1.5 rounded-md border border-neutral-200 bg-white text-sm font-mono shadow-sm"
						/>
					</label>
					<label class="flex items-center gap-2 text-xs text-neutral-600 shrink-0 pb-1">
						<input type="checkbox" id="ai-remember-key" class="rounded border-neutral-300" />
						Remember key
					</label>
				</div>

				<div class="p-4 space-y-3">
					<input type="file" id="ai-image-input" accept="image/*" multiple class="sr-only" tabindex="-1" aria-hidden="true" />

					<div
						id="ai-attachment-chips"
						class="hidden flex flex-wrap gap-2 min-h-0"
						aria-live="polite"
					></div>

					<textarea
						id="csv-paste"
						placeholder="Paste 3-column CSV, dimension notes, or paste / attach images (screenshots go to Attach automatically)."
						spellcheck="false"
						autocomplete="off"
						autocapitalize="off"
						autocorrect="off"
						class="w-full min-h-[100px] p-3 text-sm border border-neutral-200 rounded-lg bg-neutral-50/50 font-mono resize-y placeholder:text-neutral-400 focus:outline-none focus:ring-2 focus:ring-violet-400/40 focus:border-violet-300 focus:bg-white"
						rows="4"
					></textarea>

					<div class="flex flex-wrap items-center gap-2">
						<button
							type="button"
							id="ai-attach-btn"
							class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg border border-neutral-200 bg-white text-sm text-neutral-700 hover:bg-neutral-50 hover:border-neutral-300 transition-colors"
							title="Attach image for vision"
						>
							<svg class="w-4 h-4 text-neutral-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.636-9.318L8.288 6.048a2.25 2.25 0 0 0-3.182 0L2.25 9.293M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
							</svg>
							Attach image
						</button>
						<button type="button" id="import-csv-btn" class="px-3 py-1.5 rounded-lg border border-neutral-200 bg-white hover:bg-neutral-50 hover:border-neutral-300 text-sm font-medium text-neutral-700 transition-colors">
							Import CSV file(s)
						</button>
						<span class="text-[11px] text-neutral-400 hidden sm:inline">Drop images here · vision models</span>
						<span class="flex-1 min-w-[1rem]"></span>
						<button
							type="button"
							id="import-paste-btn"
							class="px-3 py-2 rounded-lg bg-neutral-200 hover:bg-neutral-300 text-sm font-medium"
						>
							Import CSV
						</button>
						<div class="relative inline-flex items-stretch rounded-lg shadow-sm">
							<button
								type="button"
								id="csv-parse-ai-btn"
								class="px-3 py-2 rounded-l-lg bg-violet-600 text-white hover:bg-violet-700 text-sm font-medium disabled:opacity-50 disabled:pointer-events-none border-r border-violet-500/50"
							>
								Parse with AI
							</button>
							<button
								type="button"
								id="ai-options-trigger"
								class="px-2 py-2 rounded-r-lg bg-violet-600 text-white hover:bg-violet-700 text-sm border-l border-violet-500/40"
								aria-expanded="false"
								aria-haspopup="true"
								aria-controls="ai-options-panel"
								title="Model & system prompt"
							>
								<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
								</svg>
							</button>
							<div
								id="ai-options-panel"
								class="hidden fixed z-[200] w-[min(100vw-2rem,22rem)] max-w-[calc(100vw-1rem)] rounded-xl border border-neutral-200 bg-white shadow-xl ring-1 ring-black/5"
								role="menu"
							>
								<div class="p-3 space-y-3 max-h-[min(70vh,28rem)] overflow-y-auto">
									<div>
										<label class="block text-xs font-medium text-neutral-600 mb-1">Model</label>
										<select
											id="ai-model-select"
											class="w-full px-2.5 py-1.5 rounded-lg border border-neutral-200 bg-white text-sm shadow-sm"
										>
											{DEFAULT_OPENROUTER_MODELS.map((m) => (
												<option value={m.id}>{m.label}</option>
											))}
											<option value="__custom">Custom…</option>
										</select>
									</div>
									<div class="hidden" id="ai-model-custom-wrap">
										<label class="block text-xs font-medium text-neutral-600 mb-1">Custom model id</label>
										<input
											type="text"
											id="ai-model-custom"
											placeholder="openai/gpt-4o"
											class="w-full px-2.5 py-1.5 rounded-lg border border-neutral-200 bg-white text-sm font-mono shadow-sm"
										/>
									</div>
									<div class="border-t border-neutral-100 pt-2">
										<div class="flex items-center justify-between gap-2 mb-1">
											<span class="text-xs font-medium text-neutral-700">System prompt</span>
											<button
												type="button"
												id="ai-copy-prompt"
												class="px-2 py-0.5 rounded border border-neutral-200 bg-neutral-50 hover:bg-neutral-100 text-[11px]"
											>
												Copy
											</button>
										</div>
										<pre
											id="ai-prompt-display"
											class="max-h-36 overflow-auto whitespace-pre-wrap font-mono text-[10px] leading-relaxed text-neutral-700 p-2 rounded-lg bg-neutral-50 border border-neutral-200"
										>{DIMENSION_PARSE_SYSTEM_PROMPT}</pre>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- 4. Rows card: direct cell editor -->
			<section class="rounded-xl border border-neutral-200 bg-white overflow-hidden">
				<div class="px-4 py-3 flex flex-wrap items-center justify-between gap-3 border-b border-neutral-100">
					<div class="flex items-center gap-2 min-w-0">
						<span class="text-[11px] font-semibold uppercase tracking-wider text-neutral-500">Rows</span>
						<span class="text-neutral-300">·</span>
						<span class="text-xs text-neutral-600">Edit A / B / C directly</span>
					</div>
					<span class="text-[11px] text-neutral-400 hidden sm:inline">Focus a cell to see the token palette</span>
				</div>
				<div class="max-h-[320px] overflow-y-auto">
					<table class="w-full text-left text-sm">
						<thead class="bg-neutral-50/80 sticky top-0 z-[1]">
							<tr>
								<th class="px-3 py-2 w-1/3 text-[10px] font-semibold uppercase tracking-wider text-neutral-500">A</th>
								<th class="px-3 py-2 w-1/3 text-[10px] font-semibold uppercase tracking-wider text-neutral-500">B</th>
								<th class="px-3 py-2 w-1/3 text-[10px] font-semibold uppercase tracking-wider text-neutral-500">C</th>
								<th class="px-2 py-2 w-16"></th>
							</tr>
						</thead>
						<tbody id="rows">
							<tr class="border-t border-neutral-100">
								<td class="p-1.5"><input type="text" class="cell-input w-full px-2 py-1.5 border border-neutral-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-neutral-300 focus:border-neutral-300" data-col="0" spellcheck="false" autocomplete="off" autocapitalize="off" autocorrect="off" /></td>
								<td class="p-1.5"><input type="text" class="cell-input w-full px-2 py-1.5 border border-neutral-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-neutral-300 focus:border-neutral-300" data-col="1" spellcheck="false" autocomplete="off" autocapitalize="off" autocorrect="off" /></td>
								<td class="p-1.5"><input type="text" class="cell-input w-full px-2 py-1.5 border border-neutral-200 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-neutral-300 focus:border-neutral-300" data-col="2" spellcheck="false" autocomplete="off" autocapitalize="off" autocorrect="off" /></td>
								<td class="p-1.5 text-right"><button type="button" class="delete-row px-2 py-1 text-xs rounded-md bg-red-50 text-red-700 hover:bg-red-100">Del</button></td>
							</tr>
						</tbody>
					</table>
				</div>
				<div class="px-4 py-2.5 border-t border-neutral-100 flex justify-end">
					<button
						type="button"
						id="add-row"
						class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg border border-neutral-200 bg-white hover:bg-neutral-50 hover:border-neutral-300 text-sm font-medium text-neutral-700 transition-colors"
					>
						<span class="text-neutral-400">+</span>
						<span>Add row</span>
					</button>
				</div>
			</section>

			<!-- Floating token palette (positioned via JS) -->
			<div
				id="token-palette"
				class="p-2 rounded-lg border border-neutral-200 bg-white/95 backdrop-blur shadow-lg z-[1000]"
				style="display:none; position: fixed;"
			>
				<div class="flex flex-wrap items-center justify-between gap-2">
					<div class="text-xs text-neutral-600">
						Token palette (click to insert into the focused cell)
					</div>
				</div>
				<div class="mt-2 flex flex-wrap gap-2">
					<button type="button" class="token-btn px-2 py-1 text-xs rounded bg-neutral-100 hover:bg-neutral-200" data-token="’" aria-pressed="false">’</button>
					<button type="button" class="token-btn px-2 py-1 text-xs rounded bg-neutral-100 hover:bg-neutral-200" data-token="'" aria-pressed="false">'</button>
					<button type="button" class="token-btn px-2 py-1 text-xs rounded bg-neutral-100 hover:bg-neutral-200" data-token="/" aria-pressed="false">/</button>
					<button type="button" class="token-btn px-2 py-1 text-xs rounded bg-neutral-100 hover:bg-neutral-200" data-token="LIVING" aria-pressed="false">LIVING</button>
					<button type="button" class="token-btn px-2 py-1 text-xs rounded bg-neutral-100 hover:bg-neutral-200" data-token="DINING" aria-pressed="false">DINING</button>
					<button type="button" class="token-btn px-2 py-1 text-xs rounded bg-neutral-100 hover:bg-neutral-200" data-token="KITCHEN" aria-pressed="false">KITCHEN</button>
					<button type="button" class="token-btn px-2 py-1 text-xs rounded bg-neutral-100 hover:bg-neutral-200" data-token="BEDROOM" aria-pressed="false">BEDROOM</button>
					<button type="button" class="token-btn px-2 py-1 text-xs rounded bg-neutral-100 hover:bg-neutral-200" data-token="POWDER" aria-pressed="false">POWDER</button>
					<button type="button" class="token-btn px-2 py-1 text-xs rounded bg-neutral-100 hover:bg-neutral-200" data-token="BALCONY" aria-pressed="false">BALCONY</button>
				</div>
			</div>
		</main>

		<style>
			.sheet-tabs-scroll {
				-webkit-overflow-scrolling: touch;
				scrollbar-width: thin;
			}
			.sheet-tabs-scroll::-webkit-scrollbar {
				height: 8px;
			}
			.sheet-tabs-scroll::-webkit-scrollbar-thumb {
				background: #d4d4d4;
				border-radius: 4px;
			}
			.preview-table-wrap {
				/* Placeholder for your custom style later */
			}
			.preview-table {
				border-collapse: collapse;
				font-kerning: normal;
				text-rendering: geometricPrecision;
			}
			.preview-table td {
				padding: 0;
				border-bottom: 1px solid #e5e7eb;
				letter-spacing: normal;
			}
			.preview-table p {
				letter-spacing: inherit;
				white-space: pre-wrap;
			}
			.preview-table tbody tr:hover {
				background: #f9fafb;
			}
		</style>

		<script>
			import {
				normalizeImperialTypography,
				normalizeMetricTypography,
				protectInchMarksInCsvLine
			} from '../lib/csv-dimension-typography';

			const MAX_IMPORT_ROWS = 200;
			const MAX_SHEETS = 40;

			/** @typedef {{ id: string, label: string, rows: string[][] }} Sheet */

			function uid() {
				return `s${Date.now().toString(36)}${Math.random().toString(36).slice(2, 9)}`;
			}

			function readFileAsText(file) {
				return new Promise((resolve, reject) => {
					const r = new FileReader();
					r.onload = () => resolve(String(r.result));
					r.onerror = () => reject(r.error ?? new Error('read failed'));
					r.readAsText(file, 'UTF-8');
				});
			}

			function sanitizeFilenameBase(name) {
				const s = String(name ?? 'three-column').replace(/\.csv$/i, '').trim() || 'three-column';
				return s.replace(/[^a-zA-Z0-9._-]+/g, '-').replace(/^-+|-+$/g, '') || 'three-column';
			}

			/** RFC-style CSV line: comma-separated, `"` escapes quotes. Returns all fields. */
			function parseCSVLineAll(line) {
				const out = [];
				let cur = '';
				let inQuotes = false;
				for (let i = 0; i < line.length; i++) {
					const c = line[i];
					if (c === '"') {
						if (inQuotes && line[i + 1] === '"') {
							cur += '"';
							i++;
						} else inQuotes = !inQuotes;
					} else if (c === ',' && !inQuotes) {
						out.push(cur.trim());
						cur = '';
					} else cur += c;
				}
				out.push(cur.trim());
				return out;
			}

			/** First two commas split A/B; remainder joins as C (imperial text may contain commas). */
			function normalizeToThreeColumns(cells) {
				if (!cells || cells.length === 0) return ['', '', ''];
				if (cells.length === 1) return [cells[0], '', ''];
				if (cells.length === 2) return [cells[0], cells[1], ''];
				return [cells[0], cells[1], cells.slice(2).join(',')];
			}

			function stripUtf8Bom(text) {
				if (text && text.charCodeAt(0) === 0xfeff) return text.slice(1);
				return text;
			}

			function parseCSV(text) {
				const rows = [];
				const cleaned = stripUtf8Bom(String(text ?? ''));
				const lines = cleaned.split(/\r?\n/).filter((l) => l.trim());
				for (const line of lines) {
					const protectedLine = protectInchMarksInCsvLine(line);
					const raw = parseCSVLineAll(protectedLine);
					const cells = normalizeToThreeColumns(raw);
					if (cells[1]) cells[1] = normalizeMetricTypography(cells[1]);
					if (cells[2]) cells[2] = normalizeImperialTypography(cells[2]);
					if (cells.some((c) => c.length > 0)) rows.push(cells);
				}
				return rows;
			}

			const tbody = document.getElementById('rows');
			const previewTbody = document.getElementById('preview-tbody');
			const fileInput = document.getElementById('file-input') as HTMLInputElement;
			const csvPaste = document.getElementById('csv-paste') as HTMLTextAreaElement;
			const importPasteBtn = document.getElementById('import-paste-btn');
			const importCsvBtn = document.getElementById('import-csv-btn');
			const addRowBtn = document.getElementById('add-row');
			const exportCsvBtn = document.getElementById('export-csv') as HTMLButtonElement | null;
			const exportPngBtn = document.getElementById('export-png') as HTMLButtonElement | null;
			const batchExportCsvBtn = document.getElementById('batch-export-csv') as HTMLButtonElement | null;
			const batchExportPngBtn = document.getElementById('batch-export-png') as HTMLButtonElement | null;
			const batchExportPngCount = document.getElementById('batch-export-png-count') as HTMLSpanElement | null;
			const batchExportCsvCount = document.getElementById('batch-export-csv-count') as HTMLSpanElement | null;
			const trackingInputs = [
				document.getElementById('tracking-col-0') as HTMLInputElement,
				document.getElementById('tracking-col-1') as HTMLInputElement,
				document.getElementById('tracking-col-2') as HTMLInputElement
			];
			const weightSelects = [
				document.getElementById('weight-col-0') as HTMLSelectElement,
				document.getElementById('weight-col-1') as HTMLSelectElement,
				document.getElementById('weight-col-2') as HTMLSelectElement
			];

			const STORAGE_KEY = 'three-column-sheets-v2';
			const STORAGE_KEY_V1 = 'three-column-rows-v1';
			const STORAGE_OPENROUTER_KEY = 'three-column-openrouter-key';
			const STORAGE_OPENROUTER_MODEL = 'three-column-openrouter-model';

			/** @type {Sheet[]} */
			let sheets = [];
			let activeIndex = 0;
			let isHydrating = true;

			function normalizeSheetRows(rows) {
				const list = Array.isArray(rows) ? rows : [];
				const out = list
					.filter((r) => Array.isArray(r) && r.length >= 3)
					.slice(0, MAX_IMPORT_ROWS)
					.map((r) => [String(r[0] ?? ''), String(r[1] ?? ''), String(r[2] ?? '')]);
				return out.length > 0 ? out : [['', '', '']];
			}

			function persistState() {
				try {
					const payload = {
						v: 2,
						activeIndex,
						sheets: sheets.slice(0, MAX_SHEETS).map((s) => ({
							id: s.id,
							label: String(s.label ?? 'Sheet').slice(0, 120),
							rows: normalizeSheetRows(s.rows)
						}))
					};
					localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
				} catch {
					// private mode, quota, etc.
				}
			}

			function loadState() {
				try {
					const raw = localStorage.getItem(STORAGE_KEY);
					if (raw) {
						const p = JSON.parse(raw);
						if (p && p.v === 2 && Array.isArray(p.sheets) && p.sheets.length > 0) {
							const loaded = p.sheets.slice(0, MAX_SHEETS).map((s, i) => ({
								id: typeof s.id === 'string' && s.id ? s.id : uid(),
								label: typeof s.label === 'string' && s.label ? s.label : `Sheet ${i + 1}`,
								rows: normalizeSheetRows(s.rows)
							}));
							let ai = Number(p.activeIndex) || 0;
							if (ai < 0 || ai >= loaded.length) ai = 0;
							return { sheets: loaded, activeIndex: ai };
						}
					}
					const v1 = localStorage.getItem(STORAGE_KEY_V1);
					if (v1) {
						const parsed = JSON.parse(v1);
						if (Array.isArray(parsed) && parsed.length > 0) {
							const rows = parsed
								.filter((r) => Array.isArray(r) && r.length >= 3)
								.slice(0, MAX_IMPORT_ROWS)
								.map((r) => [String(r[0] ?? ''), String(r[1] ?? ''), String(r[2] ?? '')]);
							if (rows.length > 0) {
								return {
									sheets: [{ id: uid(), label: 'Sheet 1', rows }],
									activeIndex: 0
								};
							}
						}
					}
				} catch {
					// ignore
				}
				return {
					sheets: [{ id: uid(), label: 'Sheet 1', rows: [['', '', '']] }],
					activeIndex: 0
				};
			}

			function trackingFor(col: number) {
				const raw = trackingInputs[col]?.value ?? '-0.6';
				const n = Number.parseFloat(raw);
				if (!Number.isFinite(n)) return '-0.6px';
				return `${n}px`;
			}

			function weightClassFor(col: number) {
				return weightSelects[col]?.value === 'bold' ? 'monospace821-bold' : 'monospace821-regular';
			}

			function getTableData() {
				const rows: string[][] = [];
				tbody.querySelectorAll('tr').forEach((tr) => {
					const inputs = tr.querySelectorAll('.cell-input');
					if (inputs.length >= 3) {
						rows.push([
							(inputs[0] as HTMLInputElement).value,
							(inputs[1] as HTMLInputElement).value,
							(inputs[2] as HTMLInputElement).value
						]);
					}
				});
				return rows;
			}

