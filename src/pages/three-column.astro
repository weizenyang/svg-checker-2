			#rows .cell-wrap .cell-drag-handle:hover {
				color: rgb(64 64 64);
				background: rgb(245 245 245);
			}
			#rows .cell-wrap .cell-drag-handle:active {
				cursor: grabbing;
				background: rgb(229 229 229);
			}
			#rows .cell-wrap.cell-source-dragging > .chip-cell {
				opacity: 0.4;
			}
			#rows .cell-wrap.cell-drop-target > .chip-cell {
				outline: 2px solid #8b5cf6;
				outline-offset: -1px;
				border-radius: 6px;
				background-color: #f5f3ff;
			}
			#ai-provider-switch[data-on="true"] {
				background-color: rgb(124 58 237);
			}
			#ai-provider-switch-knob[data-on="true"] {
				transform: translateX(1.25rem);
			}
		</style>

		<script>
			import {
				normalizeImperialTypography,
				normalizeMetricTypography,
				protectInchMarksInCsvLine
			} from '../lib/csv-dimension-typography';
			import { DEFAULT_GEMINI_MODELS, DEFAULT_OPENROUTER_MODELS } from '../lib/dimension-ai-prompt';

			const MAX_IMPORT_ROWS = 200;
			const MAX_SHEETS = 40;

			/** @typedef {{ id: string, label: string, rows: string[][] }} Sheet */

			function uid() {
				return `s${Date.now().toString(36)}${Math.random().toString(36).slice(2, 9)}`;
			}

			function readFileAsText(file) {
				return new Promise((resolve, reject) => {
					const r = new FileReader();
					r.onload = () => resolve(String(r.result));
					r.onerror = () => reject(r.error ?? new Error('read failed'));
					r.readAsText(file, 'UTF-8');
				});
			}

			function sanitizeFilenameBase(name) {
				const s = String(name ?? 'three-column').replace(/\.csv$/i, '').trim() || 'three-column';
				return s.replace(/[^a-zA-Z0-9._-]+/g, '-').replace(/^-+|-+$/g, '') || 'three-column';
			}

			/** RFC-style CSV line: comma-separated, `"` escapes quotes. Returns all fields. */
			function parseCSVLineAll(line) {
				const out = [];
				let cur = '';
				let inQuotes = false;
				for (let i = 0; i < line.length; i++) {
					const c = line[i];
					if (c === '"') {
						if (inQuotes && line[i + 1] === '"') {
							cur += '"';
							i++;
						} else inQuotes = !inQuotes;
					} else if (c === ',' && !inQuotes) {
						out.push(cur.trim());
						cur = '';
					} else cur += c;
				}
				out.push(cur.trim());
				return out;
			}

			/** First two commas split A/B; remainder joins as C (imperial text may contain commas). */
			function normalizeToThreeColumns(cells) {
				if (!cells || cells.length === 0) return ['', '', ''];
				if (cells.length === 1) return [cells[0], '', ''];
				if (cells.length === 2) return [cells[0], cells[1], ''];
				return [cells[0], cells[1], cells.slice(2).join(',')];
			}

			function stripUtf8Bom(text) {
				if (text && text.charCodeAt(0) === 0xfeff) return text.slice(1);
				return text;
			}

			function parseCSV(text) {
				const rows = [];
				const cleaned = stripUtf8Bom(String(text ?? ''));
				const lines = cleaned.split(/\r?\n/).filter((l) => l.trim());
				for (const line of lines) {
					const protectedLine = protectInchMarksInCsvLine(line);
					const raw = parseCSVLineAll(protectedLine);
					const cells = normalizeToThreeColumns(raw);
					if (cells[1]) cells[1] = normalizeMetricTypography(cells[1]);
					if (cells[2]) cells[2] = normalizeImperialTypography(cells[2]);
					if (cells.some((c) => c.length > 0)) rows.push(cells);
				}
				return rows;
			}

			function isCsvFile(file: File) {
				return file.name.toLowerCase().endsWith('.csv') || file.type === 'text/csv';
			}

			function isSvgFile(file: File) {
				return file.name.toLowerCase().endsWith('.svg') || file.type === 'image/svg+xml';
			}

			function normalizeImportedRows(raw: unknown): string[][] {
				if (!Array.isArray(raw)) return [];
				return raw
					.filter((r) => Array.isArray(r) && r.length >= 3)
					.map((r) => [String(r[0] ?? ''), String(r[1] ?? ''), String(r[2] ?? '')])
					.filter((r) => r.some((c) => c.length > 0));
			}

			type SvgTypographyPayload = {
				col0?: { weight?: string; tracking?: string };
				col1?: { weight?: string; tracking?: string };
				col2?: { weight?: string; tracking?: string };
			};

			function applyTypographyFromSvgPayload(typography?: SvgTypographyPayload) {
				if (!typography) return;
				const cols = [typography.col0, typography.col1, typography.col2];
				cols.forEach((col, i) => {
					if (col?.weight && weightSelects[i]) {
						weightSelects[i].value = col.weight === 'bold' ? 'bold' : 'regular';
					}
					if (col?.tracking != null && trackingInputs[i]) {
						trackingInputs[i].value = String(col.tracking);
					}
				});
			}

			function parseRowsFromSvgTextElements(svg: Element): string[][] | null {
				const textNodes = Array.from(svg.querySelectorAll('text')).filter((t) => (t.textContent ?? '').trim());
				if (!textNodes.length) return null;

				type Item = { y: number; x: number; anchor: string; text: string };
				const items: Item[] = textNodes.map((t) => ({
					y: Number.parseFloat(t.getAttribute('y') ?? '0'),
					x: Number.parseFloat(t.getAttribute('x') ?? '0'),
					anchor: t.getAttribute('text-anchor') ?? 'start',
					text: (t.textContent ?? '').trim()
				}));

				items.sort((a, b) => a.y - b.y || a.x - b.x);

				const ROW_Y_TOLERANCE = 8;
				const rowGroups: Item[][] = [];
				for (const item of items) {
					const last = rowGroups[rowGroups.length - 1];
					if (!last || Math.abs(item.y - last[0].y) > ROW_Y_TOLERANCE) {
						rowGroups.push([item]);
					} else {
						last.push(item);
					}
				}

				const rows = rowGroups
					.map((group) => {
						group.sort((a, b) => a.x - b.x);
						const cells = ['', '', ''];
						if (group.length === 1) {
							if (group[0].anchor === 'end') cells[2] = group[0].text;
							else cells[0] = group[0].text;
						} else if (group.length === 2) {
							cells[0] = group[0].text;
							cells[2] = group[1].text;
						} else {
							cells[0] = group[0]?.text ?? '';
							cells[1] = group[1]?.text ?? '';
							cells[2] = group[2]?.text ?? '';
						}
						return cells;
					})
					.filter((r) => r.some((c) => c.length));

				return rows.length > 0 ? rows : null;
			}

			function parseThreeColumnSvg(svgText: string): {
				rows: string[][];
				sheet?: string;
				typography?: SvgTypographyPayload;
			} | null {
				const doc = new DOMParser().parseFromString(String(svgText ?? ''), 'image/svg+xml');
				if (doc.querySelector('parsererror')) return null;

				const svg = doc.querySelector('svg');
				if (!svg) return null;

				const metadata =
					svg.querySelector('metadata[data-three-column-payload="json"]') ?? svg.querySelector('metadata');
				const metaText = metadata?.textContent?.trim();
				if (metaText) {
					try {
						const payload = JSON.parse(metaText) as {
							generator?: string;
							rows?: unknown;
							csv?: string;
							sheet?: string;
							typography?: SvgTypographyPayload;
						};
						const fromRows = normalizeImportedRows(payload.rows);
						if (fromRows.length) {
							return { rows: fromRows, sheet: payload.sheet, typography: payload.typography };
						}
						if (typeof payload.csv === 'string' && payload.csv.trim()) {
							const fromCsv = parseCSV(payload.csv);
							if (fromCsv.length) {
								return { rows: fromCsv, sheet: payload.sheet, typography: payload.typography };
							}
						}
					} catch {
						// fall through to text-element parsing
					}
				}

				const fromText = parseRowsFromSvgTextElements(svg);
				if (fromText?.length) return { rows: fromText };

				return null;
			}

			function labelFromSvgImport(file: File, sheetName?: string) {
				if (sheetName?.trim()) return sheetName.trim();
				let name = file.name.replace(/\.svg$/i, '').trim();
				name = name.replace(/-4096$/i, '').trim();
				return name || 'Imported SVG';
			}

			const tbody = document.getElementById('rows');
			const previewTbody = document.getElementById('preview-tbody');
			const fileInput = document.getElementById('file-input') as HTMLInputElement;
			const csvPaste = document.getElementById('csv-paste') as HTMLTextAreaElement;
			const importPasteBtn = document.getElementById('import-paste-btn');
			const importCsvBtn = document.getElementById('import-csv-btn');
			const addRowBtn = document.getElementById('add-row');
			const exportCsvBtn = document.getElementById('export-csv') as HTMLButtonElement | null;
			const exportPngBtn = document.getElementById('export-png') as HTMLButtonElement | null;
			const exportSvgBtn = document.getElementById('export-svg') as HTMLButtonElement | null;
			const batchExportCsvBtn = document.getElementById('batch-export-csv') as HTMLButtonElement | null;
			const batchExportPngBtn = document.getElementById('batch-export-png') as HTMLButtonElement | null;
			const batchExportSvgBtn = document.getElementById('batch-export-svg') as HTMLButtonElement | null;
			const batchExportPngCount = document.getElementById('batch-export-png-count') as HTMLSpanElement | null;
			const batchExportCsvCount = document.getElementById('batch-export-csv-count') as HTMLSpanElement | null;
			const batchExportSvgCount = document.getElementById('batch-export-svg-count') as HTMLSpanElement | null;
			const SVG_NS = 'http://www.w3.org/2000/svg';
			const trackingInputs = [
				document.getElementById('tracking-col-0') as HTMLInputElement,
				document.getElementById('tracking-col-1') as HTMLInputElement,
				document.getElementById('tracking-col-2') as HTMLInputElement
			];
			const weightSelects = [
				document.getElementById('weight-col-0') as HTMLSelectElement,
				document.getElementById('weight-col-1') as HTMLSelectElement,
				document.getElementById('weight-col-2') as HTMLSelectElement
			];

			const STORAGE_KEY = 'three-column-sheets-v2';
			const STORAGE_KEY_V1 = 'three-column-rows-v1';
			const STORAGE_OPENROUTER_KEY = 'three-column-openrouter-key';
			const STORAGE_OPENROUTER_MODEL = 'three-column-openrouter-model';
			const STORAGE_GEMINI_KEY = 'three-column-gemini-key';
			const STORAGE_GEMINI_MODEL = 'three-column-gemini-model';
			const STORAGE_AI_PROVIDER = 'three-column-ai-provider';

			/** @type {Sheet[]} */
			let sheets = [];
			let activeIndex = 0;
			let isHydrating = true;

			function normalizeSheetRows(rows) {
				const list = Array.isArray(rows) ? rows : [];
				const out = list
					.filter((r) => Array.isArray(r) && r.length >= 3)
					.slice(0, MAX_IMPORT_ROWS)
					.map((r) => [String(r[0] ?? ''), String(r[1] ?? ''), String(r[2] ?? '')]);
				return out.length > 0 ? out : [['', '', '']];
			}

			function persistState() {
				try {
					const payload = {
						v: 2,
						activeIndex,
						sheets: sheets.slice(0, MAX_SHEETS).map((s) => ({
							id: s.id,
							label: String(s.label ?? 'Sheet').slice(0, 120),
							rows: normalizeSheetRows(s.rows)
						}))
					};
					localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
				} catch {
					// private mode, quota, etc.
				}
			}

			function loadState() {
				try {
					const raw = localStorage.getItem(STORAGE_KEY);
					if (raw) {
						const p = JSON.parse(raw);
						if (p && p.v === 2 && Array.isArray(p.sheets) && p.sheets.length > 0) {
							const loaded = p.sheets.slice(0, MAX_SHEETS).map((s, i) => ({
								id: typeof s.id === 'string' && s.id ? s.id : uid(),
								label: typeof s.label === 'string' && s.label ? s.label : `Sheet ${i + 1}`,
								rows: normalizeSheetRows(s.rows)
							}));
							let ai = Number(p.activeIndex) || 0;
							if (ai < 0 || ai >= loaded.length) ai = 0;
							return { sheets: loaded, activeIndex: ai };
						}
					}
					const v1 = localStorage.getItem(STORAGE_KEY_V1);
					if (v1) {
						const parsed = JSON.parse(v1);
						if (Array.isArray(parsed) && parsed.length > 0) {
							const rows = parsed
								.filter((r) => Array.isArray(r) && r.length >= 3)
								.slice(0, MAX_IMPORT_ROWS)
								.map((r) => [String(r[0] ?? ''), String(r[1] ?? ''), String(r[2] ?? '')]);
							if (rows.length > 0) {
								return {
									sheets: [{ id: uid(), label: 'Sheet 1', rows }],
									activeIndex: 0
								};
							}
						}
					}
				} catch {
					// ignore
				}
				return {
					sheets: [{ id: uid(), label: 'Sheet 1', rows: [['', '', '']] }],
					activeIndex: 0
				};
			}

			function trackingFor(col: number) {
				const raw = trackingInputs[col]?.value ?? '-0.6';
				const n = Number.parseFloat(raw);
				if (!Number.isFinite(n)) return '-0.6px';
				return `${n}px`;
			}

			function weightClassFor(col: number) {
				return weightSelects[col]?.value === 'bold' ? 'monospace821-bold' : 'monospace821-regular';
			}

			function getTableData() {
				const rows: string[][] = [];
				tbody.querySelectorAll('tr').forEach((tr) => {
					const inputs = tr.querySelectorAll('.cell-input');
					if (inputs.length >= 3) {
						rows.push([
							(inputs[0] as HTMLInputElement).value,
							(inputs[1] as HTMLInputElement).value,
							(inputs[2] as HTMLInputElement).value
						]);
					}
				});
				return rows;
			}

			function renderPreview() {
				const data = getTableData();
				if (!isHydrating && sheets[activeIndex]) {
					sheets[activeIndex].rows = data;
					persistState();
				}
				previewTbody.innerHTML = '';
				if (data.length === 0) {
					previewTbody.innerHTML = '<tr><td colspan="3" class="text-neutral-400 text-center py-8">No data. Drop a CSV or SVG, use Input, or add rows in the table.</td></tr>';
					return;
				}
				data.forEach(([a, b, c]) => {
					const tr = document.createElement('tr');
					// Fit content tightly to avoid any extra row sizing from table layout.
					tr.style.height = 'fit-content';
					tr.style.verticalAlign = 'top';
					const t0 = trackingFor(0);
					const t1 = trackingFor(1);
					const t2 = trackingFor(2);
					const w0 = weightClassFor(0);
					const w1 = weightClassFor(1);
					const w2 = weightClassFor(2);

					const td0 = document.createElement('td');
					td0.style.textAlign = 'start';
					td0.style.width = '337px';
					const p0 = document.createElement('p');
					p0.className = w0;
					p0.style.marginLeft = '17px';
					p0.style.fontSize = '14.4px';
					p0.style.lineHeight = '14.4px';
					p0.style.textAlign = 'middle';
					p0.style.flexWrap = 'wrap';
					p0.style.alignContent = 'center';
					p0.style.height = '14.4px';
					p0.style.letterSpacing = t0;
					p0.style.whiteSpace = 'pre';
					p0.textContent = a ?? '';
					td0.appendChild(p0);

					const td1 = document.createElement('td');
					td1.style.textAlign = 'start';
					const p1 = document.createElement('p');
					p1.className = w1;
					p1.style.margin = '0';
					p1.style.fontSize = '14.4px';
					p1.style.lineHeight = '14.4px';
					p1.style.textAlign = 'middle';
					p1.style.flexWrap = 'wrap';
					p1.style.alignContent = 'center';
					p1.style.height = '14.4px';
					p1.style.letterSpacing = t1;
					p1.style.whiteSpace = 'pre';
					p1.textContent = b ?? '';
					td1.appendChild(p1);

					const td2 = document.createElement('td');
					td2.style.textAlign = 'end';
					const p2 = document.createElement('p');
					p2.className = w2;
					p2.style.marginRight = '21px';
					p2.style.fontSize = '14.4px';
					p2.style.height = '14.4px';
					p2.style.lineHeight = '14.4px';
					p2.style.textAlign = 'middle';
					p2.style.flexWrap = 'wrap';
					p2.style.alignContent = 'center';
					p2.style.letterSpacing = t2;
					p2.style.whiteSpace = 'pre';
					p2.textContent = c ?? '';
					td2.appendChild(p2);

					tr.appendChild(td0);
					tr.appendChild(td1);
					tr.appendChild(td2);
					previewTbody.appendChild(tr);

					// Pixel-precise divider line directly under each preview row
					const sepTr = document.createElement('tr');
					sepTr.style.height = 'fit-content';
					sepTr.style.verticalAlign = 'top';
					const sepTd = document.createElement('td');
					sepTd.colSpan = 3;
					sepTd.style.borderBottom = 'none';

					const topSpacer = document.createElement('div');
					topSpacer.style.height = '8px';
					topSpacer.style.width = '100%';
					sepTd.appendChild(topSpacer);

					const sepDiv = document.createElement('div');
					sepDiv.className = 'h-[2px] w-[654px] bg-black';
					sepTd.appendChild(sepDiv);

					const belowLine = document.createElement('div');
					belowLine.style.height = '7px';
					belowLine.style.width = '100%';
					sepTd.appendChild(belowLine);
					sepTr.appendChild(sepTd);
					previewTbody.appendChild(sepTr);
				});
			}

			function escapeHtml(s) {
				const div = document.createElement('div');
				div.textContent = s;
				return div.innerHTML;
			}

			// --- Chip-cell helpers ---------------------------------------------------
			// The chip-cell looks like a single input field. Internally it holds zero or
			// more frozen "chip" <span>s, plus a trailing <input> where the user types.
			// As the user types a complete value, that value freezes into a chip.
			// Backspace at start of empty trailing input "unfreezes" the last chip back
			// into typable text. Each chip has an × button that removes it entirely.
			const FANCY_APOS = '’'; // ’
			const MAX_CHIPS_PER_CELL = 2;

			function buildChipSpan(value: string): HTMLSpanElement {
				const span = document.createElement('span');
				span.className = 'chip';
				span.dataset.value = value;
				span.tabIndex = -1;

				const text = document.createElement('span');
				text.className = 'chip-text';
				text.textContent = value;
				span.appendChild(text);

				const close = document.createElement('button');
				close.type = 'button';
				close.className = 'chip-remove';
				close.tabIndex = -1;
				close.setAttribute('aria-label', 'Remove');
				close.textContent = '×';
				span.appendChild(close);

				return span;
			}

			function buildChipSeparator(): HTMLSpanElement {
				const s = document.createElement('span');
				s.className = 'chip-x';
				s.textContent = '×';
				return s;
			}

			function buildTrailingInput(value: string): HTMLInputElement {
				const inp = document.createElement('input');
				inp.type = 'text';
				inp.className = 'chip-trailing-input';
				inp.value = value;
				inp.setAttribute('spellcheck', 'false');
				inp.autocomplete = 'off';
				inp.setAttribute('autocapitalize', 'off');
				inp.setAttribute('autocorrect', 'off');
				return inp;
			}

			function getChipValues(chipCell: HTMLElement): string[] {
				return Array.from(chipCell.querySelectorAll<HTMLSpanElement>('.chip')).map(
					(c) => c.dataset.value ?? c.querySelector('.chip-text')?.textContent ?? ''
				);
			}

			function getTrailingInput(chipCell: HTMLElement): HTMLInputElement | null {
				return chipCell.querySelector<HTMLInputElement>('.chip-trailing-input');
			}

			function rebuildCombinedFromChipCell(
				chipCell: HTMLElement,
				cellInput: HTMLInputElement,
				fireEvent = true
			) {
				const chips = getChipValues(chipCell);
				const trailing = getTrailingInput(chipCell);
				const trailingVal = trailing?.value.trim() ?? '';
				const parts: string[] = [...chips];
				if (trailingVal) parts.push(trailingVal);

				let combined = '';
				if (parts.length === 1) combined = parts[0];
				else if (parts.length > 1) combined = parts.join('  x  ');

				if (cellInput.value !== combined) {
					cellInput.value = combined;
					if (fireEvent) cellInput.dispatchEvent(new Event('input', { bubbles: true }));
				}
			}

			function splitCombinedToChipValues(combined: string, col: number): string[] {
				if (col === 0) return combined ? [combined] : [];
				const trimmed = combined.trim();
				if (!trimmed) return [];
				const parts = trimmed.split(/\s+[x×]\s+|\s+by\s+/i);
				if (parts.length > 1) return parts.map((p) => p.trim()).filter(Boolean);
				return [trimmed];
			}

			function setChipsFromCombined(
				chipCell: HTMLElement,
				cellInput: HTMLInputElement,
				combined: string,
				opts?: { fireEvent?: boolean }
			) {
				const fireEvent = opts?.fireEvent !== false;
				const col = Number(chipCell.dataset.col ?? 0);
				const parts = splitCombinedToChipValues(combined, col);

				// Structure: [chip] [sep] [chip] ... [trailing]
				// No separator between the last chip and the trailing input.
				chipCell.innerHTML = '';
				if (col === 0) {
					// Room name: whole value lives in the trailing input (no chipping).
					const trailing = buildTrailingInput(combined);
					chipCell.appendChild(trailing);
					bindTrailingEvents(trailing, chipCell, cellInput);
				} else {
					parts.forEach((p, i) => {
						if (i > 0) chipCell.appendChild(buildChipSeparator());
						const chip = buildChipSpan(p);
						chipCell.appendChild(chip);
						bindChipEvents(chip, chipCell, cellInput);
					});
					const trailing = buildTrailingInput('');
					chipCell.appendChild(trailing);
					bindTrailingEvents(trailing, chipCell, cellInput);
				}

				cellInput.value = combined;
				if (fireEvent) cellInput.dispatchEvent(new Event('input', { bubbles: true }));
			}

			function isCompleteChipValue(value: string, col: number): boolean {
				const v = value.trim();
				if (!v) return false;
				if (col === 1) return /\d+(?:\.\d+)?m$/.test(v);
				if (col === 2) return /\d+’(?:\d+’’)?$/.test(v);
				return false;
			}

			function convertAsciiQuotesInPlace(inp: HTMLInputElement) {
				const oldVal = inp.value;
				const cursor = inp.selectionStart ?? oldVal.length;
				let out = '';
				let newCursor = cursor;
				for (let i = 0; i < oldVal.length; i++) {
					const c = oldVal[i];
					if (c === '"') {
						out += FANCY_APOS + FANCY_APOS;
						if (i < cursor) newCursor += 1;
					} else if (c === "'") {
						out += FANCY_APOS;
					} else {
						out += c;
					}
				}
				if (out !== oldVal) {
					inp.value = out;
					inp.setSelectionRange(newCursor, newCursor);
				}
			}

			function tryChipifyTrailing(
				trailing: HTMLInputElement,
				chipCell: HTMLElement,
				cellInput: HTMLInputElement
			): boolean {
				const col = Number(chipCell.dataset.col ?? 0);
				if (col !== 1 && col !== 2) return false;

				const v = trailing.value;
				let head: string | null = null;
				let rest = '';

				// Pass 1: explicit x/×/by separator
				let m = v.match(/^(.+?)\s*(?:[x×X]|by)\s+(.*)$/i);
				if (!m) m = v.match(/^(.+?)\s*[x×]\s*(.*)$/i);
				if (m && m[1].trim()) {
					head = m[1].trim();
					rest = m[2];
				}

				// Pass 2: space after a complete-looking value
				if (!head) {
					const m2 = v.match(/^(.+?)\s+(.*)$/);
					if (m2 && isCompleteChipValue(m2[1], col)) {
						head = m2[1];
						rest = m2[2];
					}
				}

				if (!head) return false;

				const existingChips = chipCell.querySelectorAll('.chip');
				if (existingChips.length >= MAX_CHIPS_PER_CELL) return false;

				// Insert separator (between chips) + new chip BEFORE the trailing input.
				// No separator goes between the last chip and trailing.
				if (existingChips.length > 0) {
					chipCell.insertBefore(buildChipSeparator(), trailing);
				}
				const chip = buildChipSpan(head);
				chipCell.insertBefore(chip, trailing);
				bindChipEvents(chip, chipCell, cellInput);

				trailing.value = rest;
				trailing.setSelectionRange(rest.length, rest.length);
				return true;
			}

			function removeChip(
				chip: HTMLSpanElement,
				chipCell: HTMLElement,
				cellInput: HTMLInputElement
			) {
				// Remove chip + the inter-chip separator paired with it.
				const prev = chip.previousElementSibling;
				const next = chip.nextElementSibling;
				if (next && next.classList.contains('chip-x')) next.remove();
				else if (prev && prev.classList.contains('chip-x')) prev.remove();
				chip.remove();
				rebuildCombinedFromChipCell(chipCell, cellInput);
				getTrailingInput(chipCell)?.focus();
			}

			function unfreezeChip(
				chip: HTMLSpanElement,
				chipCell: HTMLElement,
				cellInput: HTMLInputElement
			) {
				const value = chip.dataset.value ?? '';
				const trailing = getTrailingInput(chipCell);
				if (!trailing) return;

				const prev = chip.previousElementSibling;
				const next = chip.nextElementSibling;
				if (next && next.classList.contains('chip-x')) next.remove();
				else if (prev && prev.classList.contains('chip-x')) prev.remove();
				chip.remove();

				trailing.value = value + trailing.value;
				trailing.focus();
				trailing.setSelectionRange(value.length, value.length);
				rebuildCombinedFromChipCell(chipCell, cellInput);
			}

			function startChipInlineEdit(
				chip: HTMLSpanElement,
				chipCell: HTMLElement,
				cellInput: HTMLInputElement
			) {
				if (chip.dataset.editing === '1') return;
				const col = Number(chipCell.dataset.col ?? 0);
				if (col !== 1 && col !== 2) return;

				const textEl = chip.querySelector<HTMLSpanElement>('.chip-text');
				const closeBtn = chip.querySelector<HTMLButtonElement>('.chip-remove');
				if (!textEl || !closeBtn) return;

				chip.dataset.editing = '1';
				const current = chip.dataset.value ?? textEl.textContent ?? '';

				textEl.style.display = 'none';
				closeBtn.style.display = 'none';

				const editInp = document.createElement('input');
				editInp.type = 'text';
				editInp.className = 'chip-inline-edit';
				editInp.value = current;
				editInp.setAttribute('spellcheck', 'false');
				editInp.autocomplete = 'off';
				chip.insertBefore(editInp, closeBtn);
				editInp.focus();
				editInp.select();

				const finish = (commit: boolean) => {
					if (chip.dataset.editing !== '1') return;
					if (commit) {
						let val = editInp.value.trim();
						if (col === 1) val = normalizeMetricTypography(val);
						else if (col === 2) val = normalizeImperialTypography(val);
						chip.dataset.value = val;
						textEl.textContent = val;
						rebuildCombinedFromChipCell(chipCell, cellInput);
					}
					editInp.remove();
					textEl.style.display = '';
					closeBtn.style.display = '';
					delete chip.dataset.editing;
				};

				editInp.addEventListener('input', () => {
					if (col === 2) convertAsciiQuotesInPlace(editInp);
				});
				editInp.addEventListener('keydown', (e) => {
					if (e.key === 'Enter') {
						e.preventDefault();
						finish(true);
					} else if (e.key === 'Escape') {
						e.preventDefault();
						finish(false);
					}
				});
				editInp.addEventListener('blur', () => finish(true));
			}

			function bindChipEvents(
				chip: HTMLSpanElement,
				chipCell: HTMLElement,
				cellInput: HTMLInputElement
			) {
				chip.title = 'Double-click to edit';
				const close = chip.querySelector<HTMLButtonElement>('.chip-remove');
				close?.addEventListener('click', (e) => {
					e.stopPropagation();
					removeChip(chip, chipCell, cellInput);
				});
				chip.addEventListener('dblclick', (e) => {
					if ((e.target as HTMLElement).closest('.chip-remove')) return;
					e.preventDefault();
					e.stopPropagation();
					startChipInlineEdit(chip, chipCell, cellInput);
				});
				// Click chip body (not ×) → focus trailing so backspace will unfreeze it
				chip.addEventListener('click', (e) => {
					if ((e.target as HTMLElement).closest('.chip-remove')) return;
					if (chip.dataset.editing === '1') return;
					getTrailingInput(chipCell)?.focus();
				});
			}

			function bindTrailingEvents(
				trailing: HTMLInputElement,
				chipCell: HTMLElement,
				cellInput: HTMLInputElement
			) {
				const col = Number(chipCell.dataset.col ?? 0);

				trailing.addEventListener('input', () => {
					if (col === 2) convertAsciiQuotesInPlace(trailing);
					if (col === 1 || col === 2) tryChipifyTrailing(trailing, chipCell, cellInput);
					rebuildCombinedFromChipCell(chipCell, cellInput);
				});

				// Backspace at start of empty trailing → unfreeze last chip
				trailing.addEventListener('keydown', (e) => {
					if (
						e.key === 'Backspace' &&
						trailing.value === '' &&
						(trailing.selectionStart ?? 0) === 0
					) {
						const chips = chipCell.querySelectorAll<HTMLSpanElement>('.chip');
						const last = chips[chips.length - 1];
						if (last) {
							e.preventDefault();
							unfreezeChip(last, chipCell, cellInput);
						}
					}
				});

				// Typography normalize on focusout — and chipify if normalize produced "  x  ".
				trailing.addEventListener('focusout', () => {
					let n = trailing.value;
					if (col === 1) n = normalizeMetricTypography(n);
					else if (col === 2) n = normalizeImperialTypography(n);
					if (n !== trailing.value) {
						trailing.value = n;
						if (col !== 0 && /\s+x\s+/i.test(n)) {
							tryChipifyTrailing(trailing, chipCell, cellInput);
						}
						rebuildCombinedFromChipCell(chipCell, cellInput);
					}
				});
			}

			function bindChipCellClickToFocus(chipCell: HTMLElement) {
				if (chipCell.dataset.cellClickBound === '1') return;
				chipCell.dataset.cellClickBound = '1';
				chipCell.addEventListener('click', (e) => {
					const target = e.target as HTMLElement;
					if (target.closest('.chip-remove')) return;
					if (target.closest('.chip-trailing-input')) return;
					if (target.closest('.chip')) return; // chip's own click handler runs
					getTrailingInput(chipCell)?.focus();
				});
			}

			function addRow(cells: string[] = ['', '', ''], options?: { silent?: boolean }) {
				const silent = options?.silent === true;
				const tr = document.createElement('tr');
				tr.className = 'border-t border-neutral-100 transition-colors';
				const cellTabSvg = `<svg class="w-3 h-3" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><circle cx="6" cy="3" r="1"/><circle cx="6" cy="8" r="1"/><circle cx="6" cy="13" r="1"/><circle cx="10" cy="3" r="1"/><circle cx="10" cy="8" r="1"/><circle cx="10" cy="13" r="1"/></svg>`;
				// Each cell holds a `.chip-cell` with one or more visible `.chip-input` chips
				// plus a hidden `.cell-input` mirroring the combined value (for compat with
				// existing readers like getTableData / drag-swap).
				const cellTd = (col: 0 | 1 | 2) =>
					`<td class="p-1.5"><div class="cell-wrap relative"><div class="chip-cell" data-col="${col}"></div><input type="hidden" class="cell-input" data-col="${col}" value="${escapeHtml(cells[col] ?? '')}" /><span class="cell-drag-handle" draggable="true" title="Drag to swap cells" aria-label="Drag to swap cells">${cellTabSvg}</span></div></td>`;
				tr.innerHTML = `
					<td class="px-1 py-1.5 text-center align-middle"><span class="row-drag-handle inline-flex items-center justify-center w-5 h-6 text-neutral-300 hover:text-neutral-600 cursor-grab active:cursor-grabbing select-none" title="Drag to reorder" aria-label="Drag to reorder"><svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><circle cx="7" cy="4" r="1.2"/><circle cx="7" cy="10" r="1.2"/><circle cx="7" cy="16" r="1.2"/><circle cx="13" cy="4" r="1.2"/><circle cx="13" cy="10" r="1.2"/><circle cx="13" cy="16" r="1.2"/></svg></span></td>
					${cellTd(0)}
					${cellTd(1)}
					${cellTd(2)}
					<td class="p-1.5 text-right"><button type="button" class="delete-row px-2 py-1 text-xs rounded-md bg-red-50 text-red-700 hover:bg-red-100">Del</button></td>
				`;
				tr.querySelector('.delete-row')!.addEventListener('click', () => {
					tr.remove();
					renderPreview();
					commitActiveSheet();
					persistState();
				});
				tbody.appendChild(tr);

				// Build initial chips for each cell from the supplied values.
				tr.querySelectorAll<HTMLElement>('.chip-cell').forEach((chipCell) => {
					const col = Number(chipCell.dataset.col ?? 0);
					const cellInput = chipCell.parentElement?.querySelector<HTMLInputElement>('input.cell-input');
					if (!cellInput) return;
					setChipsFromCombined(chipCell, cellInput, cells[col] ?? '', { fireEvent: false });
					bindChipCellClickToFocus(chipCell);
				});

				// Hidden .cell-input still fires `input` when chips change → trigger preview.
				tr.querySelectorAll<HTMLInputElement>('input.cell-input').forEach((el) => {
					el.addEventListener('input', () => {
						renderPreview();
					});
				});
				bindRowDrag(tr);
				tr.querySelectorAll('.cell-wrap').forEach((wrap) => {
					bindCellSwapDrag(wrap as HTMLElement);
				});
				if (!silent) renderPreview();
			}

			const sheetTabsEl = document.getElementById('sheet-tabs');
			const addSheetBtn = document.getElementById('add-sheet-btn');

			function commitActiveSheet() {
				if (!sheets[activeIndex]) return;
				sheets[activeIndex].rows = getTableData();
			}

			function replaceEditorRows(rows) {
				const capped = normalizeSheetRows(rows).slice(0, MAX_IMPORT_ROWS);
				tbody.innerHTML = '';
				for (let i = 0; i < capped.length; i++) {
					addRow(capped[i], { silent: i < capped.length - 1 });
				}
			}

			function scrollActiveTabIntoView() {
				const el = sheetTabsEl?.querySelector(`[data-sheet-tab="${activeIndex}"]`);
				if (el && 'scrollIntoView' in el) {
					el.scrollIntoView({ block: 'nearest', inline: 'nearest', behavior: 'smooth' });
				}
			}

			function renderTabBar() {
				if (!sheetTabsEl) return;
				sheetTabsEl.innerHTML = '';
				sheets.forEach((sheet, i) => {
					const wrap = document.createElement('div');
					wrap.className = 'inline-flex items-stretch shrink-0 rounded-md border border-neutral-200 overflow-hidden';
					const tabMain = document.createElement('div');
					tabMain.setAttribute('role', 'tab');
					tabMain.tabIndex = 0;
					tabMain.setAttribute('aria-selected', i === activeIndex ? 'true' : 'false');
					tabMain.dataset.sheetTab = String(i);
					tabMain.className =
						i === activeIndex
							? 'px-2.5 py-1.5 max-w-[220px] min-w-[3rem] flex items-center text-sm font-medium bg-neutral-800 text-white cursor-default select-none'
							: 'px-2.5 py-1.5 max-w-[220px] min-w-[3rem] flex items-center text-sm font-medium bg-neutral-100 text-neutral-800 hover:bg-neutral-200 cursor-pointer select-none';
					const labelSpan = document.createElement('span');
					labelSpan.className = 'truncate';
					labelSpan.textContent = sheet.label;
					labelSpan.title = 'Double-click to rename (used for export filename)';
					tabMain.appendChild(labelSpan);
					tabMain.addEventListener('click', () => setActiveSheet(i));
					tabMain.addEventListener('keydown', (e) => {
						if (e.key === 'Enter' || e.key === ' ') {
							e.preventDefault();
							setActiveSheet(i);
						}
					});
					labelSpan.addEventListener('dblclick', (e) => {
						e.stopPropagation();
						e.preventDefault();
						commitActiveSheet();
						const inp = document.createElement('input');
						inp.type = 'text';
						inp.value = sheet.label;
						inp.className =
							'w-full min-w-[10rem] max-w-[200px] px-1 py-0.5 text-sm rounded border border-violet-500 bg-white text-neutral-900 shadow-sm';
						let cancelled = false;
						inp.addEventListener('keydown', (ev) => {
							if (ev.key === 'Escape') {
								ev.preventDefault();
								cancelled = true;
								renderTabBar();
								scrollActiveTabIntoView();
							}
						});
						inp.addEventListener('blur', () => {
							if (cancelled) return;
							const v = inp.value.trim().slice(0, 120) || sheet.label;
							sheets[i].label = v;
							persistState();
							renderTabBar();
							scrollActiveTabIntoView();
						});
						labelSpan.replaceWith(inp);
						inp.focus();
						inp.select();
					});

					const close = document.createElement('button');
					close.type = 'button';
					close.setAttribute('aria-label', `Close ${sheet.label}`);
					close.className =
						'px-1.5 text-sm leading-none border-l border-neutral-200 bg-neutral-50 text-neutral-600 hover:bg-red-50 hover:text-red-700 disabled:opacity-40 disabled:hover:bg-neutral-50 disabled:hover:text-neutral-600';
					close.textContent = '×';
					close.title = sheets.length <= 1 ? 'Close sheet (resets to a new empty sheet)' : 'Close sheet';
					close.addEventListener('click', (ev) => {
						ev.stopPropagation();
						removeSheet(i);
					});

					wrap.appendChild(tabMain);
					wrap.appendChild(close);
					sheetTabsEl.appendChild(wrap);
				});
				updateBatchExportVisibility();
			}

			function updateBatchExportVisibility() {
				const multi = sheets.length > 1;
				const count = multi ? `${sheets.length}` : '';
				if (batchExportPngBtn) {
					batchExportPngBtn.disabled = !multi;
					batchExportPngBtn.title = multi ? '' : 'Add another sheet to export all.';
				}
				if (batchExportCsvBtn) {
					batchExportCsvBtn.disabled = !multi;
					batchExportCsvBtn.title = multi ? '' : 'Add another sheet to export all.';
				}
				if (batchExportSvgBtn) {
					batchExportSvgBtn.disabled = !multi;
					batchExportSvgBtn.title = multi ? '' : 'Add another sheet to export all.';
				}
				if (batchExportPngCount) batchExportPngCount.textContent = count;
				if (batchExportCsvCount) batchExportCsvCount.textContent = count;
				if (batchExportSvgCount) batchExportSvgCount.textContent = count;
			}

			function setActiveSheet(i) {
				if (i === activeIndex) return;
				commitActiveSheet();
				activeIndex = Math.max(0, Math.min(i, sheets.length - 1));
				replaceEditorRows(sheets[activeIndex].rows);
				renderTabBar();
				renderPreview();
				scrollActiveTabIntoView();
			}

			function removeSheet(index) {
				commitActiveSheet();
				sheets.splice(index, 1);
				if (sheets.length === 0) {
					sheets.push({ id: uid(), label: 'Sheet 1', rows: [['', '', '']] });
					activeIndex = 0;
				} else {
					if (activeIndex >= sheets.length) activeIndex = sheets.length - 1;
					else if (index < activeIndex) activeIndex--;
				}
				replaceEditorRows(sheets[activeIndex].rows);
				renderTabBar();
				renderPreview();
				scrollActiveTabIntoView();
				persistState();
			}

			function addEmptySheet() {
				commitActiveSheet();
				if (sheets.length >= MAX_SHEETS) return;
				const n = sheets.length + 1;
				sheets.push({ id: uid(), label: `Sheet ${n}`, rows: [['', '', '']] });
				activeIndex = sheets.length - 1;
				replaceEditorRows(sheets[activeIndex].rows);
				renderTabBar();
				renderPreview();
				scrollActiveTabIntoView();
			}

			async function importCsvFiles(fileList) {
				const files = Array.from(fileList ?? []).filter((f): f is File => f instanceof File && isCsvFile(f));
				if (!files.length) return;
				commitActiveSheet();
				let added = 0;
				let firstNewIndex = -1;
				for (const file of files) {
					if (sheets.length >= MAX_SHEETS) break;
					const text = await readFileAsText(file);
					const rows = parseCSV(text);
					const body = rows.length > 0 ? rows.slice(0, MAX_IMPORT_ROWS) : [['', '', '']];
					const label = file.name.replace(/\.csv$/i, '') || 'Imported';
					sheets.push({ id: uid(), label, rows: body });
					if (firstNewIndex < 0) firstNewIndex = sheets.length - 1;
					added++;
				}
				if (added > 0 && firstNewIndex >= 0) {
					activeIndex = firstNewIndex;
					replaceEditorRows(sheets[activeIndex].rows);
					renderTabBar();
					renderPreview();
					scrollActiveTabIntoView();
				}
			}

			async function importSvgFiles(fileList) {
				const files = Array.from(fileList ?? []).filter((f): f is File => f instanceof File && isSvgFile(f));
				if (!files.length) return;
				commitActiveSheet();
				const importStatus = document.getElementById('ai-status') as HTMLSpanElement | null;
				let added = 0;
				let firstNewIndex = -1;
				let lastTypography: SvgTypographyPayload | undefined;
				let failed = 0;

				for (const file of files) {
					if (sheets.length >= MAX_SHEETS) break;
					const text = String(await readFileAsText(file));
					const parsed = parseThreeColumnSvg(text);
					if (!parsed?.rows.length) {
						failed++;
						continue;
					}
					const body = parsed.rows.slice(0, MAX_IMPORT_ROWS);
					let label = dedupeSheetLabel(labelFromSvgImport(file, parsed.sheet));
					sheets.push({ id: uid(), label, rows: body });
					lastTypography = parsed.typography;
					if (firstNewIndex < 0) firstNewIndex = sheets.length - 1;
					added++;
				}

				if (added > 0 && firstNewIndex >= 0) {
					activeIndex = firstNewIndex;
					applyTypographyFromSvgPayload(lastTypography);
					replaceEditorRows(sheets[activeIndex].rows);
					renderTabBar();
					renderPreview();
					scrollActiveTabIntoView();
					if (importStatus) {
						const failNote = failed > 0 ? ` (${failed} file(s) skipped — no embedded data)` : '';
						importStatus.textContent = `Imported ${added} SVG sheet(s)${failNote}.`;
					}
				} else if (failed > 0 && importStatus) {
					importStatus.textContent = 'Could not read table data from SVG (expected embedded metadata or text).';
				}
			}

			async function importDataFiles(fileList: FileList | File[] | null | undefined) {
				const files = Array.from(fileList ?? []).filter((f): f is File => f instanceof File);
				const csvFiles = files.filter(isCsvFile);
				const svgFiles = files.filter(isSvgFile);
				if (csvFiles.length) await importCsvFiles(csvFiles);
				if (svgFiles.length) await importSvgFiles(svgFiles);
			}

			function importPastedCsv(text) {
				const rows = parseCSV(text);
				if (!rows.length) return;
				commitActiveSheet();
				if (sheets.length >= MAX_SHEETS) return;
				const body = rows.slice(0, MAX_IMPORT_ROWS);
				let label = 'Pasted';
				let n = 2;
				while (sheets.some((s) => s.label === label)) {
					label = `Pasted (${n})`;
					n++;
				}
				sheets.push({ id: uid(), label, rows: body });
				activeIndex = sheets.length - 1;
				replaceEditorRows(sheets[activeIndex].rows);
				renderTabBar();
				renderPreview();
				scrollActiveTabIntoView();
			}

			function importMatrixAsNewSheet(matrix: string[][], baseLabel = 'AI parsed') {
				const body = (Array.isArray(matrix) ? matrix : [])
					.map((r) => [String(r[0] ?? ''), String(r[1] ?? ''), String(r[2] ?? '')])
					.filter((r) => r.some((c) => c.length))
					.slice(0, MAX_IMPORT_ROWS);
				if (!body.length) return false;
				commitActiveSheet();
				if (sheets.length >= MAX_SHEETS) return false;
				let label = baseLabel;
				let n = 2;
				while (sheets.some((s) => s.label === label)) {
					label = `${baseLabel} (${n})`;
					n++;
				}
				sheets.push({ id: uid(), label, rows: body.length ? body : [['', '', '']] });
				activeIndex = sheets.length - 1;
				replaceEditorRows(sheets[activeIndex].rows);
				renderTabBar();
				renderPreview();
				scrollActiveTabIntoView();
				return true;
			}

			function labelForAiAttachment(index: number, total: number, attachmentName?: string) {
				if (total <= 1) return 'AI parsed';
				const raw = (attachmentName ?? '').replace(/\.[^.]+$/i, '').trim();
				if (raw) return raw.length > 48 ? raw.slice(0, 45) + '…' : raw;
				return `AI ${index + 1}`;
			}

			function dedupeSheetLabel(baseLabel: string) {
				let label = baseLabel;
				let n = 2;
				while (sheets.some((s) => s.label === label)) {
					label = `${baseLabel} (${n})`;
					n++;
				}
				return label;
			}

			function rowsFromAiPart(part: { rows: { a?: string; b?: string; c?: string }[] }) {
				const matrix = part.rows.map((row) => [
					String(row.a ?? ''),
					normalizeMetricTypography(String(row.b ?? '')),
					normalizeImperialTypography(String(row.c ?? ''))
				]);
				const body = matrix
					.map((r) => [String(r[0] ?? ''), String(r[1] ?? ''), String(r[2] ?? '')])
					.filter((r) => r.some((c) => c.length))
					.slice(0, MAX_IMPORT_ROWS);
				return body.length ? body : [['', '', '']];
			}

			// --- Cross-row consistency check for AI-parsed dimensions ----------------
			// Catches the common AI failure where row N's imperial pair contains values
			// that actually belong to row N+1 (i.e. the model reordered imperial values
			// across rows, so e.g. "5.05m × 5.49m" gets paired with "16'7'' × 11'2''"
			// instead of "16'7'' × 18'0''").

			const FT_PER_M = 3.28084;
			// Per-dimension tolerance: bigger of 0.5ft (~6 inches) or 5% relative.
			const DIM_ABS_TOL_FEET = 0.5;
			const DIM_REL_TOL = 0.05;

			function parseMetricMeters(s: string): number[] {
				if (!s) return [];
				const out: number[] = [];
				const re = /(\d+(?:\.\d+)?)\s*m\b/gi;
				let m: RegExpExecArray | null;
				while ((m = re.exec(s)) !== null) {
					const v = parseFloat(m[1]);
					if (Number.isFinite(v) && v > 0) out.push(v);
				}
				return out;
			}

			function parseImperialFeet(s: string): number[] {
				if (!s) return [];
				// Normalize fancy primes to ASCII for matching: ’’ → " ; '' → " ; ’ → ' ; ″ → "
				const t = s
					.replace(/’’/g, '"')
					.replace(/''/g, '"')
					.replace(/″/g, '"')
					.replace(/[’]/g, "'");
				const out: number[] = [];
				// Match feet'inch" or feet' (inch optional, trailing inch mark optional)
				const re = /(\d+)\s*'\s*(\d+)?\s*"?/g;
				let m: RegExpExecArray | null;
				while ((m = re.exec(t)) !== null) {
					const ft = parseInt(m[1], 10);
					const inch = m[2] ? parseInt(m[2], 10) : 0;
					if (Number.isFinite(ft) && ft >= 0) out.push(ft + inch / 12);
				}
				return out;
			}

			/** Split a "A  x  B" pair on the multiplication separator; returns trimmed parts. */
			function splitDimPair(s: string): string[] {
				if (!s) return [];
				return s.split(/\s*[x×]\s*/i).map((p) => p.trim()).filter(Boolean);
			}

			function joinDimPair(parts: string[]): string {
				// Match the prompt's "  x  " spacing rule.
				return parts.join('  x  ');
			}

			function dimensionsAreConsistent(metric: number[], imperial: number[]): boolean {
				if (metric.length === 0 || imperial.length === 0) return true; // can't validate
				if (metric.length !== imperial.length) return false;
				for (let i = 0; i < metric.length; i++) {
					const expectedFt = metric[i] * FT_PER_M;
					const actualFt = imperial[i];
					const diff = Math.abs(expectedFt - actualFt);
					const rel = expectedFt > 0 ? diff / expectedFt : 0;
					if (diff > DIM_ABS_TOL_FEET && rel > DIM_REL_TOL) return false;
				}
				return true;
			}

			/**
			 * Validate metric ⇄ imperial pairing for each row, and try cheap auto-fixes
			 * when consecutive rows look mis-paired (the most common AI failure pattern).
			 *
			 * Returns a NEW matrix (input is not mutated) plus user-facing warnings and
			 * a count of rows that were auto-corrected.
			 */
			function verifyAndFixCrossPairing(matrix: string[][]): {
				matrix: string[][];
				warnings: string[];
				fixedCount: number;
				flaggedCount: number;
			} {
				type RowState = {
					row: string[];
					metric: number[];
					imperial: number[];
					impParts: string[];
				};
				const states: RowState[] = matrix.map((r) => ({
					row: [r[0] ?? '', r[1] ?? '', r[2] ?? ''],
					metric: parseMetricMeters(r[1] ?? ''),
					imperial: parseImperialFeet(r[2] ?? ''),
					impParts: splitDimPair(r[2] ?? '')
				}));

				const warnings: string[] = [];
				let fixedCount = 0;

				const matches = (st: RowState) => dimensionsAreConsistent(st.metric, st.imperial);

				const recomputeImperial = (st: RowState, newParts: string[]) => {
					st.impParts = newParts;
					const joined = newParts.length === 1 ? newParts[0] : joinDimPair(newParts);
					st.row[2] = joined;
					st.imperial = parseImperialFeet(joined);
				};

				// Pass 1: try swapping the second imperial of row i with the first imperial
				// of row i+1 (the user-reported pattern). Only apply if BOTH rows then match.
				for (let i = 0; i < states.length - 1; i++) {
					const a = states[i];
					const b = states[i + 1];
					if (matches(a) && matches(b)) continue;
					if (
						a.metric.length === 2 &&
						b.metric.length === 2 &&
						a.impParts.length === 2 &&
						b.impParts.length === 2
					) {
						const aTry = [a.impParts[0], b.impParts[0]];
						const bTry = [a.impParts[1], b.impParts[1]];
						const aFeetTry = parseImperialFeet(joinDimPair(aTry));
						const bFeetTry = parseImperialFeet(joinDimPair(bTry));
						if (
							dimensionsAreConsistent(a.metric, aFeetTry) &&
							dimensionsAreConsistent(b.metric, bFeetTry)
						) {
							recomputeImperial(a, aTry);
							recomputeImperial(b, bTry);
							fixedCount += 2;
							warnings.push(
								`Auto-fixed mis-paired imperial values between rows ${i + 1} (${a.row[0] || 'unlabelled'}) and ${i + 2} (${b.row[0] || 'unlabelled'}).`
							);
						}
					}
				}

				// Pass 2: try a full swap of imperial pairs between adjacent rows.
				for (let i = 0; i < states.length - 1; i++) {
					const a = states[i];
					const b = states[i + 1];
					if (matches(a) && matches(b)) continue;
					if (
						a.impParts.length >= 1 &&
						b.impParts.length >= 1 &&
						a.impParts.length === b.impParts.length
					) {
						const aTry = b.impParts.slice();
						const bTry = a.impParts.slice();
						const aFeetTry = parseImperialFeet(joinDimPair(aTry));
						const bFeetTry = parseImperialFeet(joinDimPair(bTry));
						if (
							dimensionsAreConsistent(a.metric, aFeetTry) &&
							dimensionsAreConsistent(b.metric, bFeetTry)
						) {
							recomputeImperial(a, aTry);
							recomputeImperial(b, bTry);
							fixedCount += 2;
							warnings.push(
								`Auto-fixed swapped imperial rows ${i + 1} ↔ ${i + 2} (${a.row[0] || '?'} / ${b.row[0] || '?'}).`
							);
						}
					}
				}

				// Final pass: flag remaining mismatches for the user. Don't mutate, just warn.
				let flaggedCount = 0;
				for (let i = 0; i < states.length; i++) {
					const st = states[i];
					if (!matches(st)) {
						flaggedCount++;
						const label = st.row[0] || `row ${i + 1}`;
						warnings.push(
							`⚠️ ${label}: metric ${st.row[1] || '—'} doesn't match imperial ${st.row[2] || '—'} (please double-check).`
						);
					}
				}

				return {
					matrix: states.map((s) => s.row),
					warnings,
					fixedCount,
					flaggedCount
				};
			}

			function extractJsonRowsFromAssistantText(raw: string): { rows: { a?: string; b?: string; c?: string }[] } {
				let t = String(raw ?? '').trim();
				const fence = /```(?:json)?\s*([\s\S]*?)```/;
				const fm = t.match(fence);
				if (fm) t = fm[1].trim();

				function tryParse(s: string): unknown {
					return JSON.parse(s);
				}

				let parsed: unknown;
				try {
					parsed = tryParse(t);
				} catch {
					const start = t.indexOf('{');
					const end = t.lastIndexOf('}');
					if (start < 0 || end <= start) {
						throw new Error('Model did not return JSON with a "rows" array. Try again or pick a stronger model.');
					}
					parsed = tryParse(t.slice(start, end + 1));
				}
				if (!parsed || typeof parsed !== 'object' || !Array.isArray((parsed as { rows?: unknown }).rows)) {
					throw new Error('JSON must be an object with a "rows" array.');
				}
				return parsed as { rows: { a?: string; b?: string; c?: string }[] };
			}

			async function parseOpenRouterResponse(res: Response): Promise<unknown> {
				const text = await res.text();
				if (!text) return {};
				try {
					return JSON.parse(text) as unknown;
				} catch {
					return { _raw: text };
				}
			}

			/** 429 = rate limit; free models hit this often. One retry after Retry-After or short backoff. */
			async function parseDimensionsWithOpenRouter(options: {
				apiKey: string;
				model: string;
				pastedText: string;
				imageDataUrls: string[];
				reportStatus?: (msg: string) => void;
				onImagePart?: (detail: {
					index: number;
					total: number;
					part: ReturnType<typeof extractJsonRowsFromAssistantText>;
				}) => void;
			}) {
				let DIMENSION_PARSE_SYSTEM_PROMPT: string;
				let OPENROUTER_CHAT_URL: string;
				try {
					const mod = await import('../lib/dimension-ai-prompt.ts');
					DIMENSION_PARSE_SYSTEM_PROMPT = mod.DIMENSION_PARSE_SYSTEM_PROMPT;
					OPENROUTER_CHAT_URL = mod.OPENROUTER_CHAT_URL;
				} catch {
					throw new Error('AI prompt module failed to load.');
				}

				const { apiKey, model, pastedText, imageDataUrls, reportStatus, onImagePart } = options;
				const trimmed = pastedText?.trim() ?? '';
				const imgs = Array.isArray(imageDataUrls) ? imageDataUrls.filter(Boolean) : [];
				if (!trimmed && imgs.length === 0) {
					throw new Error('Add pasted text and/or an image.');
				}

				type UserPart = { type: string; text?: string; image_url?: { url: string } };

				function userPartsForSingleImage(imageUrl: string): UserPart[] {
					const userParts: UserPart[] = [];
					if (trimmed) {
						userParts.push({
							type: 'text',
							text: `Convert the following into JSON as specified in the system message. Also use the attached image for any dimensions or labels not fully captured in the text.\n\n${trimmed}`
						});
					} else {
						userParts.push({
							type: 'text',
							text: 'Read all room or area labels and metric/imperial dimensions from the attached image. Output JSON as specified in the system message.'
						});
					}
					userParts.push({ type: 'image_url', image_url: { url: imageUrl } });
					return userParts;
				}

				const headers = {
					Authorization: `Bearer ${apiKey}`,
					'Content-Type': 'application/json',
					'HTTP-Referer': typeof window !== 'undefined' ? window.location.origin : '',
					'X-Title': '3-Column Dimension Parser'
				};

				async function completeOneRequest(
					userContent: string | UserPart[]
				): Promise<ReturnType<typeof extractJsonRowsFromAssistantText>> {
					const body = JSON.stringify({
						model,
						temperature: 0.15,
						messages: [
							{ role: 'system', content: DIMENSION_PARSE_SYSTEM_PROMPT },
							{ role: 'user', content: userContent }
						]
					});

					let res = await fetch(OPENROUTER_CHAT_URL, { method: 'POST', headers, body });
					let data = (await parseOpenRouterResponse(res)) as {
						error?: { message?: string };
						choices?: { message?: { content?: string } }[];
					};

					if (res.status === 429) {
						const ra = res.headers.get('Retry-After');
						const sec = Math.min(90, Math.max(4, parseInt(ra || '10', 10) || 10));
						reportStatus?.(`Rate limited (429). Retrying in ${sec}s…`);
						await new Promise((r) => setTimeout(r, sec * 1000));
						res = await fetch(OPENROUTER_CHAT_URL, { method: 'POST', headers, body });
						data = (await parseOpenRouterResponse(res)) as typeof data;
					}

					if (!res.ok) {
						const apiMsg =
							typeof data?.error?.message === 'string'
								? data.error.message
								: typeof (data as { error?: string })?.error === 'string'
									? (data as { error: string }).error
									: '';
						if (res.status === 429) {
							throw new Error(
								`Rate limited (429). Free models have tight quotas on OpenRouter. Wait a few minutes, try again, add credits, or pick a non-free model. ${apiMsg || ''}`.trim()
							);
						}
						throw new Error(apiMsg || `OpenRouter HTTP ${res.status}`);
					}
					const content = data?.choices?.[0]?.message?.content;
					if (!content || typeof content !== 'string') {
						throw new Error('Empty response from model.');
					}
					return extractJsonRowsFromAssistantText(content);
				}

				// Text-only: single request.
				if (imgs.length === 0) {
					const single = await completeOneRequest(
						`Convert the following into JSON as specified in the system message.\n\n${trimmed}`
					);
					return { parts: [single] };
				}

				// One image: single request (caller imports one sheet).
				if (imgs.length === 1) {
					reportStatus?.('Parsing image…');
					const single = await completeOneRequest(userPartsForSingleImage(imgs[0]));
					return { parts: [single] };
				}

				// Multiple images: parallel requests; onImagePart runs as each completes (for progressive tab fill).
				reportStatus?.(`Parsing ${imgs.length} images in parallel…`);
				const parts = await Promise.all(
					imgs.map((url, i) =>
						completeOneRequest(userPartsForSingleImage(url)).then((part) => {
							onImagePart?.({ index: i, total: imgs.length, part });
							return part;
						})
					)
				);
				return { parts };
			}

			function dataUrlToGeminiInlineData(dataUrl: string): { mimeType: string; data: string } {
				const m = dataUrl.match(/^data:([^;]+);base64,(.+)$/);
				if (!m) throw new Error('Invalid image data URL for Gemini.');
				return { mimeType: m[1], data: m[2] };
			}

			async function parseDimensionsWithGemini(options: {
				apiKey: string;
				model: string;
				pastedText: string;
				imageDataUrls: string[];
				reportStatus?: (msg: string) => void;
				onImagePart?: (detail: {
					index: number;
					total: number;
					part: ReturnType<typeof extractJsonRowsFromAssistantText>;
				}) => void;
			}) {
				let DIMENSION_PARSE_SYSTEM_PROMPT: string;
				let GEMINI_API_BASE: string;
				try {
					const mod = await import('../lib/dimension-ai-prompt.ts');
					DIMENSION_PARSE_SYSTEM_PROMPT = mod.DIMENSION_PARSE_SYSTEM_PROMPT;
					GEMINI_API_BASE = mod.GEMINI_API_BASE;
				} catch {
					throw new Error('AI prompt module failed to load.');
				}

				const { apiKey, model, pastedText, imageDataUrls, reportStatus, onImagePart } = options;
				const trimmed = pastedText?.trim() ?? '';
				const imgs = Array.isArray(imageDataUrls) ? imageDataUrls.filter(Boolean) : [];
				if (!trimmed && imgs.length === 0) {
					throw new Error('Add pasted text and/or an image.');
				}

				type GeminiPart = { text?: string; inlineData?: { mimeType: string; data: string } };

				function userPartsForSingleImage(imageUrl: string): GeminiPart[] {
					const userParts: GeminiPart[] = [];
					if (trimmed) {
						userParts.push({
							text: `Convert the following into JSON as specified in the system message. Also use the attached image for any dimensions or labels not fully captured in the text.\n\n${trimmed}`
						});
					} else {
						userParts.push({
							text: 'Read all room or area labels and metric/imperial dimensions from the attached image. Output JSON as specified in the system message.'
						});
					}
					userParts.push({ inlineData: dataUrlToGeminiInlineData(imageUrl) });
					return userParts;
				}

				const endpoint = `${GEMINI_API_BASE}/models/${encodeURIComponent(model)}:generateContent?key=${encodeURIComponent(apiKey)}`;

				async function completeOneRequest(
					userContent: string | GeminiPart[]
				): Promise<ReturnType<typeof extractJsonRowsFromAssistantText>> {
					const parts = typeof userContent === 'string' ? [{ text: userContent }] : userContent;
					const body = JSON.stringify({
						systemInstruction: { parts: [{ text: DIMENSION_PARSE_SYSTEM_PROMPT }] },
						contents: [{ role: 'user', parts }],
						generationConfig: { temperature: 0.15 }
					});

					let res = await fetch(endpoint, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body
					});
					let data = (await parseOpenRouterResponse(res)) as {
						error?: { message?: string; status?: string };
						candidates?: { content?: { parts?: { text?: string }[] } }[];
					};

					if (res.status === 429) {
						const ra = res.headers.get('Retry-After');
						const sec = Math.min(90, Math.max(4, parseInt(ra || '10', 10) || 10));
						reportStatus?.(`Rate limited (429). Retrying in ${sec}s…`);
						await new Promise((r) => setTimeout(r, sec * 1000));
						res = await fetch(endpoint, {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body
						});
						data = (await parseOpenRouterResponse(res)) as typeof data;
					}

					if (!res.ok) {
						const apiMsg =
							typeof data?.error?.message === 'string'
								? data.error.message
								: typeof (data as { error?: string })?.error === 'string'
									? (data as { error: string }).error
									: '';
						if (res.status === 429) {
							throw new Error(
								`Rate limited (429). Wait a few minutes or try another model. ${apiMsg || ''}`.trim()
							);
						}
						throw new Error(apiMsg || `Gemini HTTP ${res.status}`);
					}

					const contentParts = data?.candidates?.[0]?.content?.parts ?? [];
					const content = contentParts
						.map((p) => (typeof p?.text === 'string' ? p.text : ''))
						.filter(Boolean)
						.join('');
					if (!content) {
						throw new Error('Empty response from Gemini model.');
					}
					return extractJsonRowsFromAssistantText(content);
				}

				if (imgs.length === 0) {
					const single = await completeOneRequest(
						`Convert the following into JSON as specified in the system message.\n\n${trimmed}`
					);
					return { parts: [single] };
				}

				if (imgs.length === 1) {
					reportStatus?.('Parsing image…');
					const single = await completeOneRequest(userPartsForSingleImage(imgs[0]));
					return { parts: [single] };
				}

				reportStatus?.(`Parsing ${imgs.length} images in parallel…`);
				const parts = await Promise.all(
					imgs.map((url, i) =>
						completeOneRequest(userPartsForSingleImage(url)).then((part) => {
							onImagePart?.({ index: i, total: imgs.length, part });
							return part;
						})
					)
				);
				return { parts };
			}

			tbody.innerHTML = '';
			const loaded = loadState();
			sheets = loaded.sheets;
			activeIndex = loaded.activeIndex;
			replaceEditorRows(sheets[activeIndex].rows);
			renderTabBar();
			isHydrating = false;
			renderPreview();
			scrollActiveTabIntoView();

			document.addEventListener('dragover', (e) => {
				e.preventDefault();
			});
			document.addEventListener('drop', (e) => {
				e.preventDefault();
				const dt = e.dataTransfer?.files;
				if (dt?.length) void importDataFiles(dt);
			});

			fileInput.addEventListener('change', () => {
				const files = fileInput.files;
				if (!files?.length) return;
				void importDataFiles(files).finally(() => {
					fileInput.value = '';
				});
			});

			addRowBtn.addEventListener('click', () => addRow());

			// Row drag-and-drop reordering
			let draggedTr: HTMLTableRowElement | null = null;

			function clearRowDropIndicators() {
				tbody.querySelectorAll('tr.drop-above, tr.drop-below').forEach((el) => {
					el.classList.remove('drop-above', 'drop-below');
				});
			}

			function bindRowDrag(tr: HTMLTableRowElement) {
				const handle = tr.querySelector('.row-drag-handle') as HTMLElement | null;
				if (!handle) return;
				// Only enable draggable=true while user is pressing the handle, so clicks inside
				// inputs don't accidentally initiate a row drag.
				const armDrag = () => {
					tr.setAttribute('draggable', 'true');
				};
				const disarmDrag = () => {
					tr.removeAttribute('draggable');
				};
				handle.addEventListener('mousedown', armDrag);
				handle.addEventListener('touchstart', armDrag, { passive: true });
				handle.addEventListener('mouseup', disarmDrag);
				handle.addEventListener('mouseleave', disarmDrag);

				tr.addEventListener('dragstart', (e) => {
					if (!tr.hasAttribute('draggable')) {
						e.preventDefault();
						return;
					}
					draggedTr = tr;
					if (e.dataTransfer) {
						e.dataTransfer.effectAllowed = 'move';
						// Required for Firefox to initiate drag.
						try { e.dataTransfer.setData('text/plain', 'row'); } catch {}
					}
					requestAnimationFrame(() => tr.classList.add('opacity-40'));
				});
				tr.addEventListener('dragend', () => {
					tr.removeAttribute('draggable');
					tr.classList.remove('opacity-40');
					clearRowDropIndicators();
					draggedTr = null;
				});
			}

			tbody.addEventListener('dragover', (e) => {
				if (!draggedTr) return;
				e.preventDefault();
				if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';
				const target = e.target as HTMLElement;
				const overTr = target.closest('tr') as HTMLTableRowElement | null;
				clearRowDropIndicators();
				if (!overTr || overTr === draggedTr || overTr.parentElement !== tbody) return;
				const rect = overTr.getBoundingClientRect();
				const mid = rect.top + rect.height / 2;
				overTr.classList.add(e.clientY < mid ? 'drop-above' : 'drop-below');
			});

			tbody.addEventListener('dragleave', (e) => {
				const to = e.relatedTarget as Node | null;
				if (to && tbody.contains(to)) return;
				clearRowDropIndicators();
			});

			tbody.addEventListener('drop', (e) => {
				if (!draggedTr) return;
				e.preventDefault();
				const target = e.target as HTMLElement;
				const overTr = target.closest('tr') as HTMLTableRowElement | null;
				clearRowDropIndicators();
				if (!overTr || overTr === draggedTr || overTr.parentElement !== tbody) return;
				const rect = overTr.getBoundingClientRect();
				const mid = rect.top + rect.height / 2;
				if (e.clientY < mid) tbody.insertBefore(draggedTr, overTr);
				else tbody.insertBefore(draggedTr, overTr.nextSibling);
				renderPreview();
				commitActiveSheet();
				persistState();
			});

			// --- Per-cell drag-to-swap (custom mouse-driven, NOT HTML5 drag-and-drop) --
			// HTML5 drag-and-drop on small handles inside form inputs proved unreliable
			// (no visible drag image, dragend not always firing, drops swallowed by the
			// native input's text-drop handler). Custom mouse events sidestep all of that.
			type CellDragState = {
				sourceWrap: HTMLElement;
				sourceInput: HTMLInputElement;
				ghost: HTMLElement;
				currentTarget: HTMLElement | null;
				armedAtX: number;
				armedAtY: number;
				started: boolean;
			};
			let cellDrag: CellDragState | null = null;
			const CELL_DRAG_THRESHOLD = 4; // px before we commit to a drag

			function buildCellDragGhost(value: string): HTMLElement {
				const ghost = document.createElement('div');
				ghost.textContent = value && value.length ? value : '(empty)';
				ghost.style.cssText = [
					'position:fixed', 'top:0', 'left:0',
					'padding:6px 12px', 'border-radius:8px',
					'background:#8b5cf6', 'color:#ffffff',
					'font-family:system-ui,-apple-system,sans-serif',
					'font-size:13px', 'font-weight:500',
					'box-shadow:0 8px 20px rgba(0,0,0,0.25)',
					'white-space:nowrap', 'max-width:280px',
					'overflow:hidden', 'text-overflow:ellipsis',
					'pointer-events:none', 'z-index:99999',
					'transform:translate(-9999px,-9999px)',
					'transition:none', 'opacity:0.95'
				].join(';');
				document.body.appendChild(ghost);
				return ghost;
			}

			function clearCellDragVisuals() {
				document.querySelectorAll('.cell-wrap.cell-source-dragging').forEach((el) => {
					el.classList.remove('cell-source-dragging');
				});
				document.querySelectorAll('.cell-wrap.cell-drop-target').forEach((el) => {
					el.classList.remove('cell-drop-target');
				});
			}

			function endCellDrag(performSwap: boolean, e?: MouseEvent) {
				if (!cellDrag) return;
				const state = cellDrag;
				cellDrag = null;

				let target: HTMLElement | null = null;
				if (e && state.started) {
					state.ghost.style.display = 'none';
					const elUnder = document.elementFromPoint(e.clientX, e.clientY) as HTMLElement | null;
					target = elUnder?.closest('.cell-wrap') as HTMLElement | null;
				}

				state.ghost.remove();
				clearCellDragVisuals();
				document.body.style.userSelect = '';
				document.body.style.cursor = '';
				document.removeEventListener('mousemove', onCellDragMove, true);
				document.removeEventListener('mouseup', onCellDragUp, true);
				document.removeEventListener('keydown', onCellDragKey, true);

				if (!performSwap || !state.started) return;
				if (!target || target === state.sourceWrap || !target.classList.contains('cell-wrap')) return;
				const targetInput = target.querySelector('.cell-input') as HTMLInputElement | null;
				if (!targetInput) return;

				const srcVal = state.sourceInput.value;
				const tgtVal = targetInput.value;
				// Use the chip-aware setter so the visible chip-inputs rebuild from the new value.
				const sourceChipCell = state.sourceWrap.querySelector<HTMLElement>('.chip-cell');
				const targetChipCell = target.querySelector<HTMLElement>('.chip-cell');
				if (sourceChipCell) {
					setChipsFromCombined(sourceChipCell, state.sourceInput, tgtVal);
				} else {
					state.sourceInput.value = tgtVal;
					state.sourceInput.dispatchEvent(new Event('input', { bubbles: true }));
				}
				if (targetChipCell) {
					setChipsFromCombined(targetChipCell, targetInput, srcVal);
				} else {
					targetInput.value = srcVal;
					targetInput.dispatchEvent(new Event('input', { bubbles: true }));
				}
				commitActiveSheet();
				persistState();
			}

			function onCellDragMove(e: MouseEvent) {
				if (!cellDrag) return;
				e.preventDefault();
				const dx = e.clientX - cellDrag.armedAtX;
				const dy = e.clientY - cellDrag.armedAtY;
				if (!cellDrag.started) {
					if (dx * dx + dy * dy < CELL_DRAG_THRESHOLD * CELL_DRAG_THRESHOLD) return;
					cellDrag.started = true;
					cellDrag.sourceWrap.classList.add('cell-source-dragging');
					document.body.style.userSelect = 'none';
					document.body.style.cursor = 'grabbing';
				}

				cellDrag.ghost.style.transform = `translate(${e.clientX + 12}px,${e.clientY + 8}px)`;

				// Find cell under cursor (hide ghost so elementFromPoint sees through it)
				cellDrag.ghost.style.visibility = 'hidden';
				const elUnder = document.elementFromPoint(e.clientX, e.clientY) as HTMLElement | null;
				cellDrag.ghost.style.visibility = '';
				const overWrap = elUnder?.closest('.cell-wrap') as HTMLElement | null;

				if (cellDrag.currentTarget !== overWrap) {
					if (cellDrag.currentTarget) {
						cellDrag.currentTarget.classList.remove('cell-drop-target');
					}
					if (overWrap && overWrap !== cellDrag.sourceWrap) {
						overWrap.classList.add('cell-drop-target');
						cellDrag.currentTarget = overWrap;
					} else {
						cellDrag.currentTarget = null;
					}
				}
			}

			function onCellDragUp(e: MouseEvent) {
				e.preventDefault();
				endCellDrag(true, e);
			}

			function onCellDragKey(e: KeyboardEvent) {
				if (e.key === 'Escape') {
					e.preventDefault();
					endCellDrag(false);
				}
			}

			function bindCellSwapDrag(wrap: HTMLElement) {
				if (wrap.dataset.cellDragBound === '1') return;
				const handle = wrap.querySelector('.cell-drag-handle') as HTMLElement | null;
				const input = wrap.querySelector('.cell-input') as HTMLInputElement | null;
				if (!handle || !input) return;
				wrap.dataset.cellDragBound = '1';

				// Defensive: nothing in our markup should be HTML5-draggable for this feature.
				handle.removeAttribute('draggable');
				wrap.removeAttribute('draggable');

				handle.addEventListener('mousedown', (e) => {
					if (e.button !== 0) return; // left button only
					if (cellDrag) endCellDrag(false);
					e.preventDefault();
					e.stopPropagation();

					cellDrag = {
						sourceWrap: wrap,
						sourceInput: input,
						ghost: buildCellDragGhost(input.value),
						currentTarget: null,
						armedAtX: e.clientX,
						armedAtY: e.clientY,
						started: false
					};
					// Park ghost at cursor immediately (transform applied on first move)
					cellDrag.ghost.style.transform = `translate(${e.clientX + 12}px,${e.clientY + 8}px)`;

					document.addEventListener('mousemove', onCellDragMove, true);
					document.addEventListener('mouseup', onCellDragUp, true);
					document.addEventListener('keydown', onCellDragKey, true);
				});
			}

			// Bind the static initial row's cell handles. addRow() also binds dynamically.
			tbody.querySelectorAll('.cell-wrap').forEach((wrap) => {
				bindCellSwapDrag(wrap as HTMLElement);
			});

			// Window-level safety: if anything weird happens (window blur, etc.), clean up.
			window.addEventListener('blur', () => endCellDrag(false));

			// Per-chip focusout normalization is wired in bindChipInputEvents — no tbody-level
			// handler is needed.

			importPasteBtn.addEventListener('click', () => {
				const text = (csvPaste.value ?? '').trim();
				if (!text) return;
				importPastedCsv(text);
				csvPaste.value = '';
			});

			const OPENROUTER_KEY_FROM_ENV =
				typeof import.meta.env.PUBLIC_OPENROUTER_API_KEY === 'string'
					? import.meta.env.PUBLIC_OPENROUTER_API_KEY.trim()
					: '';
			const GEMINI_KEY_FROM_ENV =
				typeof import.meta.env.PUBLIC_GEMINI_API_KEY === 'string'
					? import.meta.env.PUBLIC_GEMINI_API_KEY.trim()
					: '';

			const aiApiKeyOpenRouter = document.getElementById('ai-api-key-openrouter') as HTMLInputElement | null;
			const aiApiKeyGemini = document.getElementById('ai-api-key-gemini') as HTMLInputElement | null;
			const aiKeyLabelOpenRouter = document.getElementById('ai-key-label-openrouter') as HTMLLabelElement | null;
			const aiKeyLabelGemini = document.getElementById('ai-key-label-gemini') as HTMLLabelElement | null;
			const aiProviderSwitch = document.getElementById('ai-provider-switch') as HTMLButtonElement | null;
			const aiProviderSwitchKnob = document.getElementById('ai-provider-switch-knob') as HTMLSpanElement | null;
			const aiProviderLabelOpenRouter = document.getElementById('ai-provider-label-openrouter') as HTMLSpanElement | null;
			const aiProviderLabelGemini = document.getElementById('ai-provider-label-gemini') as HTMLSpanElement | null;
			const aiRememberKey = document.getElementById('ai-remember-key') as HTMLInputElement | null;
			const aiModelSelect = document.getElementById('ai-model-select') as HTMLSelectElement | null;
			const aiModelCustomWrap = document.getElementById('ai-model-custom-wrap') as HTMLDivElement | null;
			const aiModelCustom = document.getElementById('ai-model-custom') as HTMLInputElement | null;
			const aiImageInput = document.getElementById('ai-image-input') as HTMLInputElement | null;
			const aiAttachBtn = document.getElementById('ai-attach-btn') as HTMLButtonElement | null;
			const aiAttachmentChips = document.getElementById('ai-attachment-chips') as HTMLDivElement | null;
			const pasteComposer = document.getElementById('paste-composer') as HTMLDivElement | null;
			const csvParseAiBtn = document.getElementById('csv-parse-ai-btn') as HTMLButtonElement | null;
			const aiStatus = document.getElementById('ai-status') as HTMLSpanElement | null;
			const aiCopyPrompt = document.getElementById('ai-copy-prompt') as HTMLButtonElement | null;
			const aiOptionsTrigger = document.getElementById('ai-options-trigger') as HTMLButtonElement | null;
			const aiOptionsPanel = document.getElementById('ai-options-panel') as HTMLDivElement | null;
			const manualKeyRow = document.getElementById('ai-manual-key-row') as HTMLDivElement | null;

			function isGeminiProvider(): boolean {
				return aiProviderSwitch?.getAttribute('aria-checked') === 'true';
			}

			function getEffectiveApiKey(): string {
				if (isGeminiProvider()) {
					if (GEMINI_KEY_FROM_ENV) return GEMINI_KEY_FROM_ENV;
					return (aiApiKeyGemini?.value ?? '').trim();
				}
				if (OPENROUTER_KEY_FROM_ENV) return OPENROUTER_KEY_FROM_ENV;
				return (aiApiKeyOpenRouter?.value ?? '').trim();
			}

			function updateManualKeyRowVisibility() {
				const gemini = isGeminiProvider();
				const envKey = gemini ? GEMINI_KEY_FROM_ENV : OPENROUTER_KEY_FROM_ENV;
				if (envKey) manualKeyRow?.classList.add('hidden');
				else manualKeyRow?.classList.remove('hidden');
				aiKeyLabelOpenRouter?.classList.toggle('hidden', gemini);
				aiKeyLabelGemini?.classList.toggle('hidden', !gemini);
				aiProviderLabelOpenRouter?.classList.toggle('text-neutral-600', !gemini);
				aiProviderLabelOpenRouter?.classList.toggle('text-neutral-400', gemini);
				aiProviderLabelGemini?.classList.toggle('text-neutral-600', gemini);
				aiProviderLabelGemini?.classList.toggle('text-neutral-400', !gemini);
			}

			function populateModelSelectForProvider(gemini: boolean, preferredModel?: string) {
				if (!aiModelSelect) return;
				const models = gemini ? DEFAULT_GEMINI_MODELS : DEFAULT_OPENROUTER_MODELS;
				const prev = preferredModel ?? aiModelSelect.value;
				aiModelSelect.innerHTML = '';
				for (const m of models) {
					const opt = document.createElement('option');
					opt.value = m.id;
					opt.textContent = m.label;
					aiModelSelect.appendChild(opt);
				}
				const custom = document.createElement('option');
				custom.value = '__custom';
				custom.textContent = 'Custom…';
				aiModelSelect.appendChild(custom);
				const match = Array.from(aiModelSelect.options).find((o) => o.value === prev);
				if (match) {
					aiModelSelect.value = prev;
					aiModelCustomWrap?.classList.toggle('hidden', prev !== '__custom');
				} else if (prev && prev !== '__custom') {
					aiModelSelect.value = '__custom';
					if (aiModelCustom) aiModelCustom.value = prev;
					aiModelCustomWrap?.classList.remove('hidden');
				} else {
					aiModelSelect.selectedIndex = 0;
					aiModelCustomWrap?.classList.add('hidden');
				}
			}

			function setAiProvider(gemini: boolean, opts?: { persist?: boolean }) {
				const persist = opts?.persist !== false;
				aiProviderSwitch?.setAttribute('aria-checked', gemini ? 'true' : 'false');
				aiProviderSwitch?.setAttribute('data-on', gemini ? 'true' : 'false');
				aiProviderSwitchKnob?.setAttribute('data-on', gemini ? 'true' : 'false');
				let savedModel: string | null = null;
				try {
					savedModel = localStorage.getItem(gemini ? STORAGE_GEMINI_MODEL : STORAGE_OPENROUTER_MODEL);
				} catch {
					// ignore
				}
				populateModelSelectForProvider(gemini, savedModel ?? undefined);
				updateManualKeyRowVisibility();
				if (persist) {
					try {
						localStorage.setItem(STORAGE_AI_PROVIDER, gemini ? 'gemini' : 'openrouter');
					} catch {
						// ignore
					}
				}
			}

			updateManualKeyRowVisibility();

			function positionAiOptionsPanel() {
				const trigger = aiOptionsTrigger;
				const panel = aiOptionsPanel;
				if (!trigger || !panel || panel.classList.contains('hidden')) return;
				const r = trigger.getBoundingClientRect();
				const maxW = Math.min(352, window.innerWidth - 16);
				const left = Math.max(8, Math.min(r.right - maxW, window.innerWidth - maxW - 8));
				panel.style.setProperty('left', `${left}px`);
				panel.style.setProperty('width', `${maxW}px`);
				panel.style.setProperty('top', `${r.bottom + 6}px`);
				requestAnimationFrame(() => {
					const ph = panel.getBoundingClientRect().height;
					let top = r.bottom + 6;
					if (top + ph > window.innerHeight - 8) {
						top = Math.max(8, r.top - ph - 6);
					}
					panel.style.setProperty('top', `${top}px`);
				});
			}

			function setAiOptionsOpen(open: boolean) {
				if (!aiOptionsPanel || !aiOptionsTrigger) return;
				aiOptionsPanel.classList.toggle('hidden', !open);
				aiOptionsTrigger.setAttribute('aria-expanded', open ? 'true' : 'false');
				if (open) {
					requestAnimationFrame(() => {
						positionAiOptionsPanel();
					});
				}
			}

			aiOptionsTrigger?.addEventListener('click', (e) => {
				e.stopPropagation();
				const panelClosed = aiOptionsPanel?.classList.contains('hidden') ?? true;
				setAiOptionsOpen(panelClosed);
			});

			window.addEventListener('resize', () => {
				if (aiOptionsPanel && !aiOptionsPanel.classList.contains('hidden')) positionAiOptionsPanel();
			});
			window.addEventListener(
				'scroll',
				() => {
					if (aiOptionsPanel && !aiOptionsPanel.classList.contains('hidden')) positionAiOptionsPanel();
				},
				true
			);

			document.addEventListener('mousedown', (e) => {
				const t = e.target as Node;
				if (aiOptionsPanel?.classList.contains('hidden')) return;
				if (aiOptionsTrigger?.contains(t) || aiOptionsPanel?.contains(t)) return;
				setAiOptionsOpen(false);
			});

			try {
				const savedOpenRouterKey = localStorage.getItem(STORAGE_OPENROUTER_KEY);
				if (savedOpenRouterKey && aiApiKeyOpenRouter && !OPENROUTER_KEY_FROM_ENV) {
					aiApiKeyOpenRouter.value = savedOpenRouterKey;
				}
				const savedGeminiKey = localStorage.getItem(STORAGE_GEMINI_KEY);
				if (savedGeminiKey && aiApiKeyGemini && !GEMINI_KEY_FROM_ENV) {
					aiApiKeyGemini.value = savedGeminiKey;
				}
				const savedProvider = localStorage.getItem(STORAGE_AI_PROVIDER);
				setAiProvider(savedProvider === 'gemini', { persist: false });
			} catch {
				// ignore
			}

			aiProviderSwitch?.addEventListener('click', () => {
				setAiProvider(!isGeminiProvider());
			});

			aiModelSelect?.addEventListener('change', () => {
				const v = aiModelSelect?.value;
				if (v === '__custom') aiModelCustomWrap?.classList.remove('hidden');
				else aiModelCustomWrap?.classList.add('hidden');
			});

			aiCopyPrompt?.addEventListener('click', async () => {
				try {
					const { DIMENSION_PARSE_SYSTEM_PROMPT } = await import('../lib/dimension-ai-prompt.ts');
					await navigator.clipboard.writeText(DIMENSION_PARSE_SYSTEM_PROMPT);
					aiCopyPrompt.textContent = 'Copied';
					setTimeout(() => {
						aiCopyPrompt.textContent = 'Copy prompt';
					}, 1500);
				} catch {
					aiCopyPrompt.textContent = 'Copy failed';
				}
			});

			function readFileAsDataUrl(file: File): Promise<string> {
				return new Promise((resolve, reject) => {
					const r = new FileReader();
					r.onload = () => resolve(String(r.result));
					r.onerror = () => reject(r.error ?? new Error('read failed'));
					r.readAsDataURL(file);
				});
			}

			/** @type {{ id: string; name: string; dataUrl: string }[]} */
			let aiAttachments = [];

			function renderAiAttachmentChips() {
				const wrap = aiAttachmentChips;
				if (!wrap) return;
				wrap.innerHTML = '';
				if (aiAttachments.length === 0) {
					wrap.classList.add('hidden');
					return;
				}
				wrap.classList.remove('hidden');
				for (const att of aiAttachments) {
					const chip = document.createElement('div');
					chip.className =
						'inline-flex items-center gap-2 pl-1.5 pr-1 py-1 rounded-full bg-violet-100 border border-violet-200/90 text-xs text-violet-950 shadow-sm max-w-full';
					chip.dataset.attachmentId = att.id;
					const thumb = document.createElement('img');
					thumb.src = att.dataUrl;
					thumb.alt = '';
					thumb.className = 'w-8 h-8 rounded-md object-cover shrink-0 border border-white shadow-sm';
					const nameEl = document.createElement('span');
					nameEl.className = 'truncate max-w-[min(100%,200px)] font-medium';
					nameEl.textContent = att.name;
					const rm = document.createElement('button');
					rm.type = 'button';
					rm.className =
						'shrink-0 flex h-6 w-6 items-center justify-center rounded-full text-violet-700 hover:bg-violet-200/90 text-base leading-none';
					rm.setAttribute('aria-label', `Remove ${att.name}`);
					rm.textContent = '×';
					rm.addEventListener('click', () => {
						aiAttachments = aiAttachments.filter((x) => x.id !== att.id);
						renderAiAttachmentChips();
					});
					chip.appendChild(thumb);
					chip.appendChild(nameEl);
					chip.appendChild(rm);
					wrap.appendChild(chip);
				}
			}

			// OpenRouter vision models reliably accept these; HEIC/AVIF/BMP/TIFF/SVG are frequently rejected.
			const ACCEPTED_IMAGE_MIME_TYPES = new Set([
				'image/png',
				'image/jpeg',
				'image/jpg',
				'image/webp',
				'image/gif'
			]);
			const ACCEPTED_IMAGE_EXTENSIONS = ['png', 'jpg', 'jpeg', 'webp', 'gif'];

			function describeFileFormat(f: File): string {
				const ext = (f.name.split('.').pop() ?? '').toLowerCase();
				if (f.type) return f.type + (ext ? ` (.${ext})` : '');
				return ext ? `.${ext}` : 'unknown';
			}

			function isAcceptedImage(f: File): boolean {
				const mime = (f.type || '').toLowerCase();
				if (ACCEPTED_IMAGE_MIME_TYPES.has(mime)) return true;
				if (!mime && f.name) {
					const ext = (f.name.split('.').pop() ?? '').toLowerCase();
					return ACCEPTED_IMAGE_EXTENSIONS.includes(ext);
				}
				return false;
			}

			function reportImageFormatIssue(rejected: File[], nonImages: File[]) {
				if (!aiStatus) return;
				if (!rejected.length && !nonImages.length) return;
				const parts: string[] = [];
				if (rejected.length) {
					const list = rejected.map((f) => `${f.name} [${describeFileFormat(f)}]`).join(', ');
					parts.push(
						`Unsupported image format — vision models here accept PNG, JPEG, WebP, GIF. Rejected: ${list}`
					);
				}
				if (nonImages.length) {
					const list = nonImages.map((f) => `${f.name} [${describeFileFormat(f)}]`).join(', ');
					parts.push(`Not an image file: ${list}`);
				}
				const msg = parts.join(' · ');
				aiStatus.textContent = msg;
				// Dev: full details (raw MIME/extension) for debugging which formats slipped through.
				console.warn('[three-column] Image format check failed', {
					rejected: rejected.map((f) => ({ name: f.name, type: f.type, size: f.size })),
					nonImages: nonImages.map((f) => ({ name: f.name, type: f.type, size: f.size }))
				});
			}

			async function addAiImagesFromFileList(files: FileList | File[] | null | undefined) {
				if (!files?.length) return;
				const all = Array.from(files);
				const nonImages = all.filter((f) => !f.type.startsWith('image/') && !isAcceptedImage(f));
				const imageLike = all.filter((f) => f.type.startsWith('image/') || isAcceptedImage(f));
				const accepted = imageLike.filter(isAcceptedImage);
				const rejected = imageLike.filter((f) => !isAcceptedImage(f));

				for (const f of accepted) {
					try {
						aiAttachments.push({
							id: uid(),
							name: f.name,
							dataUrl: await readFileAsDataUrl(f)
						});
					} catch (e) {
						if (aiStatus) {
							aiStatus.textContent = `Could not read ${f.name}. See console for details.`;
						}
						console.error('[three-column] Failed to read image', f.name, e);
					}
				}
				renderAiAttachmentChips();
				if (rejected.length || nonImages.length) reportImageFormatIssue(rejected, nonImages);
			}

			aiAttachBtn?.addEventListener('click', () => aiImageInput?.click());

			aiImageInput?.addEventListener('change', async () => {
				await addAiImagesFromFileList(aiImageInput.files);
				aiImageInput.value = '';
			});

			function wireImageDropZone(el: HTMLElement | null) {
				if (!el) return;
				el.addEventListener('dragover', (e) => {
					if ([...(e.dataTransfer?.types ?? [])].includes('Files')) {
						e.preventDefault();
						e.dataTransfer!.dropEffect = 'copy';
					}
				});
				el.addEventListener('drop', (e) => {
					const fl = e.dataTransfer?.files;
					if (!fl?.length) return;
					const all = Array.from(fl);
					const hasTabularImport = all.some((f) => isCsvFile(f) || isSvgFile(f));
					if (hasTabularImport) return; // let page-level CSV/SVG drop handler take this
					e.preventDefault();
					e.stopPropagation();
					void addAiImagesFromFileList(all);
				});
			}

			function clipboardImageFilesFromPaste(e: ClipboardEvent): File[] {
				const cd = e.clipboardData;
				if (!cd) return [];
				const out: File[] = [];
				const items = cd.items;
				if (items) {
					for (let i = 0; i < items.length; i++) {
						const it = items[i];
						if (it.kind === 'file' && it.type.startsWith('image/')) {
							const f = it.getAsFile();
							if (f) out.push(f);
						}
					}
				}
				if (out.length === 0 && cd.files?.length) {
					for (const f of Array.from(cd.files)) {
						if (f.type.startsWith('image/')) out.push(f);
					}
				}
				return out;
			}

			csvPaste?.addEventListener('paste', (e) => {
				const imgs = clipboardImageFilesFromPaste(e);
				if (!imgs.length) return;
				e.preventDefault();
				const text = e.clipboardData?.getData('text/plain') ?? '';
				if (text && csvPaste) {
					const start = csvPaste.selectionStart ?? 0;
					const end = csvPaste.selectionEnd ?? 0;
					const v = csvPaste.value;
					csvPaste.value = v.slice(0, start) + text + v.slice(end);
					const pos = start + text.length;
					csvPaste.setSelectionRange(pos, pos);
				}
				void addAiImagesFromFileList(imgs);
			});

