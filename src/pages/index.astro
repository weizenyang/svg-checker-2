---
const tools = [
	{
		href: "/refactored",
		title: "Floorplan CSV Editor",
		desc: "Edit and validate floorplan dimension CSVs over a backplate.",
		img: "/images/refactored.webp",
	},
	{
		href: "/three-column",
		title: "3-Column Dimensions",
		desc: "Metric + imperial dimension tables with PNG / CSV export.",
		icon: "table",
	},
	{
		href: "/roomscale-4",
		title: "3D Collision Mesh Viewer",
		desc: "Inspect roomscale collision meshes in 3D.",
		img: "/images/roomscale-4.webp",
	},
	{
		href: "/new-project",
		title: "JSON Generator",
		desc: "Create and edit project JSON.",
		icon: "doc",
	},
	{
		href: "/inpainting-king",
		title: "Inpainting King",
		desc: "Mask and inpaint images.",
		img: "/images/inpainting-king.jpg",
	},
	{
		href: "/equirectangular-editor",
		title: "Equirectangular Editor",
		desc: "Edit 360° equirectangular panoramas.",
		img: "/images/equirectangular-editor.webp",
	},
	{
		href: "/dxf-viewer",
		title: "DXF Viewer & Dimensioning",
		desc: "View DXF drawings and add dimensions.",
		icon: "ruler",
	},
];
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Tools</title>
	</head>
	<body class="bg-neutral-100 min-h-screen text-neutral-900 antialiased">
		<main class="mx-auto max-w-6xl px-6 py-12 md:py-16">
			<header class="mb-10">
				<h1 class="text-3xl font-bold tracking-tight">Tools</h1>
				<p class="mt-2 text-neutral-500">
					Floorplan, dimensioning &amp; image utilities — pick one to get started.
				</p>
			</header>

			<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
				{tools.map((tool) => (
					<a
						href={tool.href}
						class="group flex flex-col overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-sm transition duration-200 hover:-translate-y-0.5 hover:border-neutral-300 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400"
					>
						{tool.img ? (
							<div class="aspect-[16/10] overflow-hidden bg-neutral-50">
								<img
									src={tool.img}
									alt={tool.title}
									loading="lazy"
									decoding="async"
									class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
								/>
							</div>
						) : (
							<div class="flex aspect-[16/10] items-center justify-center bg-neutral-50 text-neutral-400 transition-colors group-hover:text-neutral-500">
								{tool.icon === "table" && (
									<svg class="h-14 w-14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
										<rect x="3" y="4" width="18" height="16" rx="2" />
										<path d="M9 4v16M15 4v16M3 9h18M3 14.5h18" stroke-linecap="round" />
									</svg>
								)}
								{tool.icon === "doc" && (
									<svg class="h-14 w-14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
										<path d="M14 3v4a1 1 0 0 0 1 1h4" stroke-linecap="round" stroke-linejoin="round" />
										<path d="M5 3h9l5 5v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z" stroke-linecap="round" stroke-linejoin="round" />
										<path d="M9 13h6M9 16.5h4" stroke-linecap="round" />
									</svg>
								)}
								{tool.icon === "ruler" && (
									<svg class="h-14 w-14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
										<rect x="2.5" y="8" width="19" height="8" rx="1.5" />
										<path d="M6.5 8v3M10 8v4M13.5 8v3M17 8v4" stroke-linecap="round" />
									</svg>
								)}
							</div>
						)}

						<div class="flex flex-1 flex-col p-4">
							<h2 class="font-semibold leading-snug">{tool.title}</h2>
							<p class="mt-1 text-sm text-neutral-500">{tool.desc}</p>
						</div>
					</a>
				))}
			</div>
		</main>
	</body>
</html>
