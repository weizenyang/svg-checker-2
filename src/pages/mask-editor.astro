---
import "../styles.css";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Image and SVG Viewer</title>
		<style>
			.rect-selected {
				stroke: #007bff !important;
				stroke-width: 2 !important;
				stroke-dasharray: 5,5 !important;
			}
			
			.transform-handle {
				fill: white !important;
				stroke: #666 !important;
				stroke-width: 2 !important;
				cursor: pointer;
				opacity: 0.9;
			}
			
			.transform-handle:hover {
				opacity: 1;
				fill: #f8f8f8 !important;
				stroke: #333 !important;
			}
			
			.transform-handle.nw-resize { cursor: nw-resize; }
			.transform-handle.ne-resize { cursor: ne-resize; }
			.transform-handle.sw-resize { cursor: sw-resize; }
			.transform-handle.se-resize { cursor: se-resize; }
			
			.transform-group {
				pointer-events: none;
			}
			
			.transform-handle {
				pointer-events: all;
			}
			
			/* Prevent SVG dragging and selection - AGGRESSIVE */
			svg {
				-webkit-user-select: none !important;
				-moz-user-select: none !important;
				-ms-user-select: none !important;
				user-select: none !important;
				-webkit-user-drag: none !important;
				-khtml-user-drag: none !important;
				-moz-user-drag: none !important;
				-o-user-drag: none !important;
				user-drag: none !important;
				-webkit-touch-callout: none !important;
				-webkit-tap-highlight-color: transparent !important;
				pointer-events: auto !important;
			}
			
			svg * {
				-webkit-user-select: none !important;
				-moz-user-select: none !important;
				-ms-user-select: none !important;
				user-select: none !important;
				-webkit-user-drag: none !important;
				-khtml-user-drag: none !important;
				-moz-user-drag: none !important;
				-o-user-drag: none !important;
				user-drag: none !important;
				-webkit-touch-callout: none !important;
			}
			
			/* Specifically target rect elements */
			rect {
				-webkit-user-drag: none !important;
				user-drag: none !important;
				-webkit-user-select: none !important;
				user-select: none !important;
			}
			
			/* Toolset section styling */
			.toolsets {
				position: relative;
				z-index: 1000 !important; /* Above the viewer */
			}
			
			.toolset-section {
				background: transparent !important;
				pointer-events: none; /* Make the container transparent to interactions */
			}
			
			.toolset-section > * {
				pointer-events: auto; /* But allow interactions with the modules inside */
			}
			
			/* Ensure container sections have proper styling */
			.container {
				background: rgba(255, 255, 255, 0.95) !important;
				backdrop-filter: blur(8px);
				border: 1px solid rgba(0, 0, 0, 0.1);
				border-radius: 6px;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
			}
			
			/* Canvas background styling */
			#scalable-canvas {
				background-color: #808080; /* Grey background */
			}
			
		#svg-container {
			background-color: #808080; /* Grey background */
		}

		#svg-container > svg {
			position: relative;
			z-index: 1;
		}

		#interaction-plane {
			fill: transparent;
			stroke: none;
			pointer-events: all;
		}

		#mask-rects rect {
			fill: rgba(0, 123, 255, 0.35) !important;
			stroke: #007bff !important;
			stroke-width: 2px !important;
			pointer-events: all !important;
			cursor: pointer;
		}

		/* Embedded floorplan raster inside combined bundle SVGs */
		#floorplan-raster {
			pointer-events: none;
		}

		/* Floorplan dimension reference layer (dims-only SVG imports) */
		#dims-reference {
			pointer-events: none;
		}
		#dims-reference .dim-line,
		#dims-reference .dim-ext,
		#dims-reference line {
			stroke: #ffffff;
		}
		#dims-reference .dim-text,
		#dims-reference text {
			fill: #ffffff;
		}
		
		/* Snap guides styling */
		.snap-guide {
			stroke: #ff0066 !important;
			stroke-width: 2 !important;
			stroke-dasharray: 5,5 !important;
			fill: none !important;
			pointer-events: none !important;
			opacity: 0.9 !important;
			z-index: 1000;
		}
		</style>
	</head>
	<body class="">
		<div class="drag-drop-prompt">
			<div class="animated-border">
				<h1>Drag and Drop Floorplan SVG or Image Here</h1>
			</div>
		</div>
		
		<main class="toolsets" style="display: flex">
			<div class="toolset-section">
				<a
					href="/"
					class="flex w-fit border-2 pl-2 pr-2 p-1 mb-2 text-center rounded-md content-center hover:bg-neutral-100"
				>
					<div class="align-center content-center">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							fill="none"
							viewBox="0 0 24 24"
							stroke-width="1.5"
							stroke="currentColor"
							class="size-5"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
							></path>
						</svg>
					</div>
					<p class="ml-2">Home</p>
				</a>

				<section class="container">
					<label for="myFile" class="button-style">
						Import Files
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<path
								d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
								stroke-width="2"></path>
							<polyline points="17 8 12 3 7 8" stroke-width="2"></polyline>
							<line
								x1="12"
								x2="12"
								y1="3"
								y2="15"
								stroke-width="2"></line>
						</svg>
					</label>
					<input
						type="file"
						class="input-style"
						id="myFile"
						name="filename"
						accept="image/*,.svg"
						multiple
						style="display:none;"
					/>
				</section>

				<!-- Properties Panel -->
				<section class="container" id="properties-panel">
					<h3 style="margin: 0 0 10px 0; font-size: 14px; font-weight: bold;">Properties</h3>
					<div id="properties-content" style="font-size: 12px;">
						<p style="color: #666; margin: 10px 0;">Select a rect to view properties</p>
						</div>
				</section>

				<!-- Tools Section -->
				<section class="container">
					<h3 style="margin: 0 0 10px 0; font-size: 14px; font-weight: bold;">Tools</h3>
							<button
						id="add-rect-btn"
						style="width: 100%; padding: 6px 8px; background: #28a745; color: white; border: none; border-radius: 3px; cursor: pointer; font-size: 11px; margin-bottom: 8px;"
					>
						Add Rectangle (Ctrl+L)
					</button>
				</section>

				<!-- Brush toolbar: Manual vs Auto rectangle drawing -->
				<section class="container" id="brush-toolbar">
					<h3 style="margin: 0 0 10px 0; font-size: 14px; font-weight: bold;">Draw rectangle</h3>
					<p style="font-size: 10px; color: #666; margin: 0 0 8px 0;">
						Click and drag on empty canvas area to add a rect (not on existing rects).
					</p>
					<div style="display: flex; flex-direction: column; gap: 6px;">
						<label style="display: flex; align-items: center; gap: 6px; font-size: 11px; cursor: pointer;">
							<input type="radio" name="brush-mode" id="brush-manual" value="manual" checked />
							Manual
						</label>
						<label style="display: flex; align-items: center; gap: 6px; font-size: 11px; cursor: pointer;">
							<input type="radio" name="brush-mode" id="brush-auto" value="auto" />
							Auto <span style="color: #888;">(shrink-wrap bright pixels)</span>
						</label>
					</div>
					<div id="auto-padding-row" style="display: none; margin-top: 8px;">
						<label for="auto-padding" style="font-size: 11px; display: block; margin-bottom: 4px;">Padding (SVG units)</label>
						<input
							type="number"
							id="auto-padding"
							min="0"
							step="1"
							value="0"
							style="width: 100%; padding: 4px 6px; border: 1px solid #ccc; border-radius: 3px; font-size: 11px;"
						/>
					</div>
				</section>

				<!-- Export Section -->
				<section class="container">
					<h3 style="margin: 0 0 10px 0; font-size: 14px; font-weight: bold;">Export</h3>
					<input
						type="text"
						placeholder="filename"
						id="export-filename"
						style="width: 100%; margin-bottom: 8px; padding: 4px 6px; border: 1px solid #ccc; border-radius: 3px; font-size: 11px;"
						value="exported-svg"
					/>
					<button
						id="export-svg-btn"
						style="width: 100%; padding: 6px 8px; background: #007bff; color: white; border: none; border-radius: 3px; cursor: pointer; font-size: 11px; margin-bottom: 6px;"
					>
						Export SVG overlay
					</button>
					<button
						id="export-bundle-svg-btn"
						style="width: 100%; padding: 6px 8px; background: #0a7a4b; color: white; border: none; border-radius: 3px; cursor: pointer; font-size: 11px; display: none;"
					>
						Export bundle SVG
					</button>
					<p id="export-bundle-hint" style="display: none; font-size: 10px; color: #666; margin: 6px 0 0; line-height: 1.35;">
						Bundle export: <code>dims_background</code> + <code>patch_*</code> groups each with <code>&lt;image&gt;</code> and a bezier <code>&lt;path&gt;</code> sibling (required by the floorplan generator).
					</p>
				</section>

				<!-- Instructions -->
				<section class="container">
					<h3 style="margin: 0 0 10px 0; font-size: 14px; font-weight: bold;">Instructions</h3>
					<div style="font-size: 11px; color: #666; line-height: 1.4;">
						<p>• Click a rect to select it</p>
						<p>• Drag to move selected rect</p>
						<p><strong>• Ctrl+drag to snap to edges</strong></p>
						<p>• Drag corner handles to resize</p>
						<p>• Press Delete/Backspace to delete</p>
						<p>• Ctrl+C/V to copy/paste rects</p>
						<p>• Alt+drag to duplicate rects</p>
						<p>
							<strong>• Draw rect:</strong> drag on empty canvas (avoid clicking rects/handles).
							Manual = drag box; Auto = shrink-wrap white/bright pixels under drag center (needs PNG backplate or bundle bake; includes vector dim lines).
						</p>
						<p id="dims-reference-hint" style="display: none; color: #0a5; margin-top: 8px;">
							<strong>Dimension SVG loaded.</strong> White lines are reference only — draw blue mask rectangles on top.
						</p>
						<p id="combined-bundle-hint" style="display: none; color: #0a5; margin-top: 8px;">
							<strong>Combined floorplan imported.</strong> Floorplan and all patches are baked into one canonical PNG underlay. Blue rectangles are crop guides only — move them, then export to crop new <code>patch_*</code> images from that bake.
						</p>
					</div>
				</section>
			</div>
		</main>

		<section class="container editor grid">
			<div
				id="editor-button-container"
				style="display: flex; flex-direction: row; justify-content: space-between;"
			>
				<h3>Viewer</h3>
			</div>
			<div
				class="aspect-square max-h-[91vh] max-w-[91vh]"
				id="scalable-canvas"
				tabindex="0"
				aria-label="Mask editor canvas"
			>
				<div class="output" id="svg-container">
					<p
						style="padding: 2em; background-color: #00000022; border-radius: 3px; margin: 0px;"
					>
						Import combined floorplan SVG, or PNG/JPEG + SVG overlay
					</p>
				</div>
			</div>
		</section>

	</body>

	<script>
		// Global variables
		var globalSvgContainer = document.getElementById("svg-container");
		var importedSVGs = [];
		var currentSVGIndex = 0;
		var selectedRect = null;
		var isDragging = false;
		var isResizing = false;
		var dragStartX = 0;
		var dragStartY = 0;
		var resizeHandle = null;
		var currentFileName = "exported-svg"; // Store current file name
		var copiedRect = null; // Store copied rect data
		var isAddRectMode = false; // Add rectangle mode
		var isDrawingRect = false; // Currently drawing a new rect
		var snapThreshold = 10; // Snap threshold in SVG units
		var snapGuides = []; // Store snap guide elements
		var isDuplicating = false; // Duplication drag mode
		var originalRect = null; // Original rect being duplicated
		var duplicatedRect = null; // The duplicated rect

		var isRubberBandDrawing = false;
		var rubberBandPreview = null;
		var rubberBandSvg = null;
		var rubberBandStart = { x: 0, y: 0 };
		var suppressBackgroundClickDeselect = false;

		type PatchBox = { x: number; y: number; w: number; h: number };

		type PatchTileMeta = {
			patchId: string;
			box: PatchBox;
			href: string;
			pathD: string | null;
		};

		/** Set when a combined bundle was flattened to PNG + overlay for editing. */
		type BundleSourceMeta = {
			viewBox: string;
			sourceViewBox: string;
			preserveAspectRatio: string;
			/** Load-time bake: floorplan + all patches composited once; never mutated while editing. */
			canonicalMergedDataUrl: string;
			floorplanRasterDataUrl: string;
			/** Original patch tiles at import (dimension segments live in these images). */
			initialPatchTiles: PatchTileMeta[];
			mergedPixelWidth: number;
			mergedPixelHeight: number;
			originalFileName: string;
			exportFormat: "soluis-root" | "generic";
			svgWidth: string;
			svgHeight: string;
		};
		var bundleSourceMeta: BundleSourceMeta | null = null;
		/** PNG/JPEG dropped as HTML backplate under the SVG overlay. */
		var backplateRasterDataUrl: string | null = null;

		const SVG_NS = "http://www.w3.org/2000/svg";
		const XLINK_NS = "http://www.w3.org/1999/xlink";
		function getImageHref(imageEl: Element): string | null {
			return (
				imageEl.getAttribute("href") ||
				imageEl.getAttributeNS(XLINK_NS, "href") ||
				null
			);
		}

		function isRasterImageHref(href: string | null): boolean {
			if (!href) return false;
			return (
				/^data:image\/(png|jpe?g|webp)/i.test(href) ||
				/\.(png|jpe?g|webp)(\?|#|$)/i.test(href)
			);
		}

		function getEmbeddedRasterImages(svg: SVGSVGElement): SVGImageElement[] {
			return Array.from(svg.querySelectorAll("image")).filter((el) =>
				isRasterImageHref(getImageHref(el)),
			) as SVGImageElement[];
		}

		function isDimsReferenceSvg(svg: SVGSVGElement, fileName?: string) {
			if (fileName && /\bdims[_-]/i.test(fileName)) return true;
			if (fileName && /_dims\.svg$/i.test(fileName)) return true;
			if (svg.querySelector("#dims-reference")) return true;
			if (svg.querySelector(".dim-line, .dim-ext, .dim-text")) return true;
			const lines = svg.querySelectorAll("line");
			const texts = svg.querySelectorAll("text");
			if (lines.length >= 4 && texts.length >= 4) {
				let meterLabels = 0;
				texts.forEach((t) => {
					if (/\d+(\.\d+)?\s*m\b/i.test(t.textContent || "")) meterLabels++;
				});
				if (meterLabels >= 3) return true;
			}
			return false;
		}

		function isCombinedBundleSvg(svg: SVGSVGElement, fileName?: string) {
			if (svg.getAttribute("data-mask-editor-bundle") === "true") return true;
			const rasters = getEmbeddedRasterImages(svg);
			if (rasters.length === 0) return false;
			if (svg.querySelector("#dims-reference") && svg.querySelector("#floorplan-raster")) {
				return true;
			}
			if (
				svg.querySelector("#dims_background") ||
				svg.querySelector('g[id^="patch_"]')
			) {
				return true;
			}
			return isDimsReferenceSvg(svg, fileName);
		}

		function parseImageBox(img: SVGImageElement) {
			return {
				x: parseFloat(img.getAttribute("x") || "0"),
				y: parseFloat(img.getAttribute("y") || "0"),
				w: parseFloat(img.getAttribute("width") || "0"),
				h: parseFloat(img.getAttribute("height") || "0"),
			};
		}

		function isPatchMaskImage(
			img: SVGImageElement,
			vb: { w: number; h: number },
		) {
			if (img.id === "dims_background") return false;
			const { w, h } = parseImageBox(img);
			if (w <= 0 || h <= 0) return false;
			if (w >= vb.w * 0.9 && h >= vb.h * 0.9) return false;
			const parentId = img.closest("g")?.id || "";
			if (/^patch_/i.test(parentId)) return true;
			return w < vb.w * 0.25 && h < vb.h * 0.25;
		}

		function isSoluisPatchBundleSvg(svg: SVGSVGElement) {
			return !!(
				svg.querySelector("#dims_background") ||
				svg.querySelector('g[id^="patch_"]')
			);
		}

		function sortImagesForMerge(
			images: SVGImageElement[],
			_vb: { w: number; h: number },
		) {
			const area = (img: SVGImageElement) => {
				const { w, h } = parseImageBox(img);
				return w * h;
			};
			return [...images].sort((a, b) => {
				if (a.id === "dims_background") return -1;
				if (b.id === "dims_background") return 1;
				return area(b) - area(a);
			});
		}

		function unmapRectAttrsFromOverlay(
			rect: SVGRectElement,
			overlayVb: { x: number; y: number; w: number; h: number },
			sourceVb: { x: number; y: number; w: number; h: number },
		) {
			const sx = overlayVb.w > 0 ? sourceVb.w / overlayVb.w : 1;
			const sy = overlayVb.h > 0 ? sourceVb.h / overlayVb.h : 1;
			const x = parseFloat(rect.getAttribute("x") || "0");
			const y = parseFloat(rect.getAttribute("y") || "0");
			const w = parseFloat(rect.getAttribute("width") || "0");
			const h = parseFloat(rect.getAttribute("height") || "0");
			return {
				x: x * sx + sourceVb.x,
				y: y * sy + sourceVb.y,
				w: w * sx,
				h: h * sy,
			};
		}

		/** Floorplan underlay only — excludes OCR label patches in &lt;g id="patch_*"&gt;. */
		function getFloorplanRasterImages(svg: SVGSVGElement): SVGImageElement[] {
			const bg = svg.querySelector("#dims_background");
			if (bg && bg.tagName === "image") {
				return [bg as SVGImageElement];
			}
			const vb = parseViewBoxAttr(svg);
			return getEmbeddedRasterImages(svg).filter(
				(img) => !isPatchMaskImage(img, vb),
			);
		}

		/** Convert &lt;g id="patch_*"&gt;&lt;image&gt;… masks into editable rects. */
		function formatPatchCoord(n: number) {
			return Number.isFinite(n) ? n.toFixed(1) : "0.0";
		}

		/** Closed cubic-bezier outline; required by tools-floorplan_generator `_is_text_path`. */
		function buildPatchOutlinePathD(box: PatchBox) {
			const x = box.x;
			const y = box.y;
			const x2 = box.x + box.w;
			const y2 = box.y + box.h;
			const fx = formatPatchCoord;
			return (
				`M ${fx(x)} ${fx(y)}` +
				` C ${fx(x2)} ${fx(y)} ${fx(x2)} ${fx(y)} ${fx(x2)} ${fx(y)}` +
				` C ${fx(x2)} ${fx(y)} ${fx(x2)} ${fx(y2)} ${fx(x2)} ${fx(y2)}` +
				` C ${fx(x2)} ${fx(y2)} ${fx(x)} ${fx(y2)} ${fx(x)} ${fx(y2)}` +
				` C ${fx(x)} ${fx(y2)} ${fx(x)} ${fx(y)} ${fx(x)} ${fx(y)} Z`
			);
		}

		function appendPatchPathElement(patchG: SVGGElement, box: PatchBox) {
			const path = document.createElementNS(SVG_NS, "path");
			path.setAttribute("d", buildPatchOutlinePathD(box));
			path.setAttribute("fill", "none");
			path.setAttribute("stroke", "none");
			path.setAttribute("opacity", "0");
			path.setAttribute(
				"data-migrated-bbox",
				`${box.x.toFixed(2)},${box.y.toFixed(2)},${box.w.toFixed(2)},${box.h.toFixed(2)}`,
			);
			patchG.appendChild(path);
		}

		function extractPatchTilesFromSource(svg: SVGSVGElement): PatchTileMeta[] {
			const vb = parseViewBoxAttr(svg);
			const tiles: PatchTileMeta[] = [];
			let fallbackIndex = 0;
			for (const img of svg.querySelectorAll("image")) {
				const imageEl = img as SVGImageElement;
				if (!isPatchMaskImage(imageEl, vb)) continue;
				const href = getImageHref(imageEl);
				if (!href) continue;
				const patchG = imageEl.closest("g");
				const patchId =
					patchG?.id && /^patch_/i.test(patchG.id)
						? patchG.id
						: `patch_${++fallbackIndex}`;
				const pathEl = patchG?.querySelector("path");
				tiles.push({
					patchId,
					box: parseImageBox(imageEl),
					href,
					pathD: pathEl?.getAttribute("d") || null,
				});
			}
			return tiles;
		}

		function extractPatchBoxesFromSource(svg: SVGSVGElement): PatchBox[] {
			return extractPatchTilesFromSource(svg).map((t) => t.box);
		}

		function extractMaskRectsFromPatchImages(svg: SVGSVGElement): SVGRectElement[] {
			const boxes = extractPatchBoxesFromSource(svg);
			return boxes.map((box, index) => {
				const rect = document.createElementNS(SVG_NS, "rect");
				rect.setAttribute("x", String(box.x));
				rect.setAttribute("y", String(box.y));
				rect.setAttribute("width", String(box.w));
				rect.setAttribute("height", String(box.h));
				rect.setAttribute("data-patch-id", `patch_${index + 1}`);
				return rect;
			});
		}

		function extractAllMaskRectsFromSource(svg: SVGSVGElement): SVGRectElement[] {
			return [
				...extractMaskRectsFromSource(svg),
				...extractMaskRectsFromPatchImages(svg),
			];
		}

		function parseViewBoxAttr(svg: SVGSVGElement) {
			const vb = svg.viewBox?.baseVal;
			if (vb && vb.width > 0 && vb.height > 0) {
				return { x: vb.x, y: vb.y, w: vb.width, h: vb.height };
			}
			const raw = svg.getAttribute("viewBox");
			if (raw) {
				const parts = raw.trim().split(/[\s,]+/).map(Number);
				if (parts.length === 4 && parts.every((n) => Number.isFinite(n))) {
					return { x: parts[0], y: parts[1], w: parts[2], h: parts[3] };
				}
			}
			return { x: 0, y: 0, w: 4096, h: 4096 };
		}

		function loadHtmlImage(src: string): Promise<HTMLImageElement> {
			return new Promise((resolve, reject) => {
				const img = new Image();
				img.onload = () => resolve(img);
				img.onerror = () => reject(new Error("Failed to load image"));
				img.src = src;
			});
		}

		async function mergeRasterImagesToPng(
			images: SVGImageElement[],
			vb: { x: number; y: number; w: number; h: number },
			pixelWidth: number,
			pixelHeight: number,
			options?: { opaqueBackground?: boolean },
		): Promise<string> {
			const canvas = document.createElement("canvas");
			canvas.width = pixelWidth;
			canvas.height = pixelHeight;
			const ctx = canvas.getContext("2d", { alpha: true });
			if (!ctx) throw new Error("Canvas not available");

			if (options?.opaqueBackground) {
				ctx.fillStyle = "#000000";
				ctx.fillRect(0, 0, pixelWidth, pixelHeight);
			} else {
				ctx.clearRect(0, 0, pixelWidth, pixelHeight);
			}

			const sx = pixelWidth / vb.w;
			const sy = pixelHeight / vb.h;

			for (const imageEl of images) {
				const href = getImageHref(imageEl);
				if (!href) continue;
				const { x, y, w, h } = parseImageBox(imageEl);
				if (w <= 0 || h <= 0) continue;
				const htmlImg = await loadHtmlImage(href);
				ctx.drawImage(
					htmlImg,
					(x - vb.x) * sx,
					(y - vb.y) * sy,
					w * sx,
					h * sy,
				);
			}

			return canvas.toDataURL("image/png");
		}

		async function cropRegionFromRasterDataUrl(
			dataUrl: string,
			box: { x: number; y: number; w: number; h: number },
			sourceVb: { x: number; y: number; w: number; h: number },
		): Promise<string> {
			const mergedImg = await loadHtmlImage(dataUrl);
			const imgW = mergedImg.naturalWidth;
			const imgH = mergedImg.naturalHeight;
			if (imgW <= 0 || imgH <= 0) {
				throw new Error("Merged raster has zero size");
			}

			const sx = imgW / sourceVb.w;
			const sy = imgH / sourceVb.h;
			let sx0 = Math.floor((box.x - sourceVb.x) * sx);
			let sy0 = Math.floor((box.y - sourceVb.y) * sy);
			let sw = Math.max(1, Math.ceil(box.w * sx));
			let sh = Math.max(1, Math.ceil(box.h * sy));

			sx0 = Math.max(0, Math.min(sx0, imgW - 1));
			sy0 = Math.max(0, Math.min(sy0, imgH - 1));
			sw = Math.min(sw, imgW - sx0);
			sh = Math.min(sh, imgH - sy0);

			const canvas = document.createElement("canvas");
			canvas.width = sw;
			canvas.height = sh;
			const ctx = canvas.getContext("2d", { alpha: true });
			if (!ctx) throw new Error("Canvas not available");
			ctx.clearRect(0, 0, sw, sh);
			ctx.drawImage(mergedImg, sx0, sy0, sw, sh, 0, 0, sw, sh);
			return canvas.toDataURL("image/png");
		}

		/**
		 * Soluis dims_background: floorplan + every original patch tile at its import
		 * position (keeps dimension lines connected). New labels export as patch_* only.
		 */
		async function buildDimsBackgroundForExport(
			meta: BundleSourceMeta,
			sourceVb: { x: number; y: number; w: number; h: number },
		): Promise<string> {
			const { mergedPixelWidth: pw, mergedPixelHeight: ph } = meta;
			const canvas = document.createElement("canvas");
			canvas.width = pw;
			canvas.height = ph;
			const ctx = canvas.getContext("2d", { alpha: true });
			if (!ctx) throw new Error("Canvas not available");
			ctx.clearRect(0, 0, pw, ph);

			const sx = pw / sourceVb.w;
			const sy = ph / sourceVb.h;

			const floor = await loadHtmlImage(meta.floorplanRasterDataUrl);
			ctx.drawImage(floor, 0, 0, pw, ph);

			for (const tile of meta.initialPatchTiles) {
				const patchImg = await loadHtmlImage(tile.href);
				const dx = (tile.box.x - sourceVb.x) * sx;
				const dy = (tile.box.y - sourceVb.y) * sy;
				const dw = tile.box.w * sx;
				const dh = tile.box.h * sy;
				ctx.drawImage(
					patchImg,
					0,
					0,
					patchImg.naturalWidth,
					patchImg.naturalHeight,
					dx,
					dy,
					dw,
					dh,
				);
			}

			return canvas.toDataURL("image/png");
		}

		async function mergeBundleRasters(source: SVGSVGElement) {
			const vb = parseViewBoxAttr(source);
			const maxDim = 4096;
			const scale = Math.min(1, maxDim / Math.max(vb.w, vb.h));
			const pixelWidth = Math.max(1, Math.round(vb.w * scale));
			const pixelHeight = Math.max(1, Math.round(vb.h * scale));

			const isSoluis = isSoluisPatchBundleSvg(source);
			const allImages = isSoluis
				? sortImagesForMerge(getEmbeddedRasterImages(source), vb)
				: getFloorplanRasterImages(source);
			const floorplanImages = getFloorplanRasterImages(source);

			const mergedRasterDataUrl = await mergeRasterImagesToPng(
				allImages,
				vb,
				pixelWidth,
				pixelHeight,
				{ opaqueBackground: false },
			);
			console.log(
				`Merged ${allImages.length} raster layer(s) into ${pixelWidth}×${pixelHeight} PNG (transparent background)`,
			);
			const floorplanRasterDataUrl =
				isSoluis && floorplanImages.length > 0
					? await mergeRasterImagesToPng(
							floorplanImages,
							vb,
							pixelWidth,
							pixelHeight,
							{ opaqueBackground: false },
						)
					: mergedRasterDataUrl;

			return {
				canonicalMergedDataUrl: mergedRasterDataUrl,
				floorplanRasterDataUrl,
				viewBox: `${vb.x} ${vb.y} ${vb.w} ${vb.h}`,
				pixelWidth,
				pixelHeight,
			};
		}

		function ensureBackgroundImageContainer() {
			let backgroundContainer = document.getElementById(
				"background-image-container",
			);
			if (!backgroundContainer) {
				backgroundContainer = document.createElement("div");
				backgroundContainer.id = "background-image-container";
				backgroundContainer.style.position = "absolute";
				backgroundContainer.style.top = "0";
				backgroundContainer.style.left = "0";
				backgroundContainer.style.width = "100%";
				backgroundContainer.style.height = "100%";
				backgroundContainer.style.display = "flex";
				backgroundContainer.style.alignItems = "center";
				backgroundContainer.style.justifyContent = "center";
				backgroundContainer.style.zIndex = "-1";
				backgroundContainer.style.pointerEvents = "none";
				globalSvgContainer.style.position = "relative";
				globalSvgContainer.appendChild(backgroundContainer);
			}
			return backgroundContainer;
		}

		function setBackgroundFromDataUrl(dataUrl: string, opacity = 1) {
			backplateRasterDataUrl = dataUrl;
			globalSvgContainer.querySelector("p")?.remove();
			const backgroundContainer = ensureBackgroundImageContainer();
			backgroundContainer.innerHTML = "";
			const img = document.createElement("img");
			img.style.maxWidth = "100%";
			img.style.maxHeight = "100%";
			img.style.objectFit = "contain";
			img.style.opacity = String(opacity);
			img.src = dataUrl;
			backgroundContainer.appendChild(img);
			updateExportButtonsVisibility();
		}

		function getBackplateRasterDataUrl(): string | null {
			if (backplateRasterDataUrl) return backplateRasterDataUrl;
			const img = globalSvgContainer.querySelector(
				"#background-image-container img",
			) as HTMLImageElement | null;
			const src = img?.src;
			return src && src.startsWith("data:") ? src : null;
		}

		function canExportBundleSvg(): boolean {
			if (bundleSourceMeta) return true;
			if (!getBackplateRasterDataUrl()) return false;
			return !!globalSvgContainer.querySelector("svg");
		}

		function updateExportButtonsVisibility() {
			const bundleBtn = document.getElementById("export-bundle-svg-btn");
			const bundleHint = document.getElementById("export-bundle-hint");
			const showBundle = canExportBundleSvg();
			if (bundleBtn) bundleBtn.style.display = showBundle ? "block" : "none";
			if (bundleHint) bundleHint.style.display = showBundle ? "block" : "none";
		}

		async function bakeRasterToViewBoxPixels(
			dataUrl: string,
			vb: { x: number; y: number; w: number; h: number },
		): Promise<{ dataUrl: string; pixelWidth: number; pixelHeight: number }> {
			const maxDim = 4096;
			const scale = Math.min(1, maxDim / Math.max(vb.w, vb.h));
			const pixelWidth = Math.max(1, Math.round(vb.w * scale));
			const pixelHeight = Math.max(1, Math.round(vb.h * scale));
			const img = await loadHtmlImage(dataUrl);
			const canvas = document.createElement("canvas");
			canvas.width = pixelWidth;
			canvas.height = pixelHeight;
			const ctx = canvas.getContext("2d", { alpha: true });
			if (!ctx) throw new Error("Canvas not available");
			ctx.clearRect(0, 0, pixelWidth, pixelHeight);
			ctx.drawImage(img, 0, 0, pixelWidth, pixelHeight);
			return {
				dataUrl: canvas.toDataURL("image/png"),
				pixelWidth,
				pixelHeight,
			};
		}

		async function composeCanonicalFromBackplateAndOverlay(
			floorplanDataUrl: string,
			overlay: SVGSVGElement,
			vb: { x: number; y: number; w: number; h: number },
			pixelWidth: number,
			pixelHeight: number,
		): Promise<string> {
			const dims = overlay.querySelector("#dims-reference");
			if (
				!dims ||
				!dims.querySelector("line, path, text, polyline, polygon")
			) {
				return floorplanDataUrl;
			}

			const fragSvg = document.createElementNS(SVG_NS, "svg");
			fragSvg.setAttribute("xmlns", SVG_NS);
			fragSvg.setAttribute("viewBox", `${vb.x} ${vb.y} ${vb.w} ${vb.h}`);
			fragSvg.setAttribute("width", String(pixelWidth));
			fragSvg.setAttribute("height", String(pixelHeight));
			fragSvg.appendChild(dims.cloneNode(true));

			const blob = new Blob(
				[new XMLSerializer().serializeToString(fragSvg)],
				{ type: "image/svg+xml;charset=utf-8" },
			);
			const objectUrl = URL.createObjectURL(blob);
			try {
				const canvas = document.createElement("canvas");
				canvas.width = pixelWidth;
				canvas.height = pixelHeight;
				const ctx = canvas.getContext("2d", { alpha: true });
				if (!ctx) throw new Error("Canvas not available");
				ctx.clearRect(0, 0, pixelWidth, pixelHeight);
				const floor = await loadHtmlImage(floorplanDataUrl);
				ctx.drawImage(floor, 0, 0, pixelWidth, pixelHeight);
				const dimsImg = await loadHtmlImage(objectUrl);
				ctx.drawImage(dimsImg, 0, 0, pixelWidth, pixelHeight);
				return canvas.toDataURL("image/png");
			} finally {
				URL.revokeObjectURL(objectUrl);
			}
		}

		async function buildBundleMetaFromBackplate(
			overlay: SVGSVGElement,
		): Promise<BundleSourceMeta> {
			const backplate = getBackplateRasterDataUrl();
			if (!backplate) {
				throw new Error(
					"No PNG backplate found. Drop an image under the SVG overlay first.",
				);
			}

			const vb = parseViewBoxAttr(overlay);
			const sourceViewBox = `${vb.x} ${vb.y} ${vb.w} ${vb.h}`;
			const preserveAspectRatio =
				overlay.getAttribute("preserveAspectRatio") || "xMidYMid meet";
			const { dataUrl: floorplanRasterDataUrl, pixelWidth, pixelHeight } =
				await bakeRasterToViewBoxPixels(backplate, vb);
			const canonicalMergedDataUrl =
				await composeCanonicalFromBackplateAndOverlay(
					floorplanRasterDataUrl,
					overlay,
					vb,
					pixelWidth,
					pixelHeight,
				);

			return {
				viewBox: sourceViewBox,
				sourceViewBox,
				preserveAspectRatio,
				canonicalMergedDataUrl,
				floorplanRasterDataUrl,
				initialPatchTiles: [],
				mergedPixelWidth: pixelWidth,
				mergedPixelHeight: pixelHeight,
				originalFileName: currentFileName || "exported-svg",
				exportFormat: "soluis-root",
				svgWidth: overlay.getAttribute("width") || String(vb.w),
				svgHeight: overlay.getAttribute("height") || String(vb.h),
			};
		}

		async function resolveBundleExportMeta(
			overlay: SVGSVGElement,
		): Promise<BundleSourceMeta> {
			if (bundleSourceMeta) return bundleSourceMeta;
			return buildBundleMetaFromBackplate(overlay);
		}

		function setActiveBundleMeta(meta: BundleSourceMeta | null | undefined) {
			bundleSourceMeta = meta ?? null;
			updateExportButtonsVisibility();
			const bundleHint = document.getElementById("combined-bundle-hint");
			if (bundleHint) {
				bundleHint.style.display = bundleSourceMeta ? "block" : "none";
			}
		}

		async function convertBundleToEditMode(
			sourceSvg: SVGSVGElement,
			fileName: string,
		): Promise<{ overlay: SVGSVGElement; meta: BundleSourceMeta }> {
			const isSoluis = isSoluisPatchBundleSvg(sourceSvg);
			const initialPatchTiles = isSoluis
				? extractPatchTilesFromSource(sourceSvg)
				: [];
			const patchCountAtImport = initialPatchTiles.length;
			const existingMaskRects = extractAllMaskRectsFromSource(sourceSvg);
			const sourceVb = parseViewBoxAttr(sourceSvg);
			const sourceViewBox = `${sourceVb.x} ${sourceVb.y} ${sourceVb.w} ${sourceVb.h}`;

			const preserveAspectRatio =
				sourceSvg.getAttribute("preserveAspectRatio") || "xMidYMid meet";

			const {
				canonicalMergedDataUrl,
				floorplanRasterDataUrl,
				pixelWidth,
				pixelHeight,
			} = await mergeBundleRasters(sourceSvg);

			if (isSoluis) {
				console.log(
					`Baked canonical image ${pixelWidth}×${pixelHeight} from floorplan + ${patchCountAtImport} patch(es)`,
				);
			}

			prepareImportedSvg(sourceSvg, fileName);

			const dimsRef = sourceSvg.querySelector("#dims-reference");
			const dimsClone = dimsRef
				? (dimsRef.cloneNode(true) as SVGGElement)
				: null;
			const dimsHasVectors =
				!!dimsClone?.querySelector("line, path, text, polyline, polygon");

			const meta: BundleSourceMeta = {
				viewBox: sourceViewBox,
				sourceViewBox,
				preserveAspectRatio,
				canonicalMergedDataUrl,
				floorplanRasterDataUrl,
				initialPatchTiles,
				mergedPixelWidth: pixelWidth,
				mergedPixelHeight: pixelHeight,
				originalFileName: fileName,
				exportFormat: isSoluis ? "soluis-root" : "generic",
				svgWidth: sourceSvg.getAttribute("width") || String(sourceVb.w),
				svgHeight: sourceSvg.getAttribute("height") || String(sourceVb.h),
			};

			const overlay = createNewSVG();
			overlay.setAttribute("viewBox", sourceViewBox);
			overlay.setAttribute("preserveAspectRatio", preserveAspectRatio);
			overlay.setAttribute("data-converted-from-bundle", "true");
			overlay.setAttribute(
				"data-dims-reference",
				dimsClone && dimsHasVectors && !isSoluis ? "true" : "false",
			);
			overlay.setAttribute("data-mask-editor-prepared", "true");

			if (dimsClone && dimsHasVectors && !isSoluis) {
				dimsClone.setAttribute("id", "dims-reference");
				dimsClone.setAttribute("pointer-events", "none");
				dimsClone.setAttribute(
					"transform",
					dimsLayerTransform(sourceVb, pixelWidth, pixelHeight),
				);
				dimsClone
					.querySelectorAll("rect[data-dims-bg]")
					.forEach((bg) => bg.remove());
				dimsClone
					.querySelectorAll('g[id^="patch_"]')
					.forEach((patch) => patch.remove());
				overlay.appendChild(dimsClone);
			}

			const maskGroup = getMaskRectsGroup(overlay);
			for (const rect of existingMaskRects) {
				normalizeMaskRect(rect);
				maskGroup.appendChild(rect);
			}

			ensureInteractionPlane(overlay);
			ensureOverlayLayerOrder(overlay);

			return { overlay, meta };
		}

		function triggerDownload(blob: Blob, filename: string) {
			const url = URL.createObjectURL(blob);
			const link = document.createElement("a");
			link.href = url;
			link.download = filename;
			link.style.display = "none";
			document.body.appendChild(link);
			link.click();
			document.body.removeChild(link);
			setTimeout(() => URL.revokeObjectURL(url), 1000);
		}

		/** Raster used for Auto brush: backplate + vector dims (what you see on screen). */
		async function resolveAutoBrushRasterImage(
			svg: SVGSVGElement,
		): Promise<HTMLImageElement | null> {
			const vb = parseViewBoxAttr(svg);

			if (bundleSourceMeta?.canonicalMergedDataUrl) {
				try {
					return await loadHtmlImage(bundleSourceMeta.canonicalMergedDataUrl);
				} catch {
					/* fall through */
				}
			}

			const base = await resolveBrushRasterImage(svg);
			if (!base?.src) return null;

			const { dataUrl: floorDataUrl, pixelWidth, pixelHeight } =
				await bakeRasterToViewBoxPixels(base.src, vb);

			const dims = svg.querySelector("#dims-reference");
			const hasDimVectors = !!dims?.querySelector(
				"line, path, text, polyline, polygon",
			);
			if (hasDimVectors) {
				try {
					const composite = await composeCanonicalFromBackplateAndOverlay(
						floorDataUrl,
						svg,
						vb,
						pixelWidth,
						pixelHeight,
					);
					return await loadHtmlImage(composite);
				} catch (err) {
					console.warn("Auto brush: could not composite dim vectors:", err);
				}
			}

			return loadHtmlImage(floorDataUrl);
		}

		async function resolveBrushRasterImage(
			_svg: SVGSVGElement,
		): Promise<HTMLImageElement | null> {
			const htmlImg = globalSvgContainer.querySelector(
				"#background-image-container img",
			) as HTMLImageElement | null;
			if (htmlImg?.src) {
				if (htmlImg.complete && (htmlImg.naturalWidth || 0) > 0) {
					return htmlImg;
				}
				try {
					return await loadHtmlImage(htmlImg.src);
				} catch {
					/* fall through */
				}
			}
			const url =
				backplateRasterDataUrl ||
				bundleSourceMeta?.canonicalMergedDataUrl ||
				null;
			if (!url) return null;
			try {
				return await loadHtmlImage(url);
			} catch {
				return null;
			}
		}

		function rubberBandSvgToImagePixels(
			svg: SVGSVGElement,
			img: HTMLImageElement,
			x: number,
			y: number,
			width: number,
			height: number,
		) {
			const vb = parseViewBoxAttr(svg);
			const nw = img.naturalWidth || 0;
			const nh = img.naturalHeight || 0;
			if (nw <= 0 || nh <= 0 || vb.w <= 0 || vb.h <= 0) return null;

			const ix0 = Math.max(
				0,
				Math.floor(((x - vb.x) / vb.w) * nw),
			);
			const iy0 = Math.max(
				0,
				Math.floor(((y - vb.y) / vb.h) * nh),
			);
			const ix1 = Math.min(
				nw,
				Math.ceil(((x + width - vb.x) / vb.w) * nw),
			);
			const iy1 = Math.min(
				nh,
				Math.ceil(((y + height - vb.y) / vb.h) * nh),
			);
			if (ix1 - ix0 < 1 || iy1 - iy0 < 1) return null;
			return { ix0, iy0, ix1, iy1 };
		}

		function imagePixelRectToSvgRect(
			svg: SVGSVGElement,
			img: HTMLImageElement,
			px0: number,
			py0: number,
			px1: number,
			py1: number,
		) {
			const vb = parseViewBoxAttr(svg);
			const nw = img.naturalWidth || 1;
			const nh = img.naturalHeight || 1;
			return {
				x: vb.x + (px0 / nw) * vb.w,
				y: vb.y + (py0 / nh) * vb.h,
				width: ((px1 - px0) / nw) * vb.w,
				height: ((py1 - py0) / nh) * vb.h,
			};
		}

		function getMaskRectsGroup(svg: SVGSVGElement): SVGGElement {
			let group = svg.querySelector("#mask-rects") as SVGGElement | null;
			if (!group) {
				group = document.createElementNS(SVG_NS, "g");
				group.setAttribute("id", "mask-rects");
				svg.appendChild(group);
			}
			return group;
		}

		function normalizeMaskRect(rect: SVGRectElement) {
			rect.setAttribute("fill", "rgba(0, 123, 255, 0.35)");
			rect.setAttribute("stroke", "#007bff");
			rect.setAttribute("stroke-width", "2");
			rect.setAttribute("pointer-events", "all");
		}

		function mapRectToPixelViewBox(
			rect: SVGRectElement,
			fromVb: { x: number; y: number; w: number; h: number },
			pixelW: number,
			pixelH: number,
		) {
			const sx = pixelW / fromVb.w;
			const sy = pixelH / fromVb.h;
			const x = parseFloat(rect.getAttribute("x") || "0");
			const y = parseFloat(rect.getAttribute("y") || "0");
			const w = parseFloat(rect.getAttribute("width") || "0");
			const h = parseFloat(rect.getAttribute("height") || "0");
			rect.setAttribute("x", String((x - fromVb.x) * sx));
			rect.setAttribute("y", String((y - fromVb.y) * sy));
			rect.setAttribute("width", String(w * sx));
			rect.setAttribute("height", String(h * sy));
		}

		function dimsLayerTransform(
			fromVb: { x: number; y: number; w: number; h: number },
			pixelW: number,
			pixelH: number,
		) {
			const sx = pixelW / fromVb.w;
			const sy = pixelH / fromVb.h;
			const tx = -fromVb.x * sx;
			const ty = -fromVb.y * sy;
			return `matrix(${sx},0,0,${sy},${tx},${ty})`;
		}

		function isMaskOverlaySvg(svg: SVGSVGElement, fileName?: string) {
			if (fileName && /_mask\.svg$/i.test(fileName)) return true;
			if (isCombinedBundleSvg(svg, fileName)) return false;
			return (
				extractAllMaskRectsFromSource(svg).length > 0 &&
				!isDimsReferenceSvg(svg, fileName)
			);
		}

		function importMaskRectsOntoOverlay(
			overlay: SVGSVGElement,
			maskSvg: SVGSVGElement,
		) {
			const overlayVb = parseViewBoxAttr(overlay);
			const maskVb = parseViewBoxAttr(maskSvg);
			const group = getMaskRectsGroup(overlay);
			for (const rect of extractAllMaskRectsFromSource(maskSvg)) {
				mapRectToPixelViewBox(rect, maskVb, overlayVb.w, overlayVb.h);
				normalizeMaskRect(rect);
				group.appendChild(rect);
			}
		}

		function appendMaskRect(svg: SVGSVGElement, rect: SVGRectElement) {
			normalizeMaskRect(rect);
			getMaskRectsGroup(svg).appendChild(rect);
		}

		function getContentRects(svg: SVGSVGElement) {
			const maskGroup = svg.querySelector("#mask-rects");
			const root = maskGroup || svg;
			return root.querySelectorAll(
				"rect:not(.transform-handle):not([data-dims-bg]):not(#interaction-plane)",
			);
		}

		function extractMaskRectsFromSource(svg: SVGSVGElement) {
			return Array.from(svg.querySelectorAll("rect"))
				.filter((r) => {
					if (r.getAttribute("data-dims-bg") === "true") return false;
					if (r.id === "interaction-plane") return false;
					if (r.classList.contains("transform-handle")) return false;
					if (r.closest("#floorplan-raster")) return false;
					return true;
				})
				.map((r) => r.cloneNode(true) as SVGRectElement);
		}

		function ensureInteractionPlane(svg: SVGSVGElement) {
			if (svg.querySelector("#interaction-plane")) return;

			const vb = parseViewBoxAttr(svg);
			const plane = document.createElementNS(SVG_NS, "rect");
			plane.setAttribute("id", "interaction-plane");
			plane.setAttribute("x", String(vb.x));
			plane.setAttribute("y", String(vb.y));
			plane.setAttribute("width", String(vb.w));
			plane.setAttribute("height", String(vb.h));
			plane.setAttribute("fill", "transparent");
			plane.setAttribute("stroke", "none");
			plane.setAttribute("pointer-events", "all");

			const maskGroup = svg.querySelector("#mask-rects");
			if (maskGroup) {
				svg.insertBefore(plane, maskGroup);
			} else {
				svg.appendChild(plane);
			}
			ensureOverlayLayerOrder(svg);
		}

		/** Dims on bottom, hit plane in the middle, editable mask rects on top. */
		function ensureOverlayLayerOrder(svg: SVGSVGElement) {
			const dims = svg.querySelector("#dims-reference");
			const plane = svg.querySelector("#interaction-plane");
			const maskGroup = svg.querySelector("#mask-rects");
			if (dims) svg.appendChild(dims);
			if (plane) svg.appendChild(plane);
			if (maskGroup) svg.appendChild(maskGroup);
		}

		function isSvgBackgroundHit(target: EventTarget | null, svg: SVGSVGElement) {
			if (!target || !(target instanceof Element)) return false;
			if (target === svg) return true;
			if (target.id === "interaction-plane") return true;
			return false;
		}

		function getDefaultRectSize(svg: SVGSVGElement) {
			const vb = svg.viewBox.baseVal;
			if (vb.width > 0 && vb.height > 0) {
				return {
					width: Math.max(vb.width * 0.05, 50),
					height: Math.max(vb.height * 0.05, 50),
				};
			}
			return { width: 100, height: 100 };
		}

		function isStructuralLayer(el: Element) {
			const id = el.id;
			return (
				id === "mask-rects" ||
				id === "dims-reference" ||
				id === "floorplan-raster"
			);
		}

		function ensureFloorplanRasterGroup(svg: SVGSVGElement) {
			let rasterGroup = svg.querySelector(
				"#floorplan-raster",
			) as SVGGElement | null;
			if (!rasterGroup) {
				rasterGroup = document.createElementNS(SVG_NS, "g");
				rasterGroup.setAttribute("id", "floorplan-raster");
				rasterGroup.setAttribute("pointer-events", "none");
				const insertBefore =
					svg.querySelector("#dims-reference") ||
					svg.querySelector("#mask-rects");
				if (insertBefore) {
					svg.insertBefore(rasterGroup, insertBefore);
				} else {
					svg.appendChild(rasterGroup);
				}
			}
			return rasterGroup;
		}

		function prepareImportedSvg(svg: SVGSVGElement, fileName?: string) {
			if (svg.getAttribute("data-mask-editor-prepared") === "true") return;

			const embeddedRasters = getEmbeddedRasterImages(svg);
			const isCombined = isCombinedBundleSvg(svg, fileName);
			const isDims =
				isDimsReferenceSvg(svg, fileName) || (isCombined && embeddedRasters.length > 0);

			if (!svg.getAttribute("preserveAspectRatio")) {
				svg.setAttribute("preserveAspectRatio", "xMidYMid meet");
			}

			if (!svg.querySelector("#mask-rects")) {
				const maskGroup = document.createElementNS(SVG_NS, "g");
				maskGroup.setAttribute("id", "mask-rects");
				svg.appendChild(maskGroup);
			}

			if (embeddedRasters.length > 0) {
				const rasterGroup = ensureFloorplanRasterGroup(svg);
				for (const img of getFloorplanRasterImages(svg)) {
					if (img.parentElement !== rasterGroup) {
						rasterGroup.appendChild(img);
					}
				}
			}

			const patchRects = extractMaskRectsFromPatchImages(svg);
			if (patchRects.length > 0) {
				const maskGroup = getMaskRectsGroup(svg);
				for (const rect of patchRects) {
					normalizeMaskRect(rect);
					maskGroup.appendChild(rect);
				}
			}

			if (isDims && !svg.querySelector("#dims-reference")) {
				const refGroup = document.createElementNS(SVG_NS, "g");
				refGroup.setAttribute("id", "dims-reference");
				refGroup.setAttribute("pointer-events", "none");

				const toDims: Element[] = [];
				const toMask: SVGRectElement[] = [];
				const children = Array.from(svg.childNodes);
				for (const node of children) {
					if (node.nodeType !== Node.ELEMENT_NODE) continue;
					const el = node as Element;
					if (el.tagName === "defs" || el.tagName === "style") continue;
					if (isStructuralLayer(el)) continue;
					if (el.tagName === "image") continue;
					if (el.tagName === "rect") {
						if (el.getAttribute("data-dims-bg") === "true") {
							toDims.push(el);
						} else {
							toMask.push(el as SVGRectElement);
						}
						continue;
					}
					toDims.push(el);
				}
				for (const el of toDims) refGroup.appendChild(el);
				const maskGroup = getMaskRectsGroup(svg);
				for (const rect of toMask) {
					normalizeMaskRect(rect);
					maskGroup.appendChild(rect);
				}

				const maskRectCount = maskGroup.querySelectorAll("rect").length;
				const vb = svg.viewBox.baseVal;
				if (
					!isCombined &&
					maskRectCount === 0 &&
					vb.width > 0 &&
					vb.height > 0
				) {
					const bg = document.createElementNS(SVG_NS, "rect");
					bg.setAttribute("data-dims-bg", "true");
					bg.setAttribute("x", String(vb.x));
					bg.setAttribute("y", String(vb.y));
					bg.setAttribute("width", String(vb.width));
					bg.setAttribute("height", String(vb.height));
					bg.setAttribute("fill", "#000000");
					refGroup.insertBefore(bg, refGroup.firstChild);
				}

				svg.insertBefore(refGroup, svg.querySelector("#mask-rects"));
			}

			svg.setAttribute("data-dims-reference", isDims ? "true" : "false");
			svg.setAttribute(
				"data-mask-editor-bundle",
				isCombined ? "true" : "false",
			);

			const dimsHint = document.getElementById("dims-reference-hint");
			if (dimsHint) {
				dimsHint.style.display = isDims && !isCombined ? "block" : "none";
			}

			const maskRectCount =
				svg.querySelector("#mask-rects")?.querySelectorAll("rect").length ?? 0;
			if (maskRectCount > 0) {
				svg.querySelectorAll("style").forEach((styleEl) => {
					if (/rect\s*\{[^}]*fill\s*:\s*black/i.test(styleEl.textContent || "")) {
						styleEl.remove();
					}
				});
			}

			ensureInteractionPlane(svg);
			ensureOverlayLayerOrder(svg);

			svg.setAttribute("data-mask-editor-prepared", "true");
		}

		function resetDimsReferenceHint() {
			const dimsHint = document.getElementById("dims-reference-hint");
			if (dimsHint) dimsHint.style.display = "none";
		}

		function getBrushMode() {
			const auto = document.getElementById("brush-auto") as HTMLInputElement | null;
			return auto?.checked ? "auto" : "manual";
		}

		function getAutoPaddingSvg() {
			const el = document.getElementById("auto-padding") as HTMLInputElement | null;
			const v = parseFloat(el?.value ?? "0");
			return Number.isFinite(v) ? Math.max(0, v) : 0;
		}

		function updateBrushPaddingVisibility() {
			const row = document.getElementById("auto-padding-row");
			const auto = document.getElementById("brush-auto") as HTMLInputElement | null;
			if (row && auto) row.style.display = auto.checked ? "block" : "none";
		}

		function clientPointToSvgCoords(svg: SVGSVGElement, clientX: number, clientY: number) {
			const pt = svg.createSVGPoint();
			pt.x = clientX;
			pt.y = clientY;
			const m = svg.getScreenCTM();
			if (!m) return null;
			const p = pt.matrixTransform(m.inverse());
			return { x: p.x, y: p.y };
		}

		function svgPointToClient(svg: SVGSVGElement, vx: number, vy: number) {
			const pt = svg.createSVGPoint();
			pt.x = vx;
			pt.y = vy;
			const m = svg.getScreenCTM();
			if (!m) return null;
			const p = pt.matrixTransform(m);
			return { x: p.x, y: p.y };
		}

		function svgRectToClientRect(svg: SVGSVGElement, x: number, y: number, w: number, h: number) {
			const c1 = svgPointToClient(svg, x, y);
			const c2 = svgPointToClient(svg, x + w, y);
			const c3 = svgPointToClient(svg, x, y + h);
			const c4 = svgPointToClient(svg, x + w, y + h);
			if (!c1 || !c2 || !c3 || !c4) {
				return { left: 0, top: 0, width: 0, height: 0 };
			}
			const xs = [c1.x, c2.x, c3.x, c4.x];
			const ys = [c1.y, c2.y, c3.y, c4.y];
			const left = Math.min(...xs);
			const right = Math.max(...xs);
			const top = Math.min(...ys);
			const bottom = Math.max(...ys);
			return { left, top, width: right - left, height: bottom - top };
		}

		function intersectClientRects(
			a: { left: number; top: number; width: number; height: number },
			b: DOMRect | { left: number; top: number; width: number; height: number },
		) {
			const ax2 = a.left + a.width;
			const ay2 = a.top + a.height;
			const bx2 = b.left + b.width;
			const by2 = b.top + b.height;
			const left = Math.max(a.left, b.left);
			const top = Math.max(a.top, b.top);
			const right = Math.min(ax2, bx2);
			const bottom = Math.min(ay2, by2);
			const width = right - left;
			const height = bottom - top;
			if (width <= 0 || height <= 0) return null;
			return { left, top, width, height };
		}

		function rasterPixelToClient(
			screenEl: Element,
			nw: number,
			nh: number,
			px: number,
			py: number,
		) {
			const r = screenEl.getBoundingClientRect();
			return {
				x: r.left + (px / nw) * r.width,
				y: r.top + (py / nh) * r.height,
			};
		}

		function imagePixelToClient(img: HTMLImageElement, px: number, py: number) {
			const nw = img.naturalWidth || img.width;
			const nh = img.naturalHeight || img.height;
			return rasterPixelToClient(img, nw, nh, px, py);
		}

		function imageBBoxToSvgRect(
			svg: SVGSVGElement,
			img: HTMLImageElement,
			px0: number,
			py0: number,
			px1: number,
			py1: number,
			screenEl?: Element | null,
		) {
			const nw = img.naturalWidth || img.width;
			const nh = img.naturalHeight || img.height;
			const mapEl = screenEl || img;
			const corners = [
				rasterPixelToClient(mapEl, nw, nh, px0, py0),
				rasterPixelToClient(mapEl, nw, nh, px1, py0),
				rasterPixelToClient(mapEl, nw, nh, px0, py1),
				rasterPixelToClient(mapEl, nw, nh, px1, py1),
			];
			let minSx = Infinity,
				minSy = Infinity,
				maxSx = -Infinity,
				maxSy = -Infinity;
			for (const c of corners) {
				const p = clientPointToSvgCoords(svg, c.x, c.y);
				if (!p) continue;
				minSx = Math.min(minSx, p.x);
				minSy = Math.min(minSy, p.y);
				maxSx = Math.max(maxSx, p.x);
				maxSy = Math.max(maxSy, p.y);
			}
			if (!Number.isFinite(minSx)) return null;
			return { x: minSx, y: minSy, width: maxSx - minSx, height: maxSy - minSy };
		}

		const AUTO_RGB_THRESHOLD = 12;

		function isAutoBrightPixel(
			data: Uint8ClampedArray,
			width: number,
			x: number,
			y: number,
		) {
			const i = (y * width + x) * 4;
			return (
				data[i] > AUTO_RGB_THRESHOLD ||
				data[i + 1] > AUTO_RGB_THRESHOLD ||
				data[i + 2] > AUTO_RGB_THRESHOLD
			);
		}

		/** Full union bbox of all bright pixels in the crop. */
		function findRgbContentBBox(imageData: ImageData) {
			const d = imageData.data;
			const w = imageData.width;
			const h = imageData.height;
			let minX = w,
				minY = h,
				maxX = -1,
				maxY = -1;
			for (let y = 0; y < h; y++) {
				for (let x = 0; x < w; x++) {
					if (!isAutoBrightPixel(d, w, x, y)) continue;
					if (x < minX) minX = x;
					if (y < minY) minY = y;
					if (x > maxX) maxX = x;
					if (y > maxY) maxY = y;
				}
			}
			if (maxX < minX) return null;
			return { minX, minY, maxX: maxX + 1, maxY: maxY + 1 };
		}

		/**
		 * Shrink-wrap the bright blob under the drag box center (one label),
		 * not every disconnected line in a loose rubber band.
		 */
		function findRgbContentBBoxNearCenter(imageData: ImageData) {
			const d = imageData.data;
			const w = imageData.width;
			const h = imageData.height;
			if (w < 1 || h < 1) return null;

			const cx = Math.floor(w / 2);
			const cy = Math.floor(h / 2);

			function findSeed() {
				if (isAutoBrightPixel(d, w, cx, cy)) return { x: cx, y: cy };
				const maxR = Math.max(w, h);
				for (let r = 1; r < maxR; r++) {
					for (let dx = -r; dx <= r; dx++) {
						for (const dy of [-r, r]) {
							const x = cx + dx;
							const y = cy + dy;
							if (x < 0 || y < 0 || x >= w || y >= h) continue;
							if (isAutoBrightPixel(d, w, x, y)) return { x, y };
						}
					}
					for (let dy = -r + 1; dy <= r - 1; dy++) {
						for (const x of [cx - r, cx + r]) {
							const y = cy + dy;
							if (x < 0 || y < 0 || x >= w || y >= h) continue;
							if (isAutoBrightPixel(d, w, x, y)) return { x, y };
						}
					}
				}
				return null;
			}

			const seed = findSeed();
			if (!seed) return findRgbContentBBox(imageData);

			const visited = new Uint8Array(w * h);
			const stack: [number, number][] = [[seed.x, seed.y]];
			let minX = seed.x,
				minY = seed.y,
				maxX = seed.x,
				maxY = seed.y;
			visited[seed.y * w + seed.x] = 1;

			while (stack.length > 0) {
				const [x, y] = stack.pop()!;
				if (x < minX) minX = x;
				if (y < minY) minY = y;
				if (x > maxX) maxX = x;
				if (y > maxY) maxY = y;
				for (const [nx, ny] of [
					[x + 1, y],
					[x - 1, y],
					[x, y + 1],
					[x, y - 1],
				]) {
					if (nx < 0 || ny < 0 || nx >= w || ny >= h) continue;
					const idx = ny * w + nx;
					if (visited[idx]) continue;
					if (!isAutoBrightPixel(d, w, nx, ny)) continue;
					visited[idx] = 1;
					stack.push([nx, ny]);
				}
			}

			return { minX, minY, maxX: maxX + 1, maxY: maxY + 1 };
		}

		async function finalizeRubberBandRect(
			svg: SVGSVGElement,
			x: number,
			y: number,
			width: number,
			height: number,
		) {
			const pad = getBrushMode() === "auto" ? getAutoPaddingSvg() : 0;
			let fx = x,
				fy = y,
				fw = width,
				fh = height;

			if (getBrushMode() === "auto") {
				const img = await resolveAutoBrushRasterImage(svg);
				const pixels = img
					? rubberBandSvgToImagePixels(svg, img, x, y, width, height)
					: null;
				if (pixels) {
					const { ix0, iy0, ix1, iy1 } = pixels;
					const iw = ix1 - ix0;
					const ih = iy1 - iy0;
					const canvas = document.createElement("canvas");
					canvas.width = iw;
					canvas.height = ih;
					const ctx = canvas.getContext("2d");
					if (ctx) {
						ctx.drawImage(img, ix0, iy0, iw, ih, 0, 0, iw, ih);
						let imageData: ImageData | null = null;
						try {
							imageData = ctx.getImageData(0, 0, iw, ih);
						} catch (err) {
							console.warn(
								"Auto brush could not read pixels (image may be cross-origin):",
								err,
							);
							imageData = null;
						}
						if (imageData && imageData.width > 0 && imageData.height > 0) {
							const bbox = findRgbContentBBoxNearCenter(imageData);
							if (bbox) {
								const mapped = imagePixelRectToSvgRect(
									svg,
									img,
									ix0 + bbox.minX,
									iy0 + bbox.minY,
									ix0 + bbox.maxX,
									iy0 + bbox.maxY,
								);
								if (mapped.width > 1 && mapped.height > 1) {
									fx = mapped.x;
									fy = mapped.y;
									fw = mapped.width;
									fh = mapped.height;
								}
							}
						}
					}
				} else if (!img) {
					console.warn(
						"Auto brush needs a PNG/JPEG backplate (or combined floorplan import) aligned with the overlay.",
					);
				}
			}

			if (pad > 0) {
				fx -= pad;
				fy -= pad;
				fw += pad * 2;
				fh += pad * 2;
			}

			const minDim = 4;
			if (fw < minDim || fh < minDim) return;

			const newRect = document.createElementNS("http://www.w3.org/2000/svg", "rect");
			newRect.setAttribute("x", fx.toString());
			newRect.setAttribute("y", fy.toString());
			newRect.setAttribute("width", fw.toString());
			newRect.setAttribute("height", fh.toString());
			newRect.setAttribute("fill", "rgba(0, 123, 255, 0.3)");
			newRect.setAttribute("stroke", "#007bff");
			newRect.setAttribute("stroke-width", "2");
			appendMaskRect(svg, newRect);
			addRectEventListeners(newRect);
			selectRect(newRect);
		}

		function cancelRubberBandDraw() {
			if (rubberBandPreview && rubberBandPreview.parentNode) {
				rubberBandPreview.parentNode.removeChild(rubberBandPreview);
			}
			rubberBandPreview = null;
			rubberBandSvg = null;
			isRubberBandDrawing = false;
			document.removeEventListener("mousemove", onRubberBandMouseMove);
			document.removeEventListener("mouseup", onRubberBandMouseUp);
			document.body.style.cursor = "";
		}

		function onRubberBandMouseMove(e: MouseEvent) {
			if (!isRubberBandDrawing || !rubberBandSvg || !rubberBandPreview) return;
			const cur = clientPointToSvgCoords(rubberBandSvg, e.clientX, e.clientY);
			if (!cur) return;
			const rx = Math.min(rubberBandStart.x, cur.x);
			const ry = Math.min(rubberBandStart.y, cur.y);
			const rw = Math.abs(cur.x - rubberBandStart.x);
			const rh = Math.abs(cur.y - rubberBandStart.y);
			const minDragClear = 3;
			if (selectedRect && Math.max(rw, rh) >= minDragClear) {
				deselectRect();
			}
			rubberBandPreview.setAttribute("x", rx.toString());
			rubberBandPreview.setAttribute("y", ry.toString());
			rubberBandPreview.setAttribute("width", Math.max(1, rw).toString());
			rubberBandPreview.setAttribute("height", Math.max(1, rh).toString());
		}

		function onRubberBandMouseUp(e: MouseEvent) {
			if (!isRubberBandDrawing || !rubberBandSvg || !rubberBandPreview) {
				cancelRubberBandDraw();
				return;
			}
			const svg = rubberBandSvg;
			const cur = clientPointToSvgCoords(svg, e.clientX, e.clientY);
			const rx0 = rubberBandStart.x;
			const ry0 = rubberBandStart.y;
			const rx1 = cur ? cur.x : rx0;
			const ry1 = cur ? cur.y : ry0;
			let x = Math.min(rx0, rx1);
			let y = Math.min(ry0, ry1);
			let w = Math.abs(rx1 - rx0);
			let h = Math.abs(ry1 - ry0);

			if (rubberBandPreview.parentNode) {
				rubberBandPreview.parentNode.removeChild(rubberBandPreview);
			}
			rubberBandPreview = null;
			rubberBandSvg = null;
			isRubberBandDrawing = false;
			document.removeEventListener("mousemove", onRubberBandMouseMove);
			document.removeEventListener("mouseup", onRubberBandMouseUp);
			document.body.style.cursor = "";

			const minDrag = 3;
			if (w < minDrag || h < minDrag) return;

			suppressBackgroundClickDeselect = true;
			void finalizeRubberBandRect(svg, x, y, w, h).finally(() => {
				setTimeout(() => {
					suppressBackgroundClickDeselect = false;
				}, 0);
			});
		}

		function startRubberBandDraw(e: MouseEvent, svg: SVGSVGElement) {
			const coords = clientPointToSvgCoords(svg, e.clientX, e.clientY);
			if (!coords) return;
			isRubberBandDrawing = true;
			rubberBandSvg = svg;
			rubberBandStart.x = coords.x;
			rubberBandStart.y = coords.y;

			rubberBandPreview = document.createElementNS("http://www.w3.org/2000/svg", "rect");
			rubberBandPreview.setAttribute("x", coords.x.toString());
			rubberBandPreview.setAttribute("y", coords.y.toString());
			rubberBandPreview.setAttribute("width", "1");
			rubberBandPreview.setAttribute("height", "1");
			rubberBandPreview.setAttribute("fill", "rgba(0, 200, 255, 0.15)");
			rubberBandPreview.setAttribute("stroke", "#00bcd4");
			rubberBandPreview.setAttribute("stroke-width", "1");
			rubberBandPreview.setAttribute("stroke-dasharray", "4 3");
			rubberBandPreview.setAttribute("pointer-events", "none");
			rubberBandPreview.classList.add("rubber-band-preview");
			svg.appendChild(rubberBandPreview);

			document.body.style.cursor = "crosshair";
			document.addEventListener("mousemove", onRubberBandMouseMove);
			document.addEventListener("mouseup", onRubberBandMouseUp);
		}

		// Create new SVG element
		var createNewSVG = () => {
			const newSVG = document.createElementNS(SVG_NS, "svg");
			newSVG.style.width = "100%";
			newSVG.style.height = "100%";
			newSVG.setAttribute("viewBox", "0 0 4096 4096");
			newSVG.setAttribute("xmlns:xlink", "http://www.w3.org/1999/xlink");
			newSVG.setAttribute("preserveAspectRatio", "xMidYMid meet");
			getMaskRectsGroup(newSVG);
			newSVG.setAttribute("data-mask-editor-prepared", "true");
			return newSVG;
		};

		// Basic zoom and pan functionality
		const scalableCanvas = document.getElementById("scalable-canvas");
		const svgContainer = document.getElementById("svg-container");

		let isPanning = false;
		let startX, startY;
		let translateX = 0, translateY = 0;
		let scale = 1;

		// Handle zooming with the mouse wheel
		scalableCanvas.addEventListener("wheel", (e) => {
			e.preventDefault();
			scale -= e.deltaY / 1000;
			scale = Math.max(1.0, Math.min(scale, 10)); // Minimum scale of 1.0 (100%)
			
			if (scale > 1.2) {
				svgContainer.style.transform = `scale(${scale}) translate(${translateX}px, ${translateY}px)`;
			} else {
				translateX = 0;
				translateY = 0;
				svgContainer.style.transform = `scale(${scale}) translate(${translateX}px, ${translateY}px)`;
			}
		});

		// Handle panning - check in bubble phase after rect handlers have had a chance
		scalableCanvas.addEventListener("mousedown", (e) => {
			// If event was stopped by a rect handler, don't pan
			if (e.defaultPrevented) {
				return;
			}
			
			const target = e.target as HTMLElement;
			
			// First check: if clicking directly on a mask rect, don't pan
			if (target && target.tagName === 'rect' && !target.closest('#dims-reference')) {
				return;
			}
			
			// Second check: if clicking on transform handles
			if (target && (target.classList?.contains('transform-handle') || 
			    target.closest('.transform-handle') ||
			    target.closest('.transform-group'))) {
				return;
			}
			
			// Third check: if clicking inside SVG, check if it's on a rect
			const svg = target?.closest('svg');
			if (svg) {
				// Check if the actual target or any parent is a rect
				let checkElement = target;
				while (checkElement && checkElement !== svg) {
					if (
						checkElement.tagName === "rect" &&
						!checkElement.closest("#dims-reference")
					) {
						return;
					}
					checkElement = checkElement.parentElement as HTMLElement;
				}
			}
			
			// Don't start panning if already dragging/resizing/duplicating/rubber-band draw
			if (isDragging || isResizing || isDuplicating || isRubberBandDrawing) {
				return;
			}
			
			// Only start panning if clicking on the canvas background
			isPanning = true;
			startX = e.clientX - translateX;
			startY = e.clientY - translateY;
			scalableCanvas.style.cursor = "grabbing";
		}, false); // Use bubble phase so rect handlers (in capture) can stop it first

		scalableCanvas.addEventListener("mousemove", (e) => {
			if (!isPanning || isDragging || isResizing || isDuplicating || isRubberBandDrawing) return;
			translateX = e.clientX - startX;
			translateY = e.clientY - startY;
			svgContainer.style.transform = `scale(${scale}) translate(${translateX}px, ${translateY}px)`;
		});

		scalableCanvas.addEventListener("mouseup", () => {
			isPanning = false;
			scalableCanvas.style.cursor = "default";
		});

		scalableCanvas.addEventListener("mouseleave", () => {
			isPanning = false;
		});

		function readFileAsText(file: File): Promise<string> {
			return new Promise((resolve, reject) => {
				const reader = new FileReader();
				reader.onload = () => resolve(reader.result as string);
				reader.onerror = () => reject(reader.error);
				reader.readAsText(file);
			});
		}

		function parseSvgFile(text: string): SVGSVGElement {
			const parser = new DOMParser();
			const svgDoc = parser.parseFromString(text, "image/svg+xml");
			if (svgDoc.querySelector("parsererror")) {
				throw new Error("Could not parse SVG file. Check that it is valid XML.");
			}
			return svgDoc.documentElement as unknown as SVGSVGElement;
		}

		function displayImportedOverlay(
			element: SVGSVGElement,
			fileName: string,
			bundleMeta?: BundleSourceMeta,
		) {
			if (!importedSVGs.some((e) => e.element === element)) {
				importedSVGs.push({ name: fileName, element, bundleMeta });
			}
			setActiveBundleMeta(bundleMeta ?? null);
			if (bundleMeta) {
				setBackgroundFromDataUrl(bundleMeta.canonicalMergedDataUrl);
			}
			displaySVG(element);
			wireSvgInteractions(element);
			updateExportButtonsVisibility();
			const rectCount = getContentRects(element).length;
			console.log(`Imported "${fileName}" with ${rectCount} mask rectangle(s).`);
			if (rectCount === 0 && bundleMeta) {
				console.warn(
					`No mask rectangles found. Drop the companion *_mask.svg together with the combined floorplan SVG.`,
				);
			}
			updateCurrentFileName(fileName);
			if (importedSVGs.length > 1) createSVGNavigation();
		}

		// File handling functionality
		async function handleFileChange(files) {
			if (!files || files.length === 0) return;

			const svgFiles: File[] = [];
			const imageFiles: File[] = [];

			Array.from(files).forEach((file) => {
				if (file instanceof File && file.type === "image/svg+xml") {
					svgFiles.push(file);
				} else if (file instanceof File && file.type.startsWith("image/")) {
					imageFiles.push(file);
				}
			});

			if (svgFiles.length > 0) {
				globalSvgContainer.innerHTML = "";
				backplateRasterDataUrl = null;
				importedSVGs = [];
				currentSVGIndex = 0;
				resetDimsReferenceHint();
				setActiveBundleMeta(null);
				document.getElementById("svg-nav")?.remove();

				const placeholder = document.createElement("p");
				placeholder.textContent = "Loading floorplan…";
				placeholder.style.padding = "2em";
				globalSvgContainer.appendChild(placeholder);

				try {
					let bundleOverlay: SVGSVGElement | null = null;
					let bundleMeta: BundleSourceMeta | null = null;
					let bundleFileName = "";
					const maskSvgs: SVGSVGElement[] = [];
					const standardSvgs: { file: File; svg: SVGSVGElement }[] = [];

					for (const file of svgFiles) {
						const svgElement = parseSvgFile(await readFileAsText(file));
						if (isCombinedBundleSvg(svgElement, file.name)) {
							const converted = await convertBundleToEditMode(svgElement, file.name);
							bundleOverlay = converted.overlay;
							bundleMeta = converted.meta;
							bundleFileName = file.name;
						} else if (isMaskOverlaySvg(svgElement, file.name)) {
							maskSvgs.push(svgElement);
						} else {
							standardSvgs.push({ file, svg: svgElement });
						}
					}

					if (bundleOverlay && bundleMeta) {
						for (const maskSvg of maskSvgs) {
							importMaskRectsOntoOverlay(bundleOverlay, maskSvg);
						}
						displayImportedOverlay(bundleOverlay, bundleFileName, bundleMeta);
					} else if (maskSvgs.length > 0) {
						const maskSvg = maskSvgs[0];
						const maskFile =
							svgFiles.find((f) => /_mask\.svg$/i.test(f.name)) || svgFiles[0];
						prepareImportedSvg(maskSvg, maskFile.name);
						for (let i = 1; i < maskSvgs.length; i++) {
							importMaskRectsOntoOverlay(maskSvg, maskSvgs[i]);
						}
						ensureOverlayLayerOrder(maskSvg);
						displayImportedOverlay(maskSvg, maskFile.name);
					} else if (standardSvgs.length > 0) {
						for (let i = 0; i < standardSvgs.length; i++) {
							const { file, svg } = standardSvgs[i];
							prepareImportedSvg(svg, file.name);
							ensureInteractionPlane(svg);
							if (i === 0) displayImportedOverlay(svg, file.name);
							else importedSVGs.push({ name: file.name, element: svg });
						}
						if (standardSvgs.length > 1) createSVGNavigation();
					}
				} catch (err) {
					console.error(err);
					alert(
						`Failed to import file.\n\n${err instanceof Error ? err.message : String(err)}`,
					);
				}
			}

			if (imageFiles.length > 0 && !bundleSourceMeta) {
				handleImageFile(imageFiles[0]);
				if (imageFiles.length > 1) {
					console.log(
						`Multiple images detected. Using "${imageFiles[0].name}" as background.`,
					);
				}
			}
		}

		function handleImageFile(file) {
			if (bundleSourceMeta) {
				console.log(
					`Merged floorplan already loaded from bundle; ignoring separate image "${file.name}".`,
				);
				return;
			}

			const reader = new FileReader();
			reader.onload = (event) => {
				setActiveBundleMeta(null);
				setBackgroundFromDataUrl(event.target?.result as string, 0.7);

				const img = globalSvgContainer.querySelector(
					"#background-image-container img",
				) as HTMLImageElement | null;
				if (img) {
					const finishRasterLoad = () => {
						ensureSvgOverlayForRaster(img, file);
						const nw = img.naturalWidth;
						const nh = img.naturalHeight;
						const svg = globalSvgContainer.querySelector(
							"svg",
						) as SVGSVGElement | null;
						if (svg && nw > 0 && nh > 0) {
							svg.setAttribute("viewBox", `0 0 ${nw} ${nh}`);
						}
					};
					if (img.complete) finishRasterLoad();
					else img.onload = finishRasterLoad;
				}

				console.log("Background image added underneath SVG");
			};
			reader.readAsDataURL(file);
		}

		function wireSvgInteractions(svgElement: SVGSVGElement) {
			// Prevent all drag behavior on the SVG and its children - COMPREHENSIVE APPROACH
			svgElement.setAttribute('draggable', 'false');
			svgElement.style.userSelect = 'none';
			svgElement.style.webkitUserSelect = 'none';
			svgElement.style.webkitUserDrag = 'none';
			svgElement.style.webkitTouchCallout = 'none';
			svgElement.style.webkitTapHighlightColor = 'transparent';

			// Prevent context menu which can trigger drag
			svgElement.addEventListener('contextmenu', (e) => {
				e.preventDefault();
				return false;
			});

			// Add comprehensive drag prevention to SVG - capture phase
			svgElement.addEventListener('dragstart', (e) => {
				console.log('SVG dragstart prevented');
				e.preventDefault();
				e.stopImmediatePropagation();
				return false;
			}, true);

			svgElement.addEventListener('drag', (e) => {
				e.preventDefault();
				e.stopImmediatePropagation();
				return false;
			}, true);

			svgElement.addEventListener('dragover', (e) => {
				e.stopPropagation();
			});

			// Prevent mousedown from starting drag - but don't interfere with rect clicks
			svgElement.addEventListener('mousedown', (e) => {
				const t = e.target as Element;
				if (t.closest("#mask-rects")) return;
				if (t.id === "interaction-plane") return;
				if (t.tagName === "rect" && !t.closest("#dims-reference")) return;
				if (e.target !== svgElement) {
					e.preventDefault();
				}
			}, true);

			// Add event listeners to mask rect elements only (not dim reference background)
			const rects = getContentRects(svgElement);
			console.log(`Found ${rects.length} mask rect elements`);

			rects.forEach((rect, index) => {
				// Log rect coordinates for debugging
				const x = rect.getAttribute('x');
				const y = rect.getAttribute('y');
				const width = rect.getAttribute('width');
				const height = rect.getAttribute('height');
				console.log(`Rect ${index}: x=${x}, y=${y}, width=${width}, height=${height}`);

				// Ensure rect has stroke for selection visibility
				if (!rect.getAttribute('stroke')) {
					rect.setAttribute('stroke', '#007bff');
				}
				if (!rect.getAttribute('stroke-width')) {
					rect.setAttribute('stroke-width', '2');
				}

				// Add event listeners using the reusable function
				addRectEventListeners(rect);
			});

			svgElement.addEventListener(
				"mousedown",
				(e) => {
					if (e.button !== 0) return;
					if (!isSvgBackgroundHit(e.target, svgElement)) return;
					if (isAddRectMode) return;
					if (isDragging || isResizing || isDuplicating) return;
					if (isRubberBandDrawing) return;
					e.preventDefault();
					e.stopPropagation();
					startRubberBandDraw(e, svgElement);
				},
				false,
			);

			// Deselect when clicking on SVG background or handle Add Rectangle mode
			svgElement.addEventListener('click', (e) => {
				if (!isSvgBackgroundHit(e.target, svgElement)) return;
				if (suppressBackgroundClickDeselect) return;
				if (isAddRectMode && !isDrawingRect) {
					addRectangleAtPosition(e, svgElement);
				} else {
					deselectRect();
				}
			});
		}

		function ensureSvgOverlayForRaster(img: HTMLImageElement, sourceFile?: File) {
			let svg = globalSvgContainer.querySelector("svg") as SVGSVGElement | null;
			if (svg) return;

			const nw = img.naturalWidth || 4096;
			const nh = img.naturalHeight || 4096;
			const newSvg = createNewSVG();
			newSvg.setAttribute("viewBox", `0 0 ${nw} ${nh}`);
			ensureInteractionPlane(newSvg);
			globalSvgContainer.appendChild(newSvg);
			wireSvgInteractions(newSvg);
			updateExportButtonsVisibility();

			if (sourceFile && importedSVGs.length === 0) {
				const base = sourceFile.name.replace(/\.[^.]+$/, "");
				updateCurrentFileName(base.length ? base : "mask");
			}
		}

		function displaySVG(svgElement) {
			const svg = svgElement as SVGSVGElement;
			if (svg.getAttribute("data-mask-editor-prepared") !== "true") {
				prepareImportedSvg(svg);
			}

			const isConverted =
				svg.getAttribute("data-converted-from-bundle") === "true";
			const backgroundContainer = document.getElementById(
				"background-image-container",
			);
			let backgroundHTML = "";
			if (backgroundContainer) {
				backgroundHTML = backgroundContainer.outerHTML;
			}

			globalSvgContainer.innerHTML = "";

			if (backgroundHTML) {
				globalSvgContainer.innerHTML = backgroundHTML;
				globalSvgContainer.style.position = "relative";
			} else if (isConverted && bundleSourceMeta) {
				setBackgroundFromDataUrl(bundleSourceMeta.canonicalMergedDataUrl);
			}
			
			svgElement.style.width = "100%";
			svgElement.style.height = "100%";
			
			// Check and preserve original viewBox
			const originalViewBox = svgElement.getAttribute('viewBox');
			console.log('Original SVG viewBox:', originalViewBox);
			
			// Only set default viewBox if none exists
			if (!originalViewBox) {
				svgElement.setAttribute("viewBox", "0 0 4096 4096");
				console.log('Set default viewBox: 0 0 4096 4096');
				} else {
				console.log('Preserving original viewBox:', originalViewBox);
			}
			
			ensureInteractionPlane(svg);
			ensureOverlayLayerOrder(svg);
			globalSvgContainer.appendChild(svgElement);
		}

		function createSVGNavigation() {
			let navContainer = document.getElementById("svg-nav");
			if (!navContainer) {
				navContainer = document.createElement("div");
				navContainer.id = "svg-nav";
				navContainer.style.display = "flex";
				navContainer.style.justifyContent = "center";
				navContainer.style.marginTop = "1em";
				navContainer.style.gap = "1em";

				const leftArrow = document.createElement("button");
				leftArrow.innerHTML = "← Previous";
				leftArrow.style.padding = "0.5em 1em";
				leftArrow.addEventListener("click", () => {
					if (currentSVGIndex > 0) {
						currentSVGIndex--;
						const entry = importedSVGs[currentSVGIndex];
						setActiveBundleMeta(entry.bundleMeta);
						if (entry.bundleMeta) {
							setBackgroundFromDataUrl(entry.bundleMeta.canonicalMergedDataUrl);
						}
						displaySVG(entry.element);
						wireSvgInteractions(entry.element);
						updateCurrentFileName(entry.name);
						updateCounter();
					}
				});

				const rightArrow = document.createElement("button");
				rightArrow.innerHTML = "Next →";
				rightArrow.style.padding = "0.5em 1em";
				rightArrow.addEventListener("click", () => {
					if (currentSVGIndex < importedSVGs.length - 1) {
						currentSVGIndex++;
						const entry = importedSVGs[currentSVGIndex];
						setActiveBundleMeta(entry.bundleMeta);
						if (entry.bundleMeta) {
							setBackgroundFromDataUrl(entry.bundleMeta.canonicalMergedDataUrl);
						}
						displaySVG(entry.element);
						wireSvgInteractions(entry.element);
						updateCurrentFileName(entry.name);
						updateCounter();
					}
				});

				const counter = document.createElement("span");
				counter.id = "svg-counter";
				counter.style.padding = "0.5em";

				navContainer.appendChild(leftArrow);
				navContainer.appendChild(counter);
				navContainer.appendChild(rightArrow);

				globalSvgContainer.parentNode.insertBefore(navContainer, globalSvgContainer.nextSibling);
			}
			
			updateCounter();
		}

		function updateCounter() {
			const counter = document.getElementById("svg-counter");
			if (counter) {
				counter.textContent = `${currentSVGIndex + 1} / ${importedSVGs.length}`;
			}
		}

		// Function to update current filename for export
		function updateCurrentFileName(filename) {
			// Remove the .svg extension to get the base name
			const baseName = filename.replace(/\.svg$/i, '');
			currentFileName = baseName;
			
			// Update the export filename input
			const exportInput = document.getElementById('export-filename') as HTMLInputElement;
			if (exportInput) {
				exportInput.value = baseName;
			}
		}

		// Rect selection and transform functionality
		function focusEditorCanvas() {
			const canvas = document.getElementById("scalable-canvas") as HTMLElement | null;
			canvas?.focus({ preventScroll: true });
		}

		function selectRect(rect) {
			// Deselect previous rect
			deselectRect();
			
			selectedRect = rect;
			rect.classList.add('rect-selected');
			focusEditorCanvas();
			
			console.log('Rect selected:', selectedRect);
			
			// Create transform handles
			createTransformHandles(rect);
			
			// Update properties panel
			updatePropertiesPanel(rect);
		}

		function deselectRect() {
			if (selectedRect) {
				selectedRect.classList.remove('rect-selected');
				selectedRect = null;
			}
			
			// Remove existing transform handles
			const existingHandles = document.querySelector('.transform-group');
			if (existingHandles) {
				existingHandles.remove();
			}
			
			// Clear snap guides
			clearSnapGuides();
			
			// Update properties panel
			updatePropertiesPanel(null);
		}

		function createTransformHandles(rect) {
			const svg = rect.closest('svg');
			if (!svg) return;
			
			const x = parseFloat(rect.getAttribute('x') || '0');
			const y = parseFloat(rect.getAttribute('y') || '0');
			const width = parseFloat(rect.getAttribute('width') || '0');
			const height = parseFloat(rect.getAttribute('height') || '0');
			
			// Create transform group
			const transformGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
			transformGroup.classList.add('transform-group');
			
			// Corner handle positions
			const cornerHandles = [
				{ id: 'nw', x: x, y: y, cursor: 'nw-resize', type: 'corner' },
				{ id: 'ne', x: x + width, y: y, cursor: 'ne-resize', type: 'corner' },
				{ id: 'sw', x: x, y: y + height, cursor: 'sw-resize', type: 'corner' },
				{ id: 'se', x: x + width, y: y + height, cursor: 'se-resize', type: 'corner' }
			];
			
			// Edge handle positions
			const edgeHandles = [
				{ id: 'n', x: x + width/2, y: y, cursor: 'n-resize', type: 'edge' },
				{ id: 'e', x: x + width, y: y + height/2, cursor: 'e-resize', type: 'edge' },
				{ id: 's', x: x + width/2, y: y + height, cursor: 's-resize', type: 'edge' },
				{ id: 'w', x: x, y: y + height/2, cursor: 'w-resize', type: 'edge' }
			];
			
			// Combine all handles
			const allHandles = [...cornerHandles, ...edgeHandles];
			
			allHandles.forEach(handle => {
				let handleElement;
				
				if (handle.type === 'corner') {
					// Corner handles as circles
					handleElement = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
					handleElement.setAttribute('cx', handle.x.toString());
					handleElement.setAttribute('cy', handle.y.toString());
					handleElement.setAttribute('r', '4');
				} else {
					// Edge handles as thin lines spanning full width/height
					handleElement = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
					if (handle.id === 'n' || handle.id === 's') {
						// Horizontal edge handles - span full width
						handleElement.setAttribute('x', x.toString());
						handleElement.setAttribute('y', (handle.y - 1).toString());
						handleElement.setAttribute('width', width.toString());
						handleElement.setAttribute('height', '2');
					} else {
						// Vertical edge handles - span full height
						handleElement.setAttribute('x', (handle.x - 1).toString());
						handleElement.setAttribute('y', y.toString());
						handleElement.setAttribute('width', '2');
						handleElement.setAttribute('height', height.toString());
					}
				}
				
				// Apply styling directly to SVG element
				handleElement.setAttribute('fill', 'white');
				if (handle.type === 'corner') {
					handleElement.setAttribute('stroke', '#666');
					handleElement.setAttribute('stroke-width', '2');
				} else {
					// Edge handles get thinner gray outline
					handleElement.setAttribute('stroke', '#999');
					handleElement.setAttribute('stroke-width', '1');
				}
				handleElement.setAttribute('opacity', '0.9');
				handleElement.style.cursor = handle.cursor;
				handleElement.style.pointerEvents = 'all';
				
				handleElement.classList.add('transform-handle', handle.cursor);
				handleElement.dataset.handleId = handle.id;
				handleElement.dataset.handleType = handle.type;
				
				// Add hover effects with JavaScript
				handleElement.addEventListener('mouseenter', () => {
					handleElement.setAttribute('fill', '#f8f8f8');
					if (handle.type === 'corner') {
						handleElement.setAttribute('stroke', '#333');
					} else {
						handleElement.setAttribute('stroke', '#666');
					}
					handleElement.setAttribute('opacity', '1');
				});
				
				handleElement.addEventListener('mouseleave', () => {
					handleElement.setAttribute('fill', 'white');
					if (handle.type === 'corner') {
						handleElement.setAttribute('stroke', '#666');
					} else {
						handleElement.setAttribute('stroke', '#999');
					}
					handleElement.setAttribute('opacity', '0.9');
				});
				
				// Add resize event listeners
				handleElement.addEventListener('mousedown', (e) => {
					e.stopPropagation();
					startResize(e, handle.id);
				});
				
				transformGroup.appendChild(handleElement);
			});
			
			// Drag functionality is now handled in the main rect mousedown listener above
			
			svg.appendChild(transformGroup);
		}

		function startDrag(e) {
			if (!selectedRect) return;
			
			// Prevent any default drag behavior
			e.preventDefault();
			e.stopPropagation();
			
			isDragging = true;
			dragStartX = e.clientX;
			dragStartY = e.clientY;
			
			document.addEventListener('mousemove', handleDrag);
			document.addEventListener('mouseup', stopDrag);
			
			// Set cursor for dragging
			document.body.style.cursor = 'move';
		}

		function handleDrag(e) {
			if (!isDragging || !selectedRect) return;
			
			const deltaX = e.clientX - dragStartX;
			const deltaY = e.clientY - dragStartY;
			
			// Get current position
			const currentX = parseFloat(selectedRect.getAttribute('x') || '0');
			const currentY = parseFloat(selectedRect.getAttribute('y') || '0');
			const width = parseFloat(selectedRect.getAttribute('width') || '0');
			const height = parseFloat(selectedRect.getAttribute('height') || '0');
			
			// Calculate scale factor based on SVG viewport
			const svg = selectedRect.closest('svg') as SVGSVGElement;
			const svgRect = svg.getBoundingClientRect();
			const viewBox = svg.viewBox.baseVal;
			const scaleX = viewBox.width / svgRect.width;
			const scaleY = viewBox.height / svgRect.height;
			
			// Calculate new position
			let newX = currentX + (deltaX * scaleX);
			let newY = currentY + (deltaY * scaleY);
			
			// Apply snapping if Ctrl key is pressed
			if (e.ctrlKey) {
				console.log('Ctrl key detected for snapping');
				const { xEdges, yEdges } = getAllRectEdges(selectedRect);
				console.log('Found edges - X:', xEdges.length.toFixed(2), 'Y:', yEdges.length.toFixed(2));
				
				// Find all possible snaps with their distances
				const snapCandidates = [];
				
				// Check snapping for left edge
				const leftSnapDistance = findSnapDistance(newX, xEdges, snapThreshold);
				if (leftSnapDistance.snap !== null) {
					snapCandidates.push({
						axis: 'x',
						edge: 'left',
						snapValue: leftSnapDistance.snap,
						distance: leftSnapDistance.distance,
						newPos: leftSnapDistance.snap
					});
				}
				
				// Check snapping for right edge  
				const rightSnapDistance = findSnapDistance(newX + width, xEdges, snapThreshold);
				if (rightSnapDistance.snap !== null) {
					snapCandidates.push({
						axis: 'x',
						edge: 'right',
						snapValue: rightSnapDistance.snap,
						distance: rightSnapDistance.distance,
						newPos: rightSnapDistance.snap - width
					});
				}
				
				// Check snapping for top edge
				const topSnapDistance = findSnapDistance(newY, yEdges, snapThreshold);
				if (topSnapDistance.snap !== null) {
					snapCandidates.push({
						axis: 'y',
						edge: 'top',
						snapValue: topSnapDistance.snap,
						distance: topSnapDistance.distance,
						newPos: topSnapDistance.snap
					});
				}
				
				// Check snapping for bottom edge
				const bottomSnapDistance = findSnapDistance(newY + height, yEdges, snapThreshold);
				if (bottomSnapDistance.snap !== null) {
					snapCandidates.push({
						axis: 'y',
						edge: 'bottom',
						snapValue: bottomSnapDistance.snap,
						distance: bottomSnapDistance.distance,
						newPos: bottomSnapDistance.snap - height
					});
				}
				
				// Find the closest snap (only one axis at a time)
				console.log('Snap candidates found:', snapCandidates.length);
				if (snapCandidates.length > 0) {
					const closestSnap = snapCandidates.reduce((closest, candidate) => 
						candidate.distance < closest.distance ? candidate : closest
					);
					
					console.log('Snapping to:', closestSnap.axis, 'at', closestSnap.snapValue, 'distance:', closestSnap.distance);
					
					// Apply only the closest snap
					if (closestSnap.axis === 'x') {
						newX = closestSnap.newPos;
						showSnapGuides(closestSnap.snapValue, null, selectedRect);
					} else {
						newY = closestSnap.newPos;
						showSnapGuides(null, closestSnap.snapValue, selectedRect);
					}
				} else {
					console.log('No snap candidates found');
					clearSnapGuides();
				}
			} else {
				// Clear snap guides when not snapping
				clearSnapGuides();
			}
			
			selectedRect.setAttribute('x', newX.toString());
			selectedRect.setAttribute('y', newY.toString());
			
			// Update transform handles
			updateTransformHandles();
			
			// Update properties panel with new values
			updatePropertiesPanel(selectedRect);
			
			dragStartX = e.clientX;
			dragStartY = e.clientY;
		}

		function stopDrag() {
			isDragging = false;
			document.removeEventListener('mousemove', handleDrag);
			document.removeEventListener('mouseup', stopDrag);
			
			// Clear snap guides
			clearSnapGuides();
			
			// Reset cursor
			document.body.style.cursor = 'default';
		}

		function startResize(e, handleId) {
			if (!selectedRect) return;
			
			// Prevent any default drag behavior
			e.preventDefault();
			e.stopPropagation();
			
			isResizing = true;
			resizeHandle = handleId;
			dragStartX = e.clientX;
			dragStartY = e.clientY;
			
			document.addEventListener('mousemove', handleResize);
			document.addEventListener('mouseup', stopResize);
		}

		function handleResize(e) {
			if (!isResizing || !selectedRect || !resizeHandle) return;
			
			const deltaX = e.clientX - dragStartX;
			const deltaY = e.clientY - dragStartY;
			
			// Get current rect properties
			const currentX = parseFloat(selectedRect.getAttribute('x') || '0');
			const currentY = parseFloat(selectedRect.getAttribute('y') || '0');
			const currentWidth = parseFloat(selectedRect.getAttribute('width') || '0');
			const currentHeight = parseFloat(selectedRect.getAttribute('height') || '0');
			
			// Calculate scale factor
			const svg = selectedRect.closest('svg');
			const svgRect = svg.getBoundingClientRect();
			const viewBox = svg.viewBox.baseVal;
			const scaleX = viewBox.width / svgRect.width;
			const scaleY = viewBox.height / svgRect.height;
			
			const scaledDeltaX = deltaX * scaleX;
			const scaledDeltaY = deltaY * scaleY;
			
			let newX = currentX;
			let newY = currentY;
			let newWidth = currentWidth;
			let newHeight = currentHeight;
			
			// Check if Shift key is pressed for center-based resizing
			const isShiftPressed = e.shiftKey;
			
			if (isShiftPressed) {
				// Center-based resizing: resize from center by moving both opposite edges/corners
				console.log('Shift+resize: resizing from center');
				
				// Calculate center point
				const centerX = currentX + currentWidth / 2;
				const centerY = currentY + currentHeight / 2;
				
				switch (resizeHandle) {
					// Corner handles - resize both dimensions from center
					case 'nw':
						newWidth = currentWidth - (scaledDeltaX * 2);
						newHeight = currentHeight - (scaledDeltaY * 2);
						newX = centerX - newWidth / 2;
						newY = centerY - newHeight / 2;
						break;
					case 'ne':
						newWidth = currentWidth + (scaledDeltaX * 2);
						newHeight = currentHeight - (scaledDeltaY * 2);
						newX = centerX - newWidth / 2;
						newY = centerY - newHeight / 2;
						break;
					case 'sw':
						newWidth = currentWidth - (scaledDeltaX * 2);
						newHeight = currentHeight + (scaledDeltaY * 2);
						newX = centerX - newWidth / 2;
						newY = centerY - newHeight / 2;
						break;
					case 'se':
						newWidth = currentWidth + (scaledDeltaX * 2);
						newHeight = currentHeight + (scaledDeltaY * 2);
						newX = centerX - newWidth / 2;
						newY = centerY - newHeight / 2;
						break;
					
					// Edge handles - resize only one dimension from center
					case 'n': // Top edge - resize height from center
						newHeight = currentHeight - (scaledDeltaY * 2);
						newY = centerY - newHeight / 2;
						break;
					case 'e': // Right edge - resize width from center
						newWidth = currentWidth + (scaledDeltaX * 2);
						newX = centerX - newWidth / 2;
						break;
					case 's': // Bottom edge - resize height from center
						newHeight = currentHeight + (scaledDeltaY * 2);
						newY = centerY - newHeight / 2;
						break;
					case 'w': // Left edge - resize width from center
						newWidth = currentWidth - (scaledDeltaX * 2);
						newX = centerX - newWidth / 2;
						break;
				}
			} else {
				// Normal resizing: resize from the selected edge/corner
				switch (resizeHandle) {
					// Corner handles
					case 'nw':
						newX = currentX + scaledDeltaX;
						newY = currentY + scaledDeltaY;
						newWidth = currentWidth - scaledDeltaX;
						newHeight = currentHeight - scaledDeltaY;
						break;
					case 'ne':
						newY = currentY + scaledDeltaY;
						newWidth = currentWidth + scaledDeltaX;
						newHeight = currentHeight - scaledDeltaY;
						break;
					case 'sw':
						newX = currentX + scaledDeltaX;
						newWidth = currentWidth - scaledDeltaX;
						newHeight = currentHeight + scaledDeltaY;
						break;
					case 'se':
						newWidth = currentWidth + scaledDeltaX;
						newHeight = currentHeight + scaledDeltaY;
						break;
					
					// Edge handles
					case 'n': // Top edge
						newY = currentY + scaledDeltaY;
						newHeight = currentHeight - scaledDeltaY;
						break;
					case 'e': // Right edge
						newWidth = currentWidth + scaledDeltaX;
						break;
					case 's': // Bottom edge
						newHeight = currentHeight + scaledDeltaY;
						break;
					case 'w': // Left edge
						newX = currentX + scaledDeltaX;
						newWidth = currentWidth - scaledDeltaX;
						break;
				}
			}
			
			// Prevent negative dimensions
			if (newWidth > 5 && newHeight > 5) {
				selectedRect.setAttribute('x', newX.toString());
				selectedRect.setAttribute('y', newY.toString());
				selectedRect.setAttribute('width', newWidth.toString());
				selectedRect.setAttribute('height', newHeight.toString());
				
				// Update transform handles
				updateTransformHandles();
				
				// Update properties panel with new values
				updatePropertiesPanel(selectedRect);
			}
			
			dragStartX = e.clientX;
			dragStartY = e.clientY;
		}

		function stopResize() {
			isResizing = false;
			resizeHandle = null;
			document.removeEventListener('mousemove', handleResize);
			document.removeEventListener('mouseup', stopResize);
		}

		function updateTransformHandles() {
			const transformGroup = document.querySelector('.transform-group');
			if (!transformGroup || !selectedRect) return;
			
			const x = parseFloat(selectedRect.getAttribute('x') || '0');
			const y = parseFloat(selectedRect.getAttribute('y') || '0');
			const width = parseFloat(selectedRect.getAttribute('width') || '0');
			const height = parseFloat(selectedRect.getAttribute('height') || '0');
			
			const handles = transformGroup.querySelectorAll('.transform-handle');
			handles.forEach(handle => {
				const handleElement = handle as HTMLElement;
				const handleId = handleElement.dataset.handleId;
				const handleType = handleElement.dataset.handleType;
				
				if (handleType === 'corner') {
					// Update corner handles (circles)
					switch (handleId) {
						case 'nw':
							handle.setAttribute('cx', x.toString());
							handle.setAttribute('cy', y.toString());
							break;
						case 'ne':
							handle.setAttribute('cx', (x + width).toString());
							handle.setAttribute('cy', y.toString());
							break;
						case 'sw':
							handle.setAttribute('cx', x.toString());
							handle.setAttribute('cy', (y + height).toString());
							break;
						case 'se':
							handle.setAttribute('cx', (x + width).toString());
							handle.setAttribute('cy', (y + height).toString());
							break;
					}
				} else {
					// Update edge handles (thin lines spanning full width/height)
					switch (handleId) {
						case 'n': // Top edge - spans full width
							handle.setAttribute('x', x.toString());
							handle.setAttribute('y', (y - 1).toString());
							handle.setAttribute('width', width.toString());
							handle.setAttribute('height', '2');
							break;
						case 'e': // Right edge - spans full height
							handle.setAttribute('x', (x + width - 1).toString());
							handle.setAttribute('y', y.toString());
							handle.setAttribute('width', '2');
							handle.setAttribute('height', height.toString());
							break;
						case 's': // Bottom edge - spans full width
							handle.setAttribute('x', x.toString());
							handle.setAttribute('y', (y + height - 1).toString());
							handle.setAttribute('width', width.toString());
							handle.setAttribute('height', '2');
							break;
						case 'w': // Left edge - spans full height
							handle.setAttribute('x', (x - 1).toString());
							handle.setAttribute('y', y.toString());
							handle.setAttribute('width', '2');
							handle.setAttribute('height', height.toString());
							break;
					}
				}
			});
		}

		// Global drag prevention as final safety net
		document.addEventListener('dragstart', (e) => {
			// Allow file drag-drop but prevent SVG element dragging
			const target = e.target as HTMLElement;
			if (target && (target.tagName === 'rect' || target.tagName === 'svg' || target.closest('svg'))) {
				console.log('Global dragstart prevention triggered');
				e.preventDefault();
				e.stopImmediatePropagation();
				return false;
			}
		}, true);

		// Event listeners
		const fileInput = document.getElementById("myFile");
		
		// File input change event
		fileInput.addEventListener("change", (e) => {
			const target = e.target as HTMLInputElement;
			handleFileChange(target.files);
		});

		// Drag and drop functionality
		document.body.addEventListener("dragover", (e) => {
			// Only show drag prompt for actual file drag operations
			if (e.dataTransfer && e.dataTransfer.types.includes('Files')) {
				e.preventDefault();
				document.querySelector(".drag-drop-prompt")?.classList.add("appear");
			}
		});

		document.body.addEventListener("dragleave", (e) => {
			// Only hide if leaving the entire body and it's a file drag
			if (e.dataTransfer && e.dataTransfer.types.includes('Files') && !document.body.contains(e.relatedTarget as Node)) {
				document.querySelector(".drag-drop-prompt")?.classList.remove("appear");
			}
		});

		document.body.addEventListener("drop", (e) => {
			// Only handle file drops, not element drags
			if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files.length > 0) {
			e.preventDefault();
				document.querySelector(".drag-drop-prompt")?.classList.remove("appear");
			handleFileChange(e.dataTransfer.files);
			}
		});

		// Export SVG functionality
		document.getElementById("export-svg-btn").addEventListener("click", () => {
			exportCleanSVG();
		});

		document.getElementById("export-bundle-svg-btn")?.addEventListener("click", async () => {
			const btn = document.getElementById(
				"export-bundle-svg-btn",
			) as HTMLButtonElement | null;
			if (btn) btn.disabled = true;
			try {
				await exportBundleSvg();
			} catch (err) {
				console.error(err);
				alert(
					`Bundle export failed.\n\n${err instanceof Error ? err.message : String(err)}`,
				);
			} finally {
				if (btn) btn.disabled = false;
			}
		});

		// Add Rectangle button functionality
		document.getElementById("add-rect-btn").addEventListener("click", () => {
			toggleAddRectMode();
		});

		document.getElementById("brush-manual")?.addEventListener("change", updateBrushPaddingVisibility);
		document.getElementById("brush-auto")?.addEventListener("change", updateBrushPaddingVisibility);
		updateBrushPaddingVisibility();

		function isDeleteKey(e: KeyboardEvent) {
			return (
				e.key === "Delete" ||
				e.key === "Backspace" ||
				e.code === "Delete" ||
				e.code === "Backspace"
			);
		}

		// Keyboard shortcuts (capture so toolbar radio focus does not block Delete)
		window.addEventListener(
			"keydown",
			(e) => {
			if (isTypingInInput()) return;

			if (isDeleteKey(e)) {
				if (selectedRect) {
					e.preventDefault();
					deleteSelectedRect();
				}
				return;
			}
			
			// Ctrl+C - copy selected rect
			if (e.ctrlKey && e.key === "c") {
				if (selectedRect) {
					e.preventDefault();
					copySelectedRect();
				}
			}
			
			// Ctrl+V - paste copied rect
			if (e.ctrlKey && e.key === "v") {
				if (copiedRect) {
					e.preventDefault();
					pasteRect();
				}
			}
			
			// Ctrl+L - activate Add Rectangle mode
			if (e.ctrlKey && e.key === "l") {
				e.preventDefault();
				toggleAddRectMode();
			}
			
			if (e.key === "Escape") {
				if (isRubberBandDrawing) {
					e.preventDefault();
					cancelRubberBandDraw();
					return;
				}
				if (isAddRectMode) {
					e.preventDefault();
					exitAddRectMode();
				}
			}
			},
			true,
		);

		function cleanSvgForExport(svgClone: SVGElement) {
			svgClone.querySelectorAll(".transform-group").forEach((g) => g.remove());
			svgClone.querySelectorAll(".rubber-band-preview").forEach((el) => el.remove());
			svgClone.querySelector("#interaction-plane")?.remove();

			const rects = getContentRects(svgClone as unknown as SVGSVGElement);
			rects.forEach((rect) => {
				rect.classList.remove("rect-selected");
				rect.removeAttribute("style");
			});

			svgClone.querySelectorAll("*").forEach((element) => {
				element.removeAttribute("draggable");
				element.classList.remove("hovered");
			});

			svgClone.removeAttribute("data-converted-from-bundle");
			svgClone.removeAttribute("data-mask-editor-prepared");
			svgClone.removeAttribute("data-mask-editor-bundle");
		}

		function exportCleanSVG() {
			const currentSvg = globalSvgContainer.querySelector("svg");
			if (!currentSvg) {
				alert("No SVG loaded to export");
				return;
			}

			const svgClone = currentSvg.cloneNode(true) as SVGElement;
			cleanSvgForExport(svgClone);

			const filename =
				(document.getElementById("export-filename") as HTMLInputElement).value ||
				currentFileName ||
				"exported-svg";
			const outName = filename.endsWith(".svg") ? filename : filename + ".svg";

			const svgString = new XMLSerializer().serializeToString(svgClone);
			triggerDownload(new Blob([svgString], { type: "image/svg+xml" }), outName);
			console.log("SVG overlay exported successfully");
		}

		async function exportSoluisPatchBundleSvg(
			overlay: SVGSVGElement,
			meta: BundleSourceMeta,
		) {
			const sourceVb = parseViewBoxAttr(
				(() => {
					const tmp = document.createElementNS(SVG_NS, "svg");
					tmp.setAttribute("viewBox", meta.sourceViewBox);
					return tmp;
				})(),
			);
			const overlayVb = parseViewBoxAttr(overlay);

			const dimsBackgroundHref = await buildDimsBackgroundForExport(
				meta,
				sourceVb,
			);

			const out = document.createElementNS(SVG_NS, "svg");
			out.setAttribute("xmlns", SVG_NS);
			out.setAttribute("xmlns:xlink", XLINK_NS);
			out.setAttribute("viewBox", meta.sourceViewBox);
			out.setAttribute("width", meta.svgWidth);
			out.setAttribute("height", meta.svgHeight);
			out.setAttribute("preserveAspectRatio", meta.preserveAspectRatio);

			const root = document.createElementNS(SVG_NS, "g");
			root.setAttribute("id", "root");

			const bg = document.createElementNS(SVG_NS, "image");
			bg.setAttribute("id", "dims_background");
			bg.setAttribute("x", String(sourceVb.x));
			bg.setAttribute("y", String(sourceVb.y));
			bg.setAttribute("width", String(sourceVb.w));
			bg.setAttribute("height", String(sourceVb.h));
			bg.setAttribute("preserveAspectRatio", "none");
			bg.setAttribute("href", dimsBackgroundHref);
			bg.setAttributeNS(XLINK_NS, "href", dimsBackgroundHref);
			root.appendChild(bg);

			let patchNum = 1;
			let patchCount = 0;
			for (const rect of getContentRects(overlay)) {
				const box = unmapRectAttrsFromOverlay(rect, overlayVb, sourceVb);
				if (box.w <= 0 || box.h <= 0) continue;

				const patchHref = await cropRegionFromRasterDataUrl(
					meta.canonicalMergedDataUrl,
					box,
					sourceVb,
				);

				let patchId = rect.getAttribute("data-patch-id") || "";
				if (!patchId || !/^patch_\d+$/i.test(patchId)) {
					patchId = `patch_${patchNum++}`;
				}

				const patchG = document.createElementNS(SVG_NS, "g");
				patchG.setAttribute("id", patchId);
				const img = document.createElementNS(SVG_NS, "image");
				img.setAttribute("x", String(box.x));
				img.setAttribute("y", String(box.y));
				img.setAttribute("width", String(box.w));
				img.setAttribute("height", String(box.h));
				img.setAttribute("preserveAspectRatio", "none");
				img.setAttribute("href", patchHref);
				img.setAttributeNS(XLINK_NS, "href", patchHref);
				patchG.appendChild(img);
				appendPatchPathElement(patchG, box);
				root.appendChild(patchG);
				patchCount++;
			}

			out.appendChild(root);
			console.log(
				`Exported full canonical dims_background + ${patchCount} patch crop(s) at current mask positions`,
			);
			return out;
		}

		async function exportBundleSvg() {
			const overlay = globalSvgContainer.querySelector("svg") as SVGSVGElement | null;
			if (!overlay) {
				alert("No SVG loaded to export");
				return;
			}

			if (!canExportBundleSvg()) {
				alert(
					"Bundle export needs a combined floorplan import, or a PNG/JPEG backplate with an SVG overlay loaded.",
				);
				return;
			}

			const exportMeta = await resolveBundleExportMeta(overlay);
			const patchCount = getContentRects(overlay).length;
			if (exportMeta.exportFormat === "soluis-root" && patchCount === 0) {
				alert(
					"Add at least one mask rectangle before exporting a Soluis patch bundle.",
				);
				return;
			}

			const filename =
				(document.getElementById("export-filename") as HTMLInputElement).value ||
				currentFileName ||
				"exported-svg";
			const outName = filename.endsWith(".svg") ? filename : filename + ".svg";

			if (exportMeta.exportFormat === "soluis-root") {
				const out = await exportSoluisPatchBundleSvg(overlay, exportMeta);
				const svgString = new XMLSerializer().serializeToString(out);
				triggerDownload(new Blob([svgString], { type: "image/svg+xml" }), outName);
				console.log("Soluis patch bundle SVG exported successfully");
				return;
			}

			const {
				viewBox,
				preserveAspectRatio,
				canonicalMergedDataUrl,
				floorplanRasterDataUrl,
			} = exportMeta;
			const vb = parseViewBoxAttr(
				(() => {
					const tmp = document.createElementNS(SVG_NS, "svg");
					tmp.setAttribute("viewBox", viewBox);
					return tmp;
				})(),
			);

			const out = document.createElementNS(SVG_NS, "svg");
			out.setAttribute("xmlns", SVG_NS);
			out.setAttribute("xmlns:xlink", XLINK_NS);
			out.setAttribute("viewBox", viewBox);
			out.setAttribute("preserveAspectRatio", preserveAspectRatio);
			out.setAttribute("data-mask-editor-bundle", "true");

			const style = overlay.querySelector("style");
			if (style) out.appendChild(style.cloneNode(true));

			const rasterGroup = document.createElementNS(SVG_NS, "g");
			rasterGroup.setAttribute("id", "floorplan-raster");
			rasterGroup.setAttribute("pointer-events", "none");

			const embedded = document.createElementNS(SVG_NS, "image");
			const rasterUrl = floorplanRasterDataUrl || canonicalMergedDataUrl;
			embedded.setAttribute("href", rasterUrl);
			embedded.setAttributeNS(XLINK_NS, "href", rasterUrl);
			embedded.setAttribute("x", String(vb.x));
			embedded.setAttribute("y", String(vb.y));
			embedded.setAttribute("width", String(vb.w));
			embedded.setAttribute("height", String(vb.h));
			embedded.setAttribute("preserveAspectRatio", "none");
			rasterGroup.appendChild(embedded);
			out.appendChild(rasterGroup);

			const dims = overlay.querySelector("#dims-reference");
			if (dims) {
				out.appendChild(dims.cloneNode(true));
			}

			const maskGroup = document.createElementNS(SVG_NS, "g");
			maskGroup.setAttribute("id", "mask-rects");
			getContentRects(overlay).forEach((rect) => {
				const clone = rect.cloneNode(true) as SVGRectElement;
				clone.classList.remove("rect-selected");
				clone.removeAttribute("style");
				maskGroup.appendChild(clone);
			});
			out.appendChild(maskGroup);

			const svgString = new XMLSerializer().serializeToString(out);
			triggerDownload(new Blob([svgString], { type: "image/svg+xml" }), outName);
			console.log("Bundle SVG exported successfully");
		}

		// Move keyboard event listener to end of script

		// Helper function to check if user is typing in an input field
		function isTypingInInput() {
			const el = document.activeElement;
			if (!el || el === document.body) return false;
			if (el instanceof HTMLElement && el.isContentEditable) return true;
			if (el instanceof HTMLTextAreaElement) return true;
			if (el instanceof HTMLSelectElement) return true;
			if (el instanceof HTMLInputElement) {
				const t = el.type.toLowerCase();
				if (t === "radio" || t === "checkbox" || t === "button" || t === "submit" || t === "reset" || t === "file") {
					return false;
				}
				return true;
			}
			return false;
		}

		// Function to delete the selected rect
		function deleteSelectedRect() {
			console.log('deleteSelectedRect called, selectedRect:', selectedRect);
			
			if (!selectedRect) {
				console.log('No selectedRect to delete');
				return;
			}
			
			console.log('Deleting selected rect');
			
			// Store reference before deselecting
			const rectToDelete = selectedRect;
			
			// Remove transform handles
			deselectRect();
			
			// Remove the rect from the DOM
			rectToDelete.remove();
			
			console.log('Rect deleted successfully');
			
			// Update properties panel
			updatePropertiesPanel(null);
		}

		// Function to copy the selected rect
		function copySelectedRect() {
			if (!selectedRect) return;
			
			// Store all attributes of the selected rect
			copiedRect = {
				x: selectedRect.getAttribute('x'),
				y: selectedRect.getAttribute('y'),
				width: selectedRect.getAttribute('width'),
				height: selectedRect.getAttribute('height'),
				fill: selectedRect.getAttribute('fill'),
				stroke: selectedRect.getAttribute('stroke'),
				strokeWidth: selectedRect.getAttribute('stroke-width'),
				opacity: selectedRect.getAttribute('opacity'),
				// Store any other attributes
				attributes: {}
			};
			
			// Copy all other attributes
			for (let i = 0; i < selectedRect.attributes.length; i++) {
				const attr = selectedRect.attributes[i];
				if (!['x', 'y', 'width', 'height', 'fill', 'stroke', 'stroke-width', 'opacity'].includes(attr.name)) {
					copiedRect.attributes[attr.name] = attr.value;
				}
			}
			
			console.log('Rect copied to clipboard');
		}

		// Function to paste the copied rect
		function pasteRect() {
			if (!copiedRect) return;
			
			const currentSvg = globalSvgContainer.querySelector('svg');
			if (!currentSvg) {
				console.log('No SVG available to paste rect into');
				return;
			}

			// Create new rect element
			const newRect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
			
			// Apply stored attributes
			newRect.setAttribute('x', parseFloat(copiedRect.x) + 20); // Offset by 20px
			newRect.setAttribute('y', parseFloat(copiedRect.y) + 20); // Offset by 20px
			newRect.setAttribute('width', copiedRect.width);
			newRect.setAttribute('height', copiedRect.height);
			
			if (copiedRect.fill) newRect.setAttribute('fill', copiedRect.fill);
			if (copiedRect.stroke) newRect.setAttribute('stroke', copiedRect.stroke);
			if (copiedRect.strokeWidth) newRect.setAttribute('stroke-width', copiedRect.strokeWidth);
			if (copiedRect.opacity) newRect.setAttribute('opacity', copiedRect.opacity);
			
			// Apply other attributes
			Object.entries(copiedRect.attributes).forEach(([name, value]) => {
				newRect.setAttribute(name, value);
			});
			
			// Add the rect to the mask layer
			appendMaskRect(currentSvg as SVGSVGElement, newRect);
			
			// Add event listeners to the new rect
			addRectEventListeners(newRect);
			
			// Select the new rect
			selectRect(newRect);
			
			console.log('Rect pasted');
		}

		// Function to add event listeners to a rect element
		function addRectEventListeners(rect) {
			rect.style.cursor = 'pointer';
			rect.setAttribute('draggable', 'false');
			rect.style.userSelect = 'none';
			rect.style.webkitUserSelect = 'none';
			rect.style.webkitUserDrag = 'none';
			
			// Set opacity to 80% for transparency using SVG attribute
			rect.setAttribute('opacity', '0.8');
			rect.style.webkitTouchCallout = 'none';
			
			// Prevent context menu
			rect.addEventListener('contextmenu', (e) => {
				e.preventDefault();
				return false;
			});
			
			// Click event removed - selection now happens on mousedown for immediate drag
			
			// MOST IMPORTANT: Prevent dragstart in capture phase
			rect.addEventListener('dragstart', (e) => {
				console.log('Rect dragstart prevented');
				e.preventDefault();
				e.stopImmediatePropagation();
				return false;
			}, true);
			
			rect.addEventListener('drag', (e) => {
				e.preventDefault();
				e.stopImmediatePropagation();
				return false;
			}, true);
			
			rect.addEventListener('selectstart', (e) => {
				e.preventDefault();
				e.stopImmediatePropagation();
				return false;
			}, true);
			
			// Prevent mousedown from starting browser drag
			rect.addEventListener('mousedown', (e) => {
				console.log('Rect mousedown - clicked on rect:', rect);
				e.preventDefault();
				e.stopPropagation(); // Stop bubbling to parent elements
				
				// Select the rect first
				console.log('Calling selectRect...');
				selectRect(rect);
				console.log('selectRect called, selectedRect:', selectedRect);
				
				// Check for Alt/Option key for duplication mode
				if (e.altKey) {
					startDuplicationDrag(e, rect);
				} else {
					startDrag(e);
				}
				return false;
			}, true); // Capture phase - fires before bubble phase handlers
		}

		// Function to start duplication drag mode
		function startDuplicationDrag(e, rect) {
			console.log('Starting duplication drag mode');
			
			// Store original rect reference
			originalRect = rect;
			
			// Create duplicated rect but don't position it yet
			const currentSvg = globalSvgContainer.querySelector('svg');
			if (!currentSvg) return;
			
			duplicatedRect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
			
			// Copy all attributes from the original rect
			for (let i = 0; i < originalRect.attributes.length; i++) {
				const attr = originalRect.attributes[i];
				duplicatedRect.setAttribute(attr.name, attr.value);
			}
			
			appendMaskRect(currentSvg as SVGSVGElement, duplicatedRect);
			
			// Add event listeners
			addRectEventListeners(duplicatedRect);
			
			// Select the duplicated rect
			selectRect(duplicatedRect);
			
			// Set duplication mode
			isDuplicating = true;
			isDragging = true;
			dragStartX = e.clientX;
			dragStartY = e.clientY;
			
			// Add event listeners for duplication drag
			document.addEventListener('mousemove', handleDuplicationDrag);
			document.addEventListener('mouseup', stopDuplicationDrag);
			
			// Set cursor for dragging
			document.body.style.cursor = 'copy';
		}

		// Function to handle duplication drag movement
		function handleDuplicationDrag(e) {
			if (!isDuplicating || !originalRect || !duplicatedRect) return;
			
			const deltaX = e.clientX - dragStartX;
			const deltaY = e.clientY - dragStartY;
			
			// Get original rect position
			const originalX = parseFloat(originalRect.getAttribute('x') || '0');
			const originalY = parseFloat(originalRect.getAttribute('y') || '0');
			
			// Calculate scale factor based on SVG viewport
			const svg = duplicatedRect.closest('svg') as SVGSVGElement;
			const svgRect = svg.getBoundingClientRect();
			const viewBox = svg.viewBox.baseVal;
			const scaleX = viewBox.width / svgRect.width;
			const scaleY = viewBox.height / svgRect.height;
			
			// Calculate new position based on cursor translation
			const newX = originalX + (deltaX * scaleX);
			const newY = originalY + (deltaY * scaleY);
			
			// Apply snapping if Ctrl key is pressed
			let finalX = newX;
			let finalY = newY;
			
			if (e.ctrlKey) {
				console.log('Ctrl key detected for duplication snapping');
				const { xEdges, yEdges } = getAllRectEdges(duplicatedRect);
				console.log('Found edges for duplication - X:', xEdges.length, 'Y:', yEdges.length);
				
				const width = parseFloat(duplicatedRect.getAttribute('width') || '0');
				const height = parseFloat(duplicatedRect.getAttribute('height') || '0');
				
				// Find all possible snaps with their distances
				const snapCandidates = [];
				
				// Check snapping for left edge
				const leftSnapDistance = findSnapDistance(newX, xEdges, snapThreshold);
				if (leftSnapDistance.snap !== null) {
					snapCandidates.push({
						axis: 'x',
						edge: 'left',
						snapValue: leftSnapDistance.snap,
						distance: leftSnapDistance.distance,
						newPos: leftSnapDistance.snap
					});
				}
				
				// Check snapping for right edge  
				const rightSnapDistance = findSnapDistance(newX + width, xEdges, snapThreshold);
				if (rightSnapDistance.snap !== null) {
					snapCandidates.push({
						axis: 'x',
						edge: 'right',
						snapValue: rightSnapDistance.snap,
						distance: rightSnapDistance.distance,
						newPos: rightSnapDistance.snap - width
					});
				}
				
				// Check snapping for top edge
				const topSnapDistance = findSnapDistance(newY, yEdges, snapThreshold);
				if (topSnapDistance.snap !== null) {
					snapCandidates.push({
						axis: 'y',
						edge: 'top',
						snapValue: topSnapDistance.snap,
						distance: topSnapDistance.distance,
						newPos: topSnapDistance.snap
					});
				}
				
				// Check snapping for bottom edge
				const bottomSnapDistance = findSnapDistance(newY + height, yEdges, snapThreshold);
				if (bottomSnapDistance.snap !== null) {
					snapCandidates.push({
						axis: 'y',
						edge: 'bottom',
						snapValue: bottomSnapDistance.snap,
						distance: bottomSnapDistance.distance,
						newPos: bottomSnapDistance.snap - height
					});
				}
				
				// Find the closest snap (only one axis at a time)
				if (snapCandidates.length > 0) {
					const closestSnap = snapCandidates.reduce((closest, candidate) => 
						candidate.distance < closest.distance ? candidate : closest
					);
					
					console.log('Duplication snapping to:', closestSnap.axis, 'at', closestSnap.snapValue);
					
					// Apply only the closest snap
					if (closestSnap.axis === 'x') {
						finalX = closestSnap.newPos;
						showSnapGuides(closestSnap.snapValue, null, duplicatedRect);
					} else {
						finalY = closestSnap.newPos;
						showSnapGuides(null, closestSnap.snapValue, duplicatedRect);
					}
				} else {
					clearSnapGuides();
				}
			} else {
				// Clear snap guides when not snapping
				clearSnapGuides();
			}
			
			// Update duplicated rect position
			duplicatedRect.setAttribute('x', finalX.toString());
			duplicatedRect.setAttribute('y', finalY.toString());
			
			// Update transform handles
			updateTransformHandles();
			
			// Update properties panel
			updatePropertiesPanel(duplicatedRect);
		}

		// Function to stop duplication drag
		function stopDuplicationDrag() {
			isDuplicating = false;
			isDragging = false;
			originalRect = null;
			duplicatedRect = null;
			
			document.removeEventListener('mousemove', handleDuplicationDrag);
			document.removeEventListener('mouseup', stopDuplicationDrag);
			
			// Clear snap guides
			clearSnapGuides();
			
			// Reset cursor
			document.body.style.cursor = 'default';
			
			console.log('Duplication drag completed');
		}

		// Function to toggle Add Rectangle mode
		function toggleAddRectMode() {
			isAddRectMode = !isAddRectMode;
			const button = document.getElementById('add-rect-btn');
			
			if (isAddRectMode) {
				button.style.background = '#dc3545'; // Red when active
				button.textContent = 'Exit Add Mode (Esc)';
				document.body.style.cursor = 'crosshair';
				console.log('Add Rectangle mode activated');
			} else {
				exitAddRectMode();
			}
		}

		// Function to exit Add Rectangle mode
		function exitAddRectMode() {
			isAddRectMode = false;
			isDrawingRect = false;
			const button = document.getElementById('add-rect-btn');
			button.style.background = '#28a745'; // Green when inactive
			button.textContent = 'Add Rectangle (Ctrl+L)';
			document.body.style.cursor = 'default';
			console.log('Add Rectangle mode deactivated');
		}

		// Function to get all rect edges for snapping
		function getDimReferenceEdges(svg: SVGSVGElement) {
			const xEdges: number[] = [];
			const yEdges: number[] = [];
			const ref = svg.querySelector("#dims-reference");
			if (!ref) return { xEdges, yEdges };

			ref.querySelectorAll("line").forEach((line) => {
				const x1 = parseFloat(line.getAttribute("x1") || "0");
				const y1 = parseFloat(line.getAttribute("y1") || "0");
				const x2 = parseFloat(line.getAttribute("x2") || "0");
				const y2 = parseFloat(line.getAttribute("y2") || "0");
				if (Math.abs(y1 - y2) < 1) {
					xEdges.push(x1, x2);
					yEdges.push(y1);
				} else if (Math.abs(x1 - x2) < 1) {
					yEdges.push(y1, y2);
					xEdges.push(x1);
				} else {
					xEdges.push(x1, x2);
					yEdges.push(y1, y2);
				}
			});

			return { xEdges, yEdges };
		}

		function getAllRectEdges(excludeRect) {
			const currentSvg = globalSvgContainer.querySelector("svg") as SVGSVGElement | null;
			if (!currentSvg) return { xEdges: [], yEdges: [] };
			
			const rects = getContentRects(currentSvg);
			const xEdges: number[] = [];
			const yEdges: number[] = [];
			
			console.log('getAllRectEdges: Found', rects.length, 'mask rects');
			
			rects.forEach(rect => {
				if (rect === excludeRect) return; // Skip the rect being dragged
				
				const x = parseFloat(rect.getAttribute('x') || '0');
				const y = parseFloat(rect.getAttribute('y') || '0');
				const width = parseFloat(rect.getAttribute('width') || '0');
				const height = parseFloat(rect.getAttribute('height') || '0');
				
				// Add all edges
				xEdges.push(x, x + width); // left and right edges
				yEdges.push(y, y + height); // top and bottom edges
				
				console.log('Added edges for rect:', x, y, width, height);
			});

			const dimEdges = getDimReferenceEdges(currentSvg);
			xEdges.push(...dimEdges.xEdges);
			yEdges.push(...dimEdges.yEdges);
			
			return { xEdges, yEdges };
		}
		
		// Function to find nearest snap position
		function findSnapPosition(currentPos, edges, threshold) {
			let nearestEdge = null;
			let minDistance = threshold;
			
			edges.forEach(edge => {
				const distance = Math.abs(currentPos - edge);
				if (distance < minDistance) {
					minDistance = distance;
					nearestEdge = edge;
				}
			});
			
			return nearestEdge;
		}

		// Function to find nearest snap position with distance
		function findSnapDistance(currentPos, edges, threshold) {
			let nearestEdge = null;
			let minDistance = threshold;
			
			edges.forEach(edge => {
				const distance = Math.abs(currentPos - edge);
				if (distance < minDistance) {
					minDistance = distance;
					nearestEdge = edge;
				}
			});
			
			return {
				snap: nearestEdge,
				distance: nearestEdge !== null ? minDistance : Infinity
			};
		}
		
		// Function to show snap guides
		function showSnapGuides(xSnap, ySnap, draggedRect) {
			console.log('showSnapGuides called with xSnap:', xSnap, 'ySnap:', ySnap);
			clearSnapGuides();
			
			const currentSvg = globalSvgContainer.querySelector('svg');
			if (!currentSvg) {
				console.log('No SVG found for snap guides');
				return;
			}
			
			const viewBox = currentSvg.viewBox.baseVal;
			console.log('SVG viewBox:', viewBox.x, viewBox.y, viewBox.width, viewBox.height);
			
			// Create snap guide group
			const guideGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
			guideGroup.classList.add('snap-guides');
			
			// Show vertical guide for x-snap (full height red line)
			if (xSnap !== null) {
				const vLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');
				vLine.setAttribute('x1', xSnap.toString());
				vLine.setAttribute('y1', viewBox.y.toString());
				vLine.setAttribute('x2', xSnap.toString());
				vLine.setAttribute('y2', (viewBox.y + viewBox.height).toString());
				vLine.classList.add('snap-guide');
				
				// Apply styles directly as well
				vLine.setAttribute('stroke', '#ff0066');
				vLine.setAttribute('stroke-width', '2');
				vLine.setAttribute('stroke-dasharray', '5,5');
				vLine.setAttribute('opacity', '0.9');
				vLine.style.pointerEvents = 'none';
				
				guideGroup.appendChild(vLine);
				console.log('Created vertical snap guide at x:', xSnap, 'from', viewBox.y, 'to', viewBox.y + viewBox.height);
			}
			
			// Show horizontal guide for y-snap (full width red line)
			if (ySnap !== null) {
				const hLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');
				hLine.setAttribute('x1', viewBox.x.toString());
				hLine.setAttribute('y1', ySnap.toString());
				hLine.setAttribute('x2', (viewBox.x + viewBox.width).toString());
				hLine.setAttribute('y2', ySnap.toString());
				hLine.classList.add('snap-guide');
				
				// Apply styles directly as well
				hLine.setAttribute('stroke', '#ff0066');
				hLine.setAttribute('stroke-width', '2');
				hLine.setAttribute('stroke-dasharray', '5,5');
				hLine.setAttribute('opacity', '0.9');
				hLine.style.pointerEvents = 'none';
				
				guideGroup.appendChild(hLine);
				console.log('Created horizontal snap guide at y:', ySnap, 'from', viewBox.x, 'to', viewBox.x + viewBox.width);
			}
			
			if (guideGroup.children.length > 0) {
				currentSvg.appendChild(guideGroup);
				snapGuides.push(guideGroup);
				console.log('Added snap guide group to SVG, total guides:', snapGuides.length);
			}
		}
		
		// Function to clear snap guides
		function clearSnapGuides() {
			console.log('Clearing', snapGuides.length, 'snap guides');
			snapGuides.forEach(guide => {
				if (guide.parentNode) {
					guide.parentNode.removeChild(guide);
				}
			});
			snapGuides = [];
		}

		// Function to add a rectangle at the clicked position
		function addRectangleAtPosition(event, svgElement) {
			// Get click position relative to SVG
			const svgRect = svgElement.getBoundingClientRect();
			const viewBox = svgElement.viewBox.baseVal;
			
			// Convert screen coordinates to SVG coordinates
			const scaleX = viewBox.width / svgRect.width;
			const scaleY = viewBox.height / svgRect.height;
			
			const clickX = (event.clientX - svgRect.left) * scaleX + viewBox.x;
			const clickY = (event.clientY - svgRect.top) * scaleY + viewBox.y;
			
			// Create new rect element
			const newRect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
			
			// Set default size and position (centered on click), scaled to viewBox
			const { width: defaultWidth, height: defaultHeight } = getDefaultRectSize(svgElement);
			newRect.setAttribute('x', (clickX - defaultWidth / 2).toString());
			newRect.setAttribute('y', (clickY - defaultHeight / 2).toString());
			newRect.setAttribute('width', defaultWidth.toString());
			newRect.setAttribute('height', defaultHeight.toString());
			
			// Set default styling
			newRect.setAttribute('fill', 'rgba(0, 123, 255, 0.3)');
			newRect.setAttribute('stroke', '#007bff');
			newRect.setAttribute('stroke-width', '2');
			
			// Add to mask layer
			appendMaskRect(svgElement, newRect);
			
			// Add event listeners
			addRectEventListeners(newRect);
			
			// Select the new rect
			selectRect(newRect);
			
			// Exit Add Rectangle mode
			exitAddRectMode();
			
			console.log('New rectangle added at position:', clickX, clickY);
		}

		// Function to update the properties panel
		function updatePropertiesPanel(rect) {
			const propertiesContent = document.getElementById('properties-content');
			
			if (!rect) {
				propertiesContent.innerHTML = '<p style="color: #666; margin: 10px 0;">Select a rect to view properties</p>';
				return;
			}
			
			// Get all attributes of the rect
			const attributes = {};
			for (let i = 0; i < rect.attributes.length; i++) {
				const attr = rect.attributes[i];
				const num = parseFloat(attr.value);
				if (!Number.isNaN(num)) {
					attributes[attr.name] = num.toFixed(2);
				} else {
					attributes[attr.name] = attr.value;
				}
			}
			
			// Create properties HTML
			let html = '<div style="max-height: 300px; overflow-y: auto;">';
			
			// Core properties first
			const coreProps = ['x', 'y', 'width', 'height'];
			coreProps.forEach(prop => {
				if (attributes[prop] !== undefined) {
					html += `
						<div style="margin-bottom: 8px; padding: 4px; background: #f5f5f5; border-radius: 3px;">
							<strong style="color: #333; font-size: 11px;">${prop}:</strong>
							<span style="color: #666; font-size: 11px; margin-left: 5px;">${attributes[prop]}</span>
						</div>
					`;
					delete attributes[prop]; // Remove from remaining attributes
				}
			});
			
			// Add separator if there are more attributes
			if (Object.keys(attributes).length > 0) {
				html += '<hr style="margin: 10px 0; border: none; border-top: 1px solid #ddd;">';
			}
			
			// Other attributes
			Object.entries(attributes).forEach(([key, value]) => {
				html += `
					<div style="margin-bottom: 6px; padding: 3px; background: #fafafa; border-radius: 2px;">
						<strong style="color: #555; font-size: 10px;">${key}:</strong>
						<span style="color: #777; font-size: 10px; margin-left: 5px; word-break: break-all;">${value}</span>
					</div>
				`;
			});
			
			html += '</div>';
			propertiesContent.innerHTML = html;
		}

	</script>
